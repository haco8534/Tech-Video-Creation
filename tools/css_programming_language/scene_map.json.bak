{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "id": 0,
      "title": "オープニング",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "今日のテーマは「CSSはプログラミング言語か？」なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "えっ、CSSってWebサイトの見た目を整えるやつですわよね？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。でもこの問い、SNSで毎年のように大論争になるんだよね。"
        },
        {
          "speaker": "めたん",
          "text": "たしかに、定期的に燃え上がっているのを見かけますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかもどちらの陣営も譲らない。なかなか決着がつかない問いなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "「当然プログラミング言語でしょ」という人と「絶対違う」という人がいますわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "中には「CSSが書けるだけではプログラマーとは呼べない」なんて意見もあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それはちょっと乱暴な気がしますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "実はこの問いに答えるには、まず「プログラミング言語とは何か」を考える必要があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "なるほど。定義から考えないといけないんですわね。"
        }
      ]
    },
    {
      "id": 1,
      "title": "CSSの存在感",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "その前に、CSSがどれくらい使われているか確認しておくのだ。"
        },
        {
          "speaker": "めたん",
          "text": "Webサイトを作る人はみんな使う印象ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "W3Techsの調査によると、全Webサイトの95%以上がCSSを使っているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "95%！ ほとんど全部じゃないですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Stack Overflowの2024年開発者調査でも、HTML/CSSの使用率は52%で全技術中2位なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "JavaScriptの62%に次ぐ2位ですわね。相当な存在感ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "さらにState of CSS 2024調査では、CSS変数の使用経験がある人は97%もいるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ほぼ全員が使っていますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "これだけ世界中で使われている言語の正体が、いまだに議論されているのは面白いよね。"
        },
        {
          "speaker": "めたん",
          "text": "たしかに不思議ですわ。そもそも「プログラミング言語」の定義って何なんですの？"
        }
      ]
    },
    {
      "id": 2,
      "title": "プログラミング言語の定義",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここが最大のポイントなのだ。実は学術的に統一された定義がないんだよね。"
        },
        {
          "speaker": "めたん",
          "text": "えっ、定義すらないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "よく使われる基準をいくつか紹介するのだ。まずは「チューリング完全であること」。"
        },
        {
          "speaker": "めたん",
          "text": "チューリング完全って何ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ざっくり言うと「どんな計算でもできる能力」のことなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "具体的には、条件分岐、繰り返し、メモリの読み書きができれば大体チューリング完全なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "PythonやJavaScriptはチューリング完全なんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "もちろんなのだ。でもここで面白い話があって、SQLの基本形はチューリング完全じゃないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あら、SQLって微妙な立ち位置ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "実はSQLも「プログラミング言語かどうか」は意見が分かれるのだ。問い合わせ言語だという人もいるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "CSSと同じような議論があるんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。つまりチューリング完全かどうかだけでは判定できないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "じゃあ他にどんな基準があるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "「コンピュータに対する指示を記述する言語かどうか」という広い定義もあるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "この定義だと、CSSはブラウザへの指示を書いているから該当するとも言えるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "定義によって答えが変わってしまうんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "さらに「ドメイン固有言語」、略してDSLという分類もあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "DSLって何ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "特定の問題領域に特化した言語のことなのだ。SQLはデータベース、CSSはスタイリングのDSLなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "DSLもプログラミング言語の一種と見なされるんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。だから「CSSはプログラミング言語か」の答えは、どの定義を採用するかで変わるのだ。"
        }
      ]
    },
    {
      "id": 3,
      "title": "CSSの進化年表",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "CSSの歴史を振り返ると、この議論がなぜ終わらないか見えてくるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "どういうことですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "CSSは1996年にW3Cの勧告として登場したのだ。ちょうど30年前なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "30年前のCSSって、今とは全然違うんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "全く別物なのだ。当時はフォントの色や大きさを変える程度のシンプルな言語だったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それだと「プログラミング言語ではない」と言われても仕方ないですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "提案者はHakon Wium Lieというノルウェーの研究者で、1994年にWebにスタイルシートが必要だと訴えたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "HTMLだけでは見た目の制御に限界があったんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもここからの進化がすごいのだ。2012年にcalc関数が登場したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "calc関数って何ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "CSS内で四則演算ができる機能なのだ。「100%から40ピクセル引く」なんて計算が書けるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "CSSの中で計算ができるんですの。それはプログラミングっぽいですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "さらにmin、max、clamp関数で値の範囲を制御できるようにもなったのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2017年にはCSS Custom Properties、つまりCSS変数が主要ブラウザで使えるようになったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "変数が使えるなら、ますますプログラミングっぽいですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "値を一箇所で定義して、あちこちで使い回せるのだ。色やサイズの管理がとても楽になったのだ。"
        }
      ]
    },
    {
      "id": 4,
      "title": ":hasの衝撃",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そして2022年、大きな転機が来たのだ。:has疑似クラスの登場なのだ。"
        },
        {
          "speaker": "めたん",
          "text": ":hasって何ができるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "「子要素の状態に応じて親要素のスタイルを変える」ことができるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "具体的にはどういうことですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "たとえばフォームの中に入力エラーがあったら、フォーム全体の枠を赤くするとか。"
        },
        {
          "speaker": "ずんだもん",
          "text": "画像を含むカードだけレイアウトを変えるとか。条件分岐に近いことができるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それってJavaScript無しでできるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "CSSだけでできるのだ。長年「CSSには無理」と言われていた親セレクタがついに実現したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "CSSの表現力がどんどん上がっていますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2023年にはCSS NestingとContainer Queriesも主要ブラウザで対応したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "NestingってSassにあった機能ですわよね。それがネイティブのCSSに来たんですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。Sassは2006年に登場して、変数やループ、条件分岐をCSSに持ち込んだのだ。"
        },
        {
          "speaker": "めたん",
          "text": "「CSSに足りないもの」をSassが補っていたんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも今はSassの人気機能がネイティブCSSに次々と取り込まれている流れなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "つまりCSSは「プログラミング言語的な方向」に進化し続けているんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通り。2024年には型付きカスタムプロパティを定義する@propertyも対応したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "型付きの変数ですの？ それはかなり本格的ですわね。"
        }
      ]
    },
    {
      "id": 5,
      "title": "5つの能力",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "では現代のCSSの能力を整理してみるのだ。プログラミング的にできることは大きく5つあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "5つも？ 聞かせてくださいですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1つ目は「演算」。calc、min、max、clampで数値計算ができるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2つ目は「変数」。Custom Propertiesで値を定義し、var関数で参照するのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "3つ目は「条件分岐」。メディアクエリ、:has、Container Queriesで状況に応じた切り替えができるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "4つ目は「繰り返し的な表現」。nth-childで偶数行だけ色を変えたり、counterで自動番号を振ったり。"
        },
        {
          "speaker": "ずんだもん",
          "text": "5つ目は「状態管理」。:hoverや:checkedでユーザーの操作に応じて表示を切り替えられるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "こうして並べると、かなりプログラミングっぽいことができるんですわね。"
        }
      ]
    },
    {
      "id": 6,
      "title": "CSSの限界",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ただし決定的に足りないものもあるのだ。ここは公平に見る必要があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "何が足りないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "まず「汎用的なロジック」が書けないのだ。データのソートや検索アルゴリズムは実装できないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "次に「関数定義」ができないのだ。自分で処理をまとめて名前をつけて再利用する仕組みがないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "SassにはあるけどCSSにはないんですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通りなのだ。ただしCSS Working Groupでは@functionの提案も議論されているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "将来的には関数も使えるかもしれないんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そして「入出力」がほぼないのだ。ファイル操作もネットワーク通信もできないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "見た目の制御だけに特化しているということですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "この限界が「プログラミング言語ではない」と言われる大きな理由なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "逆に言えば、CSSは「ビジュアルの制御」というドメインでは非常に強力ということですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "まさにそうなのだ。得意分野では他の言語にはできない表現ができるのだ。"
        }
      ]
    },
    {
      "id": 7,
      "title": "Rule 110",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで技術的に面白い話を紹介するのだ。CSSとチューリング完全性の議論なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "さっき出てきた「どんな計算でもできるか」の話ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2011年にEli Fox-Epsteinという人がCSSとHTMLだけでRule 110を実装したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "Rule 110って何ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "セル・オートマトンの一種で、2004年にチューリング完全であると証明された計算モデルなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それがCSSで動くなんて驚きですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "仕組みとしてはHTMLのチェックボックスを状態の記憶に使うのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": ":checkedと隣接セレクタを組み合わせて、状態の遷移をCSSで表現するのだ。"
        },
        {
          "speaker": "めたん",
          "text": "でもそれってユーザーがチェックボックスをクリックする必要がありますわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そこが議論のポイントなのだ。CSS単体では状態を自律的に進められないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから「CSSとHTMLの組み合わせは条件付きでチューリング完全」というのが妥当な見方なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "CSS単体だと不十分、でも組み合わせれば可能性がある、と。"
        }
      ]
    },
    {
      "id": 8,
      "title": "宣言型の世界",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで視点を変えて「宣言型プログラミング」について考えてみるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "宣言型？ 聞いたことはありますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "プログラミングには2つの大きなスタイルがあるのだ。命令型と宣言型なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "命令型は「どうやるか」を一歩ずつ書く。CやPythonがこのスタイルなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "宣言型は「何が欲しいか」だけ書く。処理の手順はコンピュータに任せるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "CSSはまさに「何が欲しいか」を書く言語ですわね。「この文字を赤くしたい」とか。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。そしてSQLも宣言型なのだ。「このデータが欲しい」と書くだけなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "SQLもプログラミング言語かどうかは微妙なんでしたわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。でもSQLを「プログラミング言語じゃない」と言う人はCSSほど多くないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "同じ宣言型なのに、CSSの方が厳しい目で見られがちなんですわね。"
        },
        {
          "speaker": "めたん",
          "text": "それはちょっと不公平な気もしますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかもCSSにはカスケードという独自の優先順位解決アルゴリズムがあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "カスケードって、スタイルの適用順序を決めるルールですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。詳細度という数値で優先順位を計算して、どのスタイルを適用するか決めるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "その計算ロジック自体がかなり「プログラミング的」ですわね。"
        }
      ]
    },
    {
      "id": 9,
      "title": "ゲートキーピング",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "この議論には技術だけでなく、文化的な側面もあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "文化的な側面ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "2010年代前半まで「フロントエンドは本物のプログラミングじゃない」という風潮があったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "そんな偏見があったんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "バックエンドやシステムプログラミングが「高度な仕事」で、CSSは「簡単な仕事」という見方なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "でも実際にCSSを極めるのは、かなりの専門知識が必要ですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通りなのだ。カスケードの優先順位、詳細度の計算、レイアウトアルゴリズム。奥がとても深いのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「CSSはプログラミング言語じゃない」という主張が、ゲートキーピングに使われることがあったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ゲートキーピングというと、仲間外れにする行為ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「CSSしか書けないならプログラマーとは呼べない」みたいな排他的な態度のことなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "技術の議論と人の価値を混同してはいけませんわね。"
        }
      ]
    },
    {
      "id": 10,
      "title": "スペクトラム",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そろそろ結論に向かうのだ。CSSはプログラミング言語か？"
        },
        {
          "speaker": "めたん",
          "text": "ここまで聞いてきて、単純にYES・NOとは言えない気がしますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "実はそれが一番正確な答えなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「プログラミング言語かどうか」は白黒ではなく、グラデーションとして捉えるのが健全なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "グラデーションというと？"
        },
        {
          "speaker": "ずんだもん",
          "text": "HTMLは構造を記述するマークアップ言語。CSSは宣言的なスタイリング言語なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "SQLは宣言的なドメイン特化言語で、これも分類が割れるのだ。PythonやCは汎用言語なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "これらは「プログラミング的かどうか」の軸で一列に並んでいるイメージなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "CSSはそのグラデーションの中間あたりにいるんですわね。"
        }
      ]
    },
    {
      "id": 11,
      "title": "本当に大切なこと",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "最後に大切なことを3つまとめるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1つ目。「プログラミング言語」に唯一の正解の定義はないのだ。基準次第で答えが変わるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2つ目。CSSは30年で劇的に進化したのだ。変数、演算、条件分岐がある現代のCSSは昔と別物なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "3つ目。大切なのは「何と呼ぶか」ではなく「何ができるか」なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ラベルに囚われるより、技術そのものを正しく理解することが大事なんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通りなのだ。CSSを書く人がプログラマーかどうかは、呼び方の問題に過ぎないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "今日はとても勉強になりましたわ。ありがとうございます。"
        },
        {
          "speaker": "ずんだもん",
          "text": "こちらこそなのだ。コメント欄であなたの意見も聞かせてほしいのだ。"
        },
        {
          "speaker": "めたん",
          "text": "「CSSはプログラミング言語だと思いますか？」ですわね。それではまた次回。"
        }
      ]
    }
  ]
}