{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "id": 0,
      "title": "オープニング",
      "lines": [
        {
          "speaker": "めたん",
          "text": "今日のテーマは「Rustは本当にC++を置き換えるのか？」ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Rustって最近すごく名前聞くけど、本当にC++を倒せるの？"
        },
        {
          "speaker": "めたん",
          "text": "鋭い疑問ですわね。データと事実で検証していきましょう。"
        }
      ]
    },
    {
      "id": 1,
      "title": "C++が支える世界",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まずC++って今どんなところで使われてるの？"
        },
        {
          "speaker": "めたん",
          "text": "ゲームエンジン、OS、組み込みシステム。社会インフラの根幹ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Unreal EngineもWindowsもLinuxもC++なんだよね。"
        },
        {
          "speaker": "めたん",
          "text": "40年以上の歴史を持つ、システムプログラミングの王者ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "じゃあなんでRustが生まれたの？"
        },
        {
          "speaker": "めたん",
          "text": "C++の最大の弱点——メモリ安全性の問題が深刻すぎたからですわ。"
        }
      ]
    },
    {
      "id": 2,
      "title": "メモリバグ70%",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "メモリ安全性の問題ってどのくらい深刻なの？"
        },
        {
          "speaker": "めたん",
          "text": "Microsoftの調査で、過去12年間のCVEの約70%がメモリ安全性の問題でしたの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "70%！？ バグの大半がメモリ関連ってこと？"
        },
        {
          "speaker": "めたん",
          "text": "Linuxカーネルでも脆弱性の約3分の2がメモリ安全性に起因しますのよ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それでRustが注目されてるんだね。"
        },
        {
          "speaker": "めたん",
          "text": "ええ。Rustはこれらのバグを「コンパイル時に物理的に不可能」にしますわ。"
        }
      ]
    },
    {
      "id": 3,
      "title": "所有権システム",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "Rustの「所有権」ってどういう仕組みなの？"
        },
        {
          "speaker": "めたん",
          "text": "C++では複数の変数が同じメモリを指せるので、ダングリングポインタが起きますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "解放されたメモリを参照しちゃうやつだね。"
        },
        {
          "speaker": "めたん",
          "text": "Rustでは所有者は必ず1つ。スコープを抜けると自動でメモリが解放されますの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ガベージコレクションなしで安全ってすごいね！"
        },
        {
          "speaker": "めたん",
          "text": "コンパイラが全チェックするから、実行時オーバーヘッドもゼロですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それでC++並みの速度と安全を両立できるんだね。"
        }
      ]
    },
    {
      "id": 4,
      "title": "性能比較",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "でもRustって本当にC++と同じくらい速いの？"
        },
        {
          "speaker": "めたん",
          "text": "CPUバウンドな処理ではほぼ同等ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "差があるところは？"
        },
        {
          "speaker": "めたん",
          "text": "並行・非同期処理ではRustが10〜20%速いケースもありますの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "逆にC++の方が速い場面は？"
        },
        {
          "speaker": "めたん",
          "text": "SIMDなど超低レベルのHPC最適化では、まだC++がやや優位ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "性能はほぼ互角で、安全性でRustが圧勝ってことか。"
        },
        {
          "speaker": "めたん",
          "text": "そうなりますわね。"
        }
      ]
    },
    {
      "id": 5,
      "title": "Android事例",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "実際に大企業はRustを使ってるの？"
        },
        {
          "speaker": "めたん",
          "text": "代表例はGoogleのAndroidですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "どんな成果が出たの？"
        },
        {
          "speaker": "めたん",
          "text": "Rust導入後、メモリ安全性の脆弱性が76%から24%に激減しましたの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "5年で3分の1以下に！？"
        },
        {
          "speaker": "めたん",
          "text": "件数で言えば、223件から50件以下になりましたわ。"
        }
      ]
    },
    {
      "id": 6,
      "title": "企業採用一覧",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "他の企業はどうなの？"
        },
        {
          "speaker": "めたん",
          "text": "MicrosoftはWindowsカーネルにRustを導入していますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "カーネルに！？"
        },
        {
          "speaker": "めたん",
          "text": "さらにAIでC/C++ 10億行をRustに書き換える研究も進行中ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Linuxカーネルは？"
        },
        {
          "speaker": "めたん",
          "text": "2025年のメンテナーサミットでRustの永続統合が正式決定しましたわ。"
        }
      ]
    },
    {
      "id": 7,
      "title": "クラウド企業",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "クラウド系の企業は？"
        },
        {
          "speaker": "めたん",
          "text": "CloudflareはC++製NginxプロキシをRust製Pingoraに完全移行しましたの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "完全移行ってすごい決断だね。成果は？"
        },
        {
          "speaker": "めたん",
          "text": "CPU使用率が削減され、応答速度も向上しましたわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "AWSやDiscordも使ってるんだよね。"
        },
        {
          "speaker": "めたん",
          "text": "ええ。AWSのFirecrackerは完全Rust製。DiscordもRust移行で性能改善ですわ。"
        }
      ]
    },
    {
      "id": 8,
      "title": "政府も動いた",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "企業だけじゃなくて政府も動いてるって本当？"
        },
        {
          "speaker": "めたん",
          "text": "2024年、米国ホワイトハウスがC/C++からRustへの移行を公式に推奨しましたの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ホワイトハウスが！？"
        },
        {
          "speaker": "めたん",
          "text": "DARPAもC/C++をRustに自動変換するAIに投資していますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "国家レベルの戦略転換なんだね。"
        },
        {
          "speaker": "めたん",
          "text": "2026年までに移行ロードマップの策定を企業に求めていますの。"
        }
      ]
    },
    {
      "id": 9,
      "title": "C++の牙城",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "じゃあすぐにC++はなくなるの？"
        },
        {
          "speaker": "めたん",
          "text": "それはありえませんわ。C++が支える世界は巨大すぎますの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "たとえばどのくらい？"
        },
        {
          "speaker": "めたん",
          "text": "ゲームエンジン、車載システム、HPC。天文学的な量のコードが存在しますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "全部書き換えるのは無理だよね。"
        },
        {
          "speaker": "めたん",
          "text": "しかもRustは学習コストが高い。所有権の概念は独特ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "じゃあRustとC++はどう共存していくの？"
        }
      ]
    },
    {
      "id": 10,
      "title": "段階的移行",
      "lines": [
        {
          "speaker": "めたん",
          "text": "現実的には、既存C++は維持しつつ新規コンポーネントでRustを採用しますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "一気に置き換えじゃなくて段階的なんだね。"
        },
        {
          "speaker": "めたん",
          "text": "RustはC FFIで既存のC/C++コードと連携できますの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "セキュリティが重要なところから順にRustに？"
        },
        {
          "speaker": "めたん",
          "text": "まさにそうですわ。「全置き換え」ではなく「段階的共存」が現実解ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "GoogleもMicrosoftもそのアプローチだもんね。"
        },
        {
          "speaker": "めたん",
          "text": "歴史あるコードベースは尊重しつつ、新しい領域でRustを活用する時代ですわ。"
        }
      ]
    },
    {
      "id": 11,
      "title": "まとめ3つ",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "じゃあ結論をまとめてよ！"
        },
        {
          "speaker": "めたん",
          "text": "3つのポイントですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1つ目は？"
        },
        {
          "speaker": "めたん",
          "text": "Rustは性能がC++と同等、安全性では所有権システムにより圧勝ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2つ目は？"
        },
        {
          "speaker": "めたん",
          "text": "Google、Microsoft、Linux、AWS、Cloudflare。主要インフラで採用が加速中ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "3つ目は？"
        },
        {
          "speaker": "めたん",
          "text": "C++を一夜で置き換えるのは不可能。現実は長い共存と段階的移行の時代ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「完全置き換えじゃなくて新時代の幕開け」って感じだね！"
        },
        {
          "speaker": "めたん",
          "text": "Rustはシステムプログラミングのパラダイムを変えつつありますわ。"
        }
      ]
    },
    {
      "id": 12,
      "title": "ご視聴ありがとう",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "今日の動画どうだった？"
        },
        {
          "speaker": "めたん",
          "text": "RustとC++の話、もっと掘り下げたいテーマがあればコメントで教えてください。"
        },
        {
          "speaker": "ずんだもん",
          "text": "チャンネル登録もよろしくね！"
        },
        {
          "speaker": "めたん",
          "text": "ごきげんよう！"
        }
      ]
    }
  ]
}