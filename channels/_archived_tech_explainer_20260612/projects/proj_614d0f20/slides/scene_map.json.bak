  "scenes": [
    {
      "title": "オープニング",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "今日のテーマは「アルゴリズムって結局なんなのか」なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "普段から耳にする言葉ですけれど、意外と説明に詰まる単語ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ぼくもちょっと前まで、なんかすごい式みたいなやつ、くらいの理解だったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "わたくしも、ふわっと使っていた自覚があります。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「YouTubeのアルゴリズムに嫌われた」とか、「アルゴリズムを勉強しないと」とか、口にする機会は多いのだ。"
        },
        {
          "speaker": "めたん",
          "text": "でも正面から「アルゴリズムって何？」と聞かれると、手が止まりますわね。"
        }
      ],
      "id": 0
    },
    {
      "title": "3つのアルゴリズム",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで突然なんだけど、3つのアルゴリズムを並べてみたいのだ。"
        },
        {
          "speaker": "めたん",
          "text": "3つ、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "1つめ、YouTubeのおすすめ動画を選んでいる、いわゆる「アルゴリズム」。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2つめ、紀元前300年、Euclidという数学者が本に書き残した計算手順。"
        },
        {
          "speaker": "ずんだもん",
          "text": "3つめ、プログラミング入門で出てくる、並び替えのやつ。"
        },
        {
          "speaker": "めたん",
          "text": "ずいぶん時代も分野も散らばっていますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもこれ、全部「アルゴリズム」と呼ばれているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "時代で言えば2000年以上離れていますし、使う道具も紙と鉛筆からスマホまで。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それでも同じ名前で呼ばれる。何が共通していて、何が違うのかを解きほぐすのが今日の目的なのだ。"
        }
      ],
      "id": 1
    },
    {
      "title": "今日の見取り図",
      "lines": [
        {
          "speaker": "めたん",
          "text": "同じ言葉で呼ぶからには、何か共通点があるのですね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それを今日4つの順路で確かめていくのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "まず「語源と歴史」、次に「厳密な定義」、そして「よくある誤解」、最後に「速さの測り方」なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "順路が見えると安心しますわ。参りましょう。"
        }
      ],
      "id": 2
    },
    {
      "title": "人の名前だった",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "いきなり意外な話なんだけど、「アルゴリズム」って実は一人の人の名前が語源なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "え、人名ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "9世紀のペルシャの数学者で、Muhammad ibn Musa al-Khwarizmiという長い名前の人。"
        },
        {
          "speaker": "ずんだもん",
          "text": "バグダードの「知恵の館」で働いていた、天文も地理もできる万能の学者なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "そのお名前がラテン語に翻訳された時の音写が、Algoritmiだったのですね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その翻訳が12世紀にヨーロッパに伝わって、彼の名前がそのまま「計算手順」を指す言葉として定着したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "人の名前が、学問分野そのものの名前に化けてしまった、ということですわね。"
        }
      ],
      "id": 3
    },
    {
      "title": "代数との兄弟関係",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "しかも面白いのが、同じ人の著作からalgebra、つまり「代数」という言葉も生まれているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "代数とアルゴリズムが、同じお一人の方から派生した兄弟語だったなんて。"
        },
        {
          "speaker": "ずんだもん",
          "text": "教科書的には、そう整理されているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ただ、「アルゴリズム」という語が「手続き一般」という広い意味で使われ始めたのは、わりと20世紀以降なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "昔から今の意味で使われていた、というわけではないのですね。"
        }
      ],
      "id": 4
    },
    {
      "title": "紀元前300年の手順",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "次、人類が記録した最古の「非自明なアルゴリズム」は、紀元前300年までさかのぼれるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "その昔にですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Euclidが『原論』という本に書いた、2つの数の最大公約数を求める手順。「Euclidの互除法」と呼ばれているやつ。"
        },
        {
          "speaker": "めたん",
          "text": "最大公約数、中学で習ったあれですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "手順はすごくシンプル。大きい数を小さい数で割って、余りが出たら今度はその余りで割る、というのを繰り返すだけ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "余りが0になったときの割る数が、求めていた最大公約数なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "実際にやってみれば、確かに紙の上で完結する手順ですわね。"
        }
      ],
      "id": 5
    },
    {
      "title": "互除法は今も現役",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "この2300年前の手順が、今もぼくらのスマホの中で動いているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "まさか、ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "RSAという暗号を作る時、鍵を計算する段階で互除法が使われる。ネット通販でカード番号を送る瞬間にも、実は走っているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "紀元前300年の手順が、現代の暗号通信を支えている——なかなかの光景ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ここが今日の伏線なのだ。道具が変わっても、ちゃんと作った手順は時間を超える。"
        },
        {
          "speaker": "めたん",
          "text": "その伏線、後でしっかり回収してくださいませね。"
        }
      ],
      "id": 6
    },
    {
      "title": "Knuth登場",
      "lines": [
        {
          "speaker": "めたん",
          "text": "で、そろそろ真面目に定義を聞いてもよろしいでしょうか。"
        },
        {
          "speaker": "ずんだもん",
          "text": "了解なのだ。多くの教科書が引用するのは、Donald KnuthというCSの重鎮が挙げた5つの性質。"
        },
        {
          "speaker": "ずんだもん",
          "text": "彼の『The Art of Computer Programming』という、1968年初版の超大著に書かれているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "今も刊行が続いていると伺いましたわ。"
        }
      ],
      "id": 7
    },
    {
      "title": "5つの性質",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "5つの性質、並べていくのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Finiteness、Definiteness、Input、Output、Effectiveness。"
        },
        {
          "speaker": "ずんだもん",
          "text": "日本語にすると、有限性、明確性、入力、出力、そして実行可能性、なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "言葉だけでは少し硬いですわね。順に教えていただけます。"
        }
      ],
      "id": 8
    },
    {
      "title": "有限性",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "有限性は、いつか必ず止まること。"
        },
        {
          "speaker": "ずんだもん",
          "text": "永遠に終わらない手順はアルゴリズムとは呼ばないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "止まらないサブスクの自動更新も、アルゴリズムとは呼ばないのですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "少なくとも教科書的にはそう扱わないのだ。"
        }
      ],
      "id": 9
    },
    {
      "title": "明確性",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "明確性は、各ステップが曖昧さなく決まっていること。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「塩を適度に」「肉を美味しそうな焼き色まで」は、ここで落第なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "人間の判断に頼ってしまうと駄目、ということですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう、読む人によって結果が変わる手順はアルゴリズムじゃないのだ。"
        }
      ],
      "id": 10
    },
    {
      "title": "入力と出力",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "入力は、手順を始める前に与えられる材料。"
        },
        {
          "speaker": "ずんだもん",
          "text": "出力は、終わった時に出てくる結果。"
        },
        {
          "speaker": "ずんだもん",
          "text": "材料を受け取って、求めた答えを返す。この筋道が通っていることが条件なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "自動販売機のモデルに少し似ていますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "お金とボタンが入力、出てくる飲み物が出力。間に「どの飲み物が選ばれたか判定する」手順が挟まっている。アルゴリズムの構造そっくりなのだ。"
        }
      ],
      "id": 11
    },
    {
      "title": "実行可能性",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "最後の実行可能性は、ステップが紙と鉛筆で人間が実行できるくらい基本であること。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「神のお告げを聞く」とか「祈る」みたいな手順は入れちゃいけないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "なるほど、具体的に手を動かして再現できるレベルまで、ということですか。"
        }
      ],
      "id": 12
    },
    {
      "title": "同じ問題 複数の手順",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "もう一つ大事なのが、同じ問題に対してアルゴリズムは1つじゃないということ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "たとえば数字の並び替え。bubble sort、quick sort、merge sort、いくつも方法がある。"
        },
        {
          "speaker": "めたん",
          "text": "どれも結果は同じなのでしょう。"
        },
        {
          "speaker": "ずんだもん",
          "text": "うん、正しく並ぶ。でも速度や向いているデータが全然違うのだ。"
        },
        {
          "speaker": "めたん",
          "text": "「最強のアルゴリズム」を探す問いは、前提が崩れているのですね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "データがほぼ整列済みのときに速いやつ、メモリが少ない環境で動くやつ、というふうに、得意不得意で使い分けるのだ。"
        }
      ],
      "id": 13
    },
    {
      "title": "Knuth本人の留保",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで一つ、誠実に言っておきたいのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "実はKnuth本人が、この定義は直観的にはクリアでも、形式的な厳密さには欠けると認めているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "定義を作ったご本人が、ですか。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「厳密に定義されている」の「厳密に」って何？という問いに、彼自身が完全には答えていない。"
        },
        {
          "speaker": "めたん",
          "text": "教科書的には5つの性質、でも学問の最前線ではまだ議論の余地がある、という立ち位置なのですね。"
        }
      ],
      "id": 14
    },
    {
      "title": "3つの誤解",
      "lines": [
        {
          "speaker": "めたん",
          "text": "では、アルゴリズムじゃないものの話に移りたいですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "よくある誤解を3つ潰していくのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1つめ、レシピのこと？ 2つめ、コードのこと？ 3つめ、YouTubeのあれのこと？"
        }
      ],
      "id": 15
    },
    {
      "title": "レシピとの違い",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まず、レシピ。よく入門書で「アルゴリズムはレシピみたいなもの」と書かれるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "入口としては、悪くないたとえに感じますけれど。"
        },
        {
          "speaker": "ずんだもん",
          "text": "入口としては、そう。でも料理のレシピって、「塩少々」「弱火で」「焦げない程度に」みたいな、人間判断の言葉だらけなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "先ほどの明確性の基準で落第してしまう、ということですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "厳密なアルゴリズムとしては成立しないのだ。大きく分けると、レシピは「アルゴリズム風の手順書」ではあるけれど、アルゴリズムそのものではない。"
        }
      ],
      "id": 16
    },
    {
      "title": "コードとの違い",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "2つめ、「アルゴリズムってプログラムのコードのこと？」。"
        },
        {
          "speaker": "めたん",
          "text": "確かにわたくしも、それとイコールで捉えていた時期があります。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ここは重要なんだけど、アルゴリズムは言語から独立した抽象概念なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "同じ並び替えアルゴリズムを、Pythonでも、JavaでもC++でも書ける。書いたものはコード、でも中身の手順はどれも同じ。"
        },
        {
          "speaker": "めたん",
          "text": "なるほど、手順自体が「設計図」で、コードは「ある工場での実装」という感じですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その整理で大きく間違っていないのだ。"
        }
      ],
      "id": 17
    },
    {
      "title": "YouTubeのあれ",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "3つめ、最大の鬼門、「YouTubeのアルゴリズム」。"
        },
        {
          "speaker": "めたん",
          "text": "普段わたくしたちが「アルゴリズムに気に入られる」と言っている、あれですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "うん。ただこれ、厳密には古典的アルゴリズムというより、「機械学習モデル」と呼ぶ方が正確なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "違いはどのあたりにあるのですか。"
        }
      ],
      "id": 18
    },
    {
      "title": "MLモデルとの違い",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "古典アルゴリズムは、人間が書いたステップが全てで、同じ入力なら必ず同じ結果が出るのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "一方、機械学習モデルは、大量の過去データから「こういう時こうしがち」という傾向を自動で学び取って作られる。"
        },
        {
          "speaker": "ずんだもん",
          "text": "同じ動画に対しても、何を学習したかで出力が変わるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "では、完全に別物なのですか。"
        },
        {
          "speaker": "ずんだもん",
          "text": "完全な別物ではなくて、機械学習も古典アルゴリズムで作られる、という入れ子の関係なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ああ、部品としての古典アルゴリズムは、ちゃんと中に居るわけですね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "勾配降下法とか誤差逆伝播とか、モデルを訓練するための手順自体は、ちゃんとKnuthの5性質を満たす古典アルゴリズムなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう、でも出来上がった「学習済みのモデル」は、Knuthの5性質にきれいには収まらない。"
        },
        {
          "speaker": "めたん",
          "text": "「YouTubeのアルゴリズム」は、完全な誤用ではないけれど、古典的な定義からはみ出している、と理解しました。"
        }
      ],
      "id": 19
    },
    {
      "title": "速さの測り方",
      "lines": [
        {
          "speaker": "めたん",
          "text": "アルゴリズムは1つじゃないというお話がありましたけれど、どれを選ぶか、何を基準にするのですか。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「正しさ」が最優先で、次に「速さ」を見るのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そして速さは、入力の大きさが増えたときに、時間が何倍に伸びるかで考えるのだ。"
        }
      ],
      "id": 20
    },
    {
      "title": "Big Oの直感",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "具体例で行くのだ。アルゴリズムAは、データが100個から200個に倍になると、時間が2倍になる。"
        },
        {
          "speaker": "ずんだもん",
          "text": "アルゴリズムBは、同じ条件で時間が4倍になる。"
        },
        {
          "speaker": "めたん",
          "text": "倍と4倍、長期的にはかなり差が出そうですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "これをBig Oという書き方で、AはO(n)、BはO(n²)と記すのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あの大文字のOが突然出てくる記法、こういう意味でしたのね。"
        }
      ],
      "id": 21
    },
    {
      "title": "爆発する差",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "データが100万個になると、AとBの差はどれくらいになると思う？"
        },
        {
          "speaker": "めたん",
          "text": "100万と1兆、というオーダーですか。"
        },
        {
          "speaker": "ずんだもん",
          "text": "正解なのだ。AがO(n)なら100万ステップだけど、BがO(n²)なら1兆ステップ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Aなら一瞬、Bは何日も帰ってこないレベルなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "見かけが似ていても、育ち方がこれほど違うのですね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "この「育ち方の違い」こそが、アルゴリズムを比較する時の一番大事な物差しなのだ。"
        }
      ],
      "id": 22
    },
    {
      "title": "二分探索の発想",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "もう一つ身近な例、紙の辞書で単語を探す時。"
        },
        {
          "speaker": "めたん",
          "text": "1ページずつめくる方はさすがにやりませんわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "真ん中を開いて、探したい単語がそれより前か後ろかを見て、半分を捨てるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "これがbinary search、二分探索。100万語でも20回ほどで見つかるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "桁違いの速さですわね。ただ、前もって並んでいる必要があるのですよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そこなのだ。前提条件——「ソート済み」——の設計が、アルゴリズムの肝なのだ。"
        }
      ],
      "id": 23
    },
    {
      "title": "身近なアルゴリズム",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "カーナビの最短経路。あれはDijkstraという人が1956年に喫茶店で20分で思いついたアルゴリズムが基礎になっているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "喫茶店で、ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "本人がインタビューでそう言っている。今も世界中の地図アプリで走っている。"
        },
        {
          "speaker": "めたん",
          "text": "アイデア自体は、意外と身近な場所で生まれているのですね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "仰々しい研究所じゃなくて、ふとした日常の中から。そこもアルゴリズムの面白さなのだ。"
        }
      ],
      "id": 24
    },
    {
      "title": "正しさが最優先",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "忘れちゃいけないのは、速くても間違った答えを出すやつは、そもそもアルゴリズムじゃないってこと。"
        },
        {
          "speaker": "めたん",
          "text": "Knuthの出力の条件に戻ってきましたわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "正しさがまず先、その上での速さ、という順番は、ずっと変わらないのだ。"
