{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "id": 0,
      "title": "オープニング",
      "lines": [
        {
          "speaker": "めたん",
          "text": "今日のテーマは「5G」ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。ちょっと聞きたいんだけど、めたんのスマホ、5G対応してる？"
        },
        {
          "speaker": "めたん",
          "text": "もちろんですわ。去年機種変したときに5G対応になりましたの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "じゃあ率直に聞くけど、4Gのときと比べて何か変わった？"
        },
        {
          "speaker": "めたん",
          "text": "……正直、全然変わった実感がないですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "動画が速くなったとか、ダウンロードが一瞬で終わるとか？"
        },
        {
          "speaker": "めたん",
          "text": "全く実感できませんわ。画面に5Gって表示は出てるのに、速くなった感じが全然しない。"
        }
      ]
    },
    {
      "id": 1,
      "title": "理論と実測の差",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "その感覚、めたんだけじゃないのだ。5Gの理論上の最大速度は下り20Gbps。"
        },
        {
          "speaker": "めたん",
          "text": "20Gbps！？映画1本が1秒で落とせるレベルですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ところが、ICT総研が2026年1月に発表した日本全国の実測平均は約140Mbps。"
        },
        {
          "speaker": "ずんだもん",
          "text": "理論値の約140分の1なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "140分の1……。それ、ほぼ詐欺じゃないですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかも山手線の駅と駅の間で測ると、平均47Mbpsしか出ないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "47Mbps……。それって4Gでも普通に出る速度ですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "うん。みんなも通勤中にスピードテストアプリで測ってみてほしいのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「あれ、4Gのときと変わらなくない？」って思うはずなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "わたくしも今度やってみますわ……。ちょっと怖いけど。"
        }
      ]
    },
    {
      "id": 2,
      "title": "幻滅期",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "だからガートナーのハイプサイクルでも5Gは「幻滅期」に入っているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "幻滅期……。つまり世界的に期待はずれだったということですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう結論づける前に、ぼくは一つ聞きたいのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "めたんのスマホに「5G」って表示されてるよね？"
        },
        {
          "speaker": "めたん",
          "text": "ええ、ちゃんと5Gと出てますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その「5G」、実は本当の5Gじゃないかもしれないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "え……どういうことですの？"
        }
      ]
    },
    {
      "id": 3,
      "title": "周波数の違い",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "5Gには大きく2種類の周波数帯があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "2種類もあるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "一つはSub-6。6GHz未満の周波数帯で、日本だと3.7GHzや4.5GHz帯を使うのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "4Gで使う周波数帯より高いけど、まだ扱いやすい範囲なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "扱いやすいってどういう意味ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "電波が比較的遠くまで届いて、障害物も回り込める性質が残っているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "もう一つがミリ波。28GHz帯で、こっちが5Gの「本命」と言われているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "数字が大きいほうが速いんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "大まかに言えばそうなのだ。ミリ波は理論上1Gbps超を出せるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ただし致命的な弱点があるのだ。"
        }
      ]
    },
    {
      "id": 4,
      "title": "ミリ波の弱点",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ミリ波は電波の到達距離が見通しで約500メートルしかないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかも壁やガラスを通り抜けると信号の90〜95%が消えてしまうのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "雨が降るとさらに減衰する。物理的にどうしようもない特性なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "500メートルで壁も通れない！？それじゃ基地局だらけにしないと使えませんわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通りなのだ。街中に数百メートルおきに基地局を建てるコストは膨大すぎるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "スタジアムや駅構内のような限定エリアでは力を発揮するのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ただ「全国どこでもミリ波で超高速」は物理的に非現実的なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "じゃあ「5Gは速い！」っていう宣伝は、ミリ波の理論値を見せていただけですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "全部がそうとは言い切れないけど、そういう側面はあるのだ。"
        }
      ]
    },
    {
      "id": 5,
      "title": "転用5Gの仕組み",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "で、ここからが本題なのだ。日本のキャリアは5Gエリアを急いで広げたかった。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そこで4Gで使っていた700MHzや900MHzの周波数帯を、5G方式に「転用」したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それが「転用5G」……通称「なんちゃって5G」ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。4Gの周波数帯をそのまま使うから、速度はほとんど変わらないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもスマホの画面には「5G」と堂々と表示されるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "わたくしもそれで「5Gなのに速くない」ってモヤモヤしてましたわ……。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ドコモは当初「優良誤認にあたる」と転用5Gに消極的だったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "良心的ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもauやソフトバンクが先にエリアを広げて、カバー率競争で負け始めたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "結局ドコモも2022年に方針転換して転用5Gを導入したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "競争の圧力には逆らえなかったんですわね……。"
        },
        {
          "speaker": "ずんだもん",
          "text": "消費者からすると「5Gエリア広い＝速くなった」と期待するよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも中身は4Gと同じ速度。この期待と現実のギャップが不満を生んでいるのだ。"
        }
      ]
    },
    {
      "id": 6,
      "title": "カバー率の内訳",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "日本の5G人口カバー率は98.4%と総務省が発表しているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "98%ならほぼ全国カバーですわよね。すごいじゃないですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ところがICT総研が全国729地点で実測したら、5Gを受信できたのは67.9%だったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "98%と68%って全然違いますわ……。何が起きているんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "約3割の地点では5Gスマホなのに4Gに繋がっていたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "カバー率の数字には転用5Gのエリアも含まれていて、実態とズレがあるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかもこれは日本だけの話じゃないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "アメリカではAT&Tが4G LTEを「5G E」と表記して、Sprint社に訴えられたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "消費者の54%が「5Gと同等」と誤認していたという調査もあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "名前を変えるだけでユーザーを騙せてしまうんですわね……。"
        },
        {
          "speaker": "ずんだもん",
          "text": "5Gの「5G」という表示自体が、かなり曖昧なものになっているのだ。"
        }
      ]
    },
    {
      "id": 7,
      "title": "世代とキラーアプリ",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで一つ大事な視点を入れたいのだ。通信の世代交代の歴史なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "どの通信世代にも、普及を決定づけた「キラーアプリ」があったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "キラーアプリ？"
        },
        {
          "speaker": "ずんだもん",
          "text": "その世代がないと成り立たなかったサービスのことなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2GのキラーアプリはSMSなのだ。携帯でテキストメッセージが打てるようになった。"
        },
        {
          "speaker": "ずんだもん",
          "text": "日本ではiモードが爆発的に広まって、携帯でWebが見られるようになったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "懐かしいですわね。あの小さい画面でニュースを読んでましたわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "4GのキラーアプリはYouTubeやNetflix、TikTokなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "電車で動画が止まらず見られるようになったときは感動しましたわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "あの体験こそ、4Gが「なくてはならない」と実感できた瞬間なのだ。"
        }
      ]
    },
    {
      "id": 8,
      "title": "道路と車のアナロジー",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで面白いパターンがあるのだ。通信規格とキラーアプリにはタイムラグがあるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "3Gの通信インフラは日本では2001年にスタートしたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも「3Gがなければ成り立たない」と実感させたiPhoneは2008年に登場したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "7年もかかったんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかも3Gは当初「大失敗」とまで言われていたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ドコモのFOMAは初期に「繋がらない」と大不評だったのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "目玉機能のテレビ電話も画質がひどくて普及しなかったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "今の5Gの状況と完全に重なりますわね……。"
        },
        {
          "speaker": "ずんだもん",
          "text": "道路があっても、その道路を活かす「車」がまだ来ていなかったのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも7年後にiPhoneという「車」が走り出したら、世界が一変したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "今では3Gなしの世界なんて想像できませんわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "当時「3Gは失敗」と断言した人たちは、まさかこうなるとは思わなかったはずなのだ。"
        }
      ]
    },
    {
      "id": 9,
      "title": "5Gのキラーアプリは？",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "じゃあ5Gのキラーアプリは何だろう？"
        },
        {
          "speaker": "めたん",
          "text": "遠隔手術とか自動運転ってよく聞きましたけど……。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2019年にキャリア各社が大々的に宣伝していたのだ。CMもすごかったよね。"
        },
        {
          "speaker": "めたん",
          "text": "「5Gで未来が変わる！」みたいなのをよく見ましたわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも2026年の今、どちらもまだ実証実験段階なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "7年経ってもまだ実験段階ですの……。"
        },
        {
          "speaker": "ずんだもん",
          "text": "一般の人が「5Gにして良かった！」と実感できるサービスが、まだ見つかっていないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "月額料金は上がったのに、体験は変わらない。それは不満になりますわ。"
        }
      ]
    },
    {
      "id": 10,
      "title": "韓国の事例",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "象徴的なデータを紹介するのだ。韓国は5G平均速度939Mbpsで世界トップクラスなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "日本の6倍以上ですわ。それなら満足度も高いでしょう？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ところが「5Gに満足」と答えた利用者はわずか14%だったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "14%！？速くても満足できないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "TikTokの動画は3〜8MBで、4Gの20Mbpsでも2秒以内にロードできるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "スマホの主な使い方が4Gで十分な限り、5Gの恩恵は体感しにくいのだ。"
        },
        {
          "speaker": "めたん",
          "text": "速い道路を作ったのに、走る車がまだないんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "さっきの3Gとまったく同じ構造なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "道路はある。でも車がない。これが今の5Gの現在地なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "でもそれって結局「5Gは失敗」ということですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "実は、ぼくたちが使っている5Gにはまだ大きな制限が残っているのだ。"
        }
      ]
    },
    {
      "id": 11,
      "title": "NSAとSAの違い",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "今の5Gの大部分は「NSA」という方式で動いているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Non-Standalone、つまり4Gのコアネットワークに5Gの無線を載せた形なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "4Gの上に5Gを載せている……。建て増しみたいなものですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "うまい表現なのだ。これに対して「SA」方式は5G専用のコアネットワークを使うのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "5G本来の目玉機能である低遅延やネットワークスライシングはSAでなければ使えないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "つまり今のNSA方式では、5Gの力を半分も出せていないということですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "Opensignalの調査では、SA方式はNSA比でダウンロード速度が1.7倍なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "1.7倍って結構違いますわね。世界でSAはどれくらい普及していますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "世界の5G接続のうちSAはまだ17.6%。8割以上がまだNSAなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "じゃあ今使っている5Gは「仮の姿」みたいなものですわね。"
        }
      ]
    },
    {
      "id": 12,
      "title": "スライシングの仕組み",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "SA方式で特に注目なのがネットワークスライシングなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "スライシング……何かを切り分けるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "高速道路を想像してみてほしいのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "今の通信は全員が同じ道路を走っているようなものなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "動画を見る人もメールの人も、医療機器のデータも全部同じ道路なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "年末のカウントダウンとか、花火大会で全然繋がらなくなること、ありますわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "まさにそれなのだ。全員が同じ回線を奪い合うから起きる現象なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "スライシングがあれば用途別の専用レーンを作れるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "動画レーン、IoTレーン、医療レーンを仮想的に分けるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それぞれの用途に最適な帯域と遅延を保証できるんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通りなのだ。2023年の東京マラソンでは実証実験が行われたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "放送カメラ専用スライスを使って、数万人がスマホを使う中でも安定した中継ができたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それは実用的ですわね。渋滞に巻き込まれない専用レーンがあるイメージですわ。"
