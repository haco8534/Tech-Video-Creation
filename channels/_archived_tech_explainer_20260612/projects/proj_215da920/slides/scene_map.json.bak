{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "title": "謎のイライラ",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ずんだもん、今日のテーマはなんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "プリンターだけいつも機嫌が悪い理由、なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あぁ、それはわたくしも最近ムッときましたわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "めたんも紙詰まりやった？"
        },
        {
          "speaker": "めたん",
          "text": "違いますの。インクはまだあるはずなのに、印刷できないって言われましたの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それ、すごく典型的なやつなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "スマホもテレビも普通に動いてますのに、プリンターだけ「機嫌悪い」って、不思議ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それ、ぼくもずっと気になってたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから、結構深く調べてきたのだ。"
        }
      ],
      "id": 0
    },
    {
      "title": "擬人化される家電",
      "lines": [
        {
          "speaker": "めたん",
          "text": "言われてみれば、「機嫌悪い」って擬人化される家電、プリンターくらいですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "冷蔵庫がへそ曲げたとは言わないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "洗濯機もグズらないですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "エアコンが気分屋だとも聞かないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "でも、プリンターだけ「今日はダメみたいね」って言われますの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "これ、実は性格の問題じゃないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "中身を開けてみると、ちゃんと理由が出てくるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "理由、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかも一つじゃないのだ。"
        }
      ],
      "id": 1
    },
    {
      "title": "今日の見取り図",
      "lines": [
        {
          "speaker": "めたん",
          "text": "その「一つじゃない理由」、先に教えてくださらない？"
        },
        {
          "speaker": "ずんだもん",
          "text": "大きく分けると、3つの要因が重なってるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "一つ目は、プリンターが技術的にやたら難しい、って話。"
        },
        {
          "speaker": "ずんだもん",
          "text": "二つ目は、メーカーの商売のやり方の話、なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "三つ目は、わたくしたちが、月に1回くらいしか使わない、っていう話なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "最後、意外なところから来ましたわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも、この3つが重なるから「機嫌悪い」が生まれるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "まず、技術の難しさから順番に見ていくのだ。"
        }
      ],
      "id": 2
    },
    {
      "title": "画面と印刷",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まずね、「印刷する」ってなにをやってると思う？"
        },
        {
          "speaker": "めたん",
          "text": "画面に映ってる絵を、そのまま紙に写してるんじゃないですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "それがね、実はぜんぜん違うのだ。"
        },
        {
          "speaker": "めたん",
          "text": "えっ、写してるだけじゃないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "画面とプリンターは、ぜんぜん別のルートで絵が作られてるのだ。"
        }
      ],
      "id": 3
    },
    {
      "title": "翻訳が要る",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "画面の絵は、OSやアプリが、ピクセルを直接描いてるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "つまり、そのまま絵として表示してる、と。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。でもプリンターには、その絵を直接は送れないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あら、なんでですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "プリンターは、ピクセルの絵そのものを理解できないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから、「こう描け」っていう命令書の言語に翻訳してから送るのだ。"
        },
        {
          "speaker": "めたん",
          "text": "翻訳、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "これをページ記述言語、Page Description Language、略してPDLって言うのだ。"
        },
        {
          "speaker": "めたん",
          "text": "印刷する前に、一回、命令書を書くイメージですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう、ぼくのイメージではそうなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "翻訳が一段挟まってるって、言われないと気づきませんわね。"
        }
      ],
      "id": 4
    },
    {
      "title": "五つの言語",
      "lines": [
        {
          "speaker": "めたん",
          "text": "でも、どのプリンターも同じ言語ならいいですわよね？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ここが、ひとつ目の罠なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "この命令書の言語、大きく分けると、40年間で5種類くらい併存してるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "5種類も？"
        },
        {
          "speaker": "ずんだもん",
          "text": "1984年にAdobeが作ったPostScript。"
        },
        {
          "speaker": "ずんだもん",
          "text": "同じ年にHPが作ったPCL。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2006年にMicrosoftが出したXPS。"
        },
        {
          "speaker": "ずんだもん",
          "text": "あとはPDF、それから2013年のIPP Everywhereなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "全部、別物ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "たとえばPostScriptは「美しく描く」方向に重きを置いた言語なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "対するPCLは「速く簡素に描く」方向を選んだ言語なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "哲学が違う、ですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "で、40年経っても、どちらも現役で残ってるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "設計思想が違うから、直接は変換できない場面も多いのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それは、めんどくさいですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "だからプリンター1台を動かすのに、まずOSとドライバーが、どの言語で話すか決めないといけないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "画面はただ絵を出せばいい。プリンターは翻訳の段取りを決めてから描かせる。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう、ここがスタート地点なのだ。"
        }
      ],
      "id": 5
    },
    {
      "title": "中身を開ける",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ソフトの話はちょっと分かってきましたわ。"
        },
        {
          "speaker": "めたん",
          "text": "じゃあ、機械の中身は、もう少し単純なんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "それがね、物理のほうは、もっとカオスなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "またですの。"
        }
      ],
      "id": 6
    },
    {
      "title": "μmのノズル",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まず家庭で多いインクジェット。"
        },
        {
          "speaker": "ずんだもん",
          "text": "実はインクの飛ばし方にも、大きく分けると2方式あるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "2方式、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "Epsonは圧電素子を使うピエゾ方式。"
        },
        {
          "speaker": "ずんだもん",
          "text": "HPやCanonは、瞬間的に加熱して気泡でインクを飛ばすサーマル方式なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "同じインクジェットでも、中身がずいぶん違いますのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "で、インクを飛ばすノズルの穴、どれくらいだと思う？"
        },
        {
          "speaker": "めたん",
          "text": "うーん、1ミリくらい？"
        },
        {
          "speaker": "ずんだもん",
          "text": "10マイクロメートル、つまり100分の1ミリなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それは、ものすごく細いんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "で、その穴の先端から、インクの溶媒が、じわじわ蒸発していくのだ。"
        },
        {
          "speaker": "めたん",
          "text": "溶媒が、蒸発するんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "揮発する成分だから、置いておくだけで先から乾いて、固まっていくのだ。"
        },
        {
          "speaker": "めたん",
          "text": "つまり、詰まる。"
        },
        {
          "speaker": "ずんだもん",
          "text": "早ければ4週間くらい使わないだけで、ノズル詰まりは始まると言われてるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "月1でしか使わない家庭だと、だいたい間に合わないじゃないですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。だから印刷前に、勝手にヘッドクリーニングをする設計なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あぁ、あの無駄にインクが減るやつ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "アメリカのConsumer Reportsっていう雑誌が、これを検証したのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "間欠使用だと、買ったインクの半分以上が、クリーニングに消える機種もあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "紙に届いてないの、半分？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ひどい機種だと、7〜8割くらい捨ててるって結果なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それは、機嫌悪く見えますわね。"
        }
      ],
      "id": 7
    },
    {
      "title": "学部の実験室",
      "lines": [
        {
          "speaker": "めたん",
          "text": "レーザーのほうは、もう少しマシなんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "レーザーは機械としての難しさの種類が違うのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "中で起きてる工程、教科書的に数えると、6つあるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "帯電、露光、現像、転写、定着、それからクリーニング、なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "1行ずつが、ちょっとした実験テーマになりそうですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "使う物理も、高電圧と、レーザー光と、摩擦帯電と、放電と、熱と、機械の動き、全部違うのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それが1台の中で、順番に協調動作してるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "熱って、どれくらいですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "定着ローラーは、だいたい150から200℃に保たれてるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "200℃？家電なのに？"
        },
        {
          "speaker": "ずんだもん",
          "text": "家の中で、こっそりオーブン並みに熱くなってる家電なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それ、家電というよりオーブンですわよ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかもその隣で、光学系と高電圧と摩擦帯電が、同時に動いてるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "プリンター1台の中で、学部の物理実験が同時に走ってるみたいですわね。"
        }
      ],
      "id": 8
    },
    {
      "title": "湿度と紙",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "あと、紙自体も、けっこうな難物なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ただの紙じゃないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "紙は湿気を吸う素材なのだ。湿度で挙動が変わるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "高湿だと膨らんでカール、低湿だと静電気でくっつくのだ。"
        },
        {
          "speaker": "めたん",
          "text": "湿度で紙詰まりの起きやすさが変わるのも、物理の話だったんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「今日は天気が悪いから調子悪いのね」って、感覚として当たってたのだ。"
        }
      ],
      "id": 9
    },
    {
      "title": "OS更新で壊れる",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ここまでで、物理もソフトも、どっちも難物っていうのは分かりましたわ。"
        },
        {
          "speaker": "めたん",
          "text": "でも、もう一つの謎。"
        },
        {
          "speaker": "めたん",
          "text": "Windowsアップデートの後にプリンターが動かなくなる、あれはなんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "それ、かなり深い話なのだ。"
        }
      ],
      "id": 10
    },
    {
      "title": "NT時代の亡霊",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "Windowsの印刷を裏で回してるのは、Print Spoolerっていうサービスなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "Spoolerって、印刷の行列を管理するやつですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "うん、でもね、このSpoolerの基本設計はWindows NT時代のままなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "NTって、1990年代ですわよね？"
        },
        {
          "speaker": "ずんだもん",
          "text": "1993年に作られた設計の骨格を、今のWindows 11も引きずってるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "30年前の設計、まだ現役ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかもプリンタードライバーも、2000年のV3モデルと、2012年のV4モデルが両方残ってるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "新旧が、同じOSの中で同居してるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう、この入れ子が厄介なのだ。"
        }
      ],
      "id": 11
    },
    {
      "title": "プリントナイトメア",
      "lines": [
        {
          "speaker": "めたん",
          "text": "30年前のコードだと、どこかに穴も空いてそうですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "まさにそれが露呈したのが、2021年のPrintNightmareっていう事件なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "名前からして、悪そうですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Print Spoolerの仕様上、一般ユーザーが、任意のプログラムを管理者権限で動かせたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "印刷機能で、管理者権限が取れてしまうの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ドライバーを後から追加する仕組みそのものが、古すぎたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ちょっと待って、そんな穴のある仕組みで、世界中が毎日印刷してましたの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "大きく分けると、気づかれないまま28年動いてたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ドライバーを後から足せる柔軟な設計が、逆に攻撃の窓口になっていたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "柔軟さのツケが、あとから来たんですのね。"
        }
      ],
      "id": 12
    },
    {
      "title": "Wi-Fiに居るのに",
      "lines": [
        {
          "speaker": "めたん",
          "text": "あと、Wi-Fiにはちゃんと繋がってるのに、プリンターだけ見つからない日もありますのよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それ、mDNSっていう仕組みの特徴なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "エムディーエヌエス、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "近くのプリンターを、自動で見つけてくれる仕組みなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ただ、これ、原則として同じWi-Fiの中でしか届かない設計なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "だから、同じ家でもルーターが分かれてると、見えないんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "教科書的には、それで正しい動作、なのだ。"
        }
      ],
      "id": 13
    },
    {
      "title": "AirPrintは先行",
      "lines": [
        {
          "speaker": "めたん",
          "text": "そういえば、iPhoneから印刷するときは、こんなに揉めないですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それ、本当にいい質問なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Appleは2010年に、AirPrintっていう仕組みを作ったのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "OSにドライバーを入れない、プリンター側で完結させる設計なのだ。"
        },
        {
