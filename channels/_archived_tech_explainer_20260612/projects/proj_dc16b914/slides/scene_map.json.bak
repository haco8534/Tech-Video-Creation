{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "title": "今日の問い",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ずんだもん、今日はひとつ教えてほしいんですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "なんなのだ？"
        },
        {
          "speaker": "めたん",
          "text": "クラウドって、結局なんなんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "お、いきなり直球なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "みんな「クラウドに保存」「クラウドで動く」って言いますわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "言うのだ。広告でもニュースでも毎日聞くのだ。"
        },
        {
          "speaker": "めたん",
          "text": "でもわたくし、正直ちゃんとわかってない気がしますの。"
        }
      ],
      "id": 0
    },
    {
      "title": "身近なクラウド",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "じゃあ逆に聞くのだ。めたんのスマホの写真、どこに入ってるのだ？"
        },
        {
          "speaker": "めたん",
          "text": "え、スマホの中ですわよね？"
        },
        {
          "speaker": "ずんだもん",
          "text": "iCloudとかGoogleフォトの同期、オンにしてないのだ？"
        },
        {
          "speaker": "めたん",
          "text": "あ…しっかり入ってますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その瞬間、写真は世界のどこかの倉庫に光ファイバで飛んでるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "倉庫…？わたくしの猫の写真が倉庫ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "LINEのトークも、Netflixの動画も、インスタに載せたご飯も、全部倉庫から来てるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "え、わたくし毎日クラウド使ってたんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "知らずに使ってる側が、世界で一番多いのだ。"
        }
      ],
      "id": 1
    },
    {
      "title": "60年前の予言",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。でも「クラウドって何？」って聞かれると答えにくいのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ふわっとしてますわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "今日はそこを整理するのだ。で、ぼくも調べて驚いたのだけど。"
        },
        {
          "speaker": "めたん",
          "text": "なんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "クラウドって言葉、思ったよりずっと古いのだ。"
        },
        {
          "speaker": "めたん",
          "text": "え、最近の技術じゃないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "その話から行くのだ。"
        }
      ],
      "id": 2
    },
    {
      "title": "1961年の講演",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "時代をいっきに1961年までさかのぼるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "1961年…東京オリンピックの前ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "MITで100周年記念の講演があったのだ。登壇したのはジョン・マッカーシーという研究者。"
        },
        {
          "speaker": "めたん",
          "text": "どんな人ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "当時のコンピュータ科学の先駆けにいた人で、名前は覚えなくて大丈夫なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "はい。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その人がこう言ったのだ。「コンピューティングはいつか、電話のような公共インフラになるだろう」。"
        },
        {
          "speaker": "めたん",
          "text": "電話みたいに？"
        },
        {
          "speaker": "ずんだもん",
          "text": "使った分だけ払えばいい、という話まで当時言ってたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それ、今わたくしが使ってるクラウドの考え方、そのものじゃありませんの？"
        }
      ],
      "id": 3
    },
    {
      "title": "タイムシェア時代",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そう。実は大型コンピュータを時間で分けて貸す仕組みは、60年代からあったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "え、もうその時代に？"
        },
        {
          "speaker": "ずんだもん",
          "text": "端末からメインフレームに接続して、使った時間で料金を払う。仕組みの骨格は当時と今で同じなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "じゃあ今わたくしが使ってるのは、60年前の発想の延長線ってことですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通りなのだ。ただ、メインフレームは高価で、一般の会社や人が触れる世界じゃなかったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "昔は\"特別な人だけのもの\"だったんですのね。"
        }
      ],
      "id": 4
    },
    {
      "title": "1996年の戦略書",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "で、ここが面白いのだ。「クラウドコンピューティング」って言葉の最古の記録を調べると。"
        },
        {
          "speaker": "めたん",
          "text": "はい。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1996年、コンパックという会社の社内マーケティング資料なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "マーケティング…？技術論文じゃないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。文書化された最古の用例が、技術論文ではなく\"売り方を考える資料\"側だったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "つまりクラウドって言葉自体、ビジネス側から生まれてるんですのね。"
        }
      ],
      "id": 5
    },
    {
      "title": "2006年のEC2",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ただ、概念が商売として実装されたのは2006年のアマゾンなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あの通販のアマゾンですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "通販の運営で培った\"設備を標準化して自動で動かす技術\"を、外販用に作り直して売り出したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "自分の会社の運営ノウハウを、商品にしたんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そこから20年で、世界のIT基盤はこの形になったのだ。では、その\"この形\"が具体的に何なのか、次で見ていくのだ。"
        }
      ],
      "id": 6
    },
    {
      "title": "NISTという組織",
      "lines": [
        {
          "speaker": "めたん",
          "text": "でもずんだもん、結局クラウドの定義って何なんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "実はちゃんと公式な定義があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "えっ、あるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "アメリカの国立標準技術研究所、NISTという組織が2011年に定めたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "標準規格があるなんて意外ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "発行から10年以上、改訂なしで使われ続けてるのだ。"
        }
      ],
      "id": 7
    },
    {
      "title": "5つの特徴",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そこで挙げられてる特徴は5つあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "5つ。聞きますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1つ目、自分でポチッと借りられる。人と交渉しない。"
        },
        {
          "speaker": "めたん",
          "text": "アプリをインストールするみたいな感覚ですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2つ目、ネット経由でどこからでも使える。"
        },
        {
          "speaker": "めたん",
          "text": "スマホでもPCでもタブレットでも、ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "3つ目、設備は他のユーザーと共有されてる。"
        },
        {
          "speaker": "めたん",
          "text": "共有…ちょっと不思議な感じがしますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "4つ目、欲しい時にすぐ増やせて、要らなくなったらすぐ減らせる。"
        },
        {
          "speaker": "めたん",
          "text": "必要な分だけ、というやつですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "5つ目、使った分がきっちり計測されて、その分だけ請求される。"
        },
        {
          "speaker": "めたん",
          "text": "電気料金みたいですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "いまのめたんのひとことが、実は60年前のマッカーシーの予言そのものなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あの電話の話ですわね。時代を越えて繋がってますわ。"
        }
      ],
      "id": 8
    },
    {
      "title": "ただの借り物じゃない",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "この5つが揃って初めて、クラウドと言えるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "じゃあ「ネット越しのサーバー」ってだけじゃ足りないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。たとえば固定で1年借りるホスティングは、厳密にはクラウドと呼びにくいのだ。"
        },
        {
          "speaker": "めたん",
          "text": "なるほど。言葉の使われ方、かなり雑ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "定義を知ると、広告の「クラウド対応！」が何を指してるのか見えてくるのだ。"
        }
      ],
      "id": 9
    },
    {
      "title": "3つのモデル",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "クラウドにはもうひとつ、3種類の「深さ」があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "深さ、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "どこまで自分でやって、どこからお任せするか、の段階なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "うーん、まだ抽象的ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "これはピザで例えると一瞬でわかるのだ。"
        }
      ],
      "id": 10
    },
    {
      "title": "ピザで例える",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ピザ？急にお腹が空く話ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ピザを食べたい時、選択肢が3つあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "聞きますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1つ目、小麦粉から生地をこねて、全部自分で焼くのだ。"
        },
        {
          "speaker": "めたん",
          "text": "手間かかりますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2つ目、冷凍ピザを買ってきて、オーブンで焼くだけ。"
        },
        {
          "speaker": "めたん",
          "text": "ちょっと楽ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "3つ目、宅配を頼む。届いたら箱を開けて食べるだけ。"
        },
        {
          "speaker": "めたん",
          "text": "楽しみ方が違うだけで、全部「ピザを食べる」ですわね。"
        }
      ],
      "id": 11
    },
    {
      "title": "IaaSの中身",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "これをクラウドに当てはめるのだ。一番下がIaaS、インフラだけ借りる形なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "生地から焼くやつですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "サーバーの中身のOSから設定から、全部自分で組む。自由だけど手間がかかるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "代表的なのはどんなサービスですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "アマゾンのEC2とか、マイクロソフトのAzure仮想マシン、グーグルのCompute Engineなのだ。"
        }
      ],
      "id": 12
    },
    {
      "title": "PaaSの中身",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "真ん中がPaaS、プラットフォームとして借りる形なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "冷凍ピザを焼く感じですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "土台は用意されてて、自分はアプリのコードを置くだけで動くのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ちょっと開発者ならって話ですわね。"
        }
      ],
      "id": 13
    },
    {
      "title": "SaaSの中身",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そして一番上がSaaS。これは全部お任せで、ブラウザで使うだけなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "宅配ピザですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Gmail、Slack、Netflix、LINE、ChatGPT。全部SaaSなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あら、わたくし毎日お世話になってますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから「クラウド使ってますか？」の答えは、ほぼ全員イエスなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "知らずに使ってた側の話なのですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "大事なのは、どの層を誰が提供しているか、なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "どういうことですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "めたんが使うGmailは、Googleが裏でIaaSとPaaSも全部自前で用意してるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ピザで言えば、生地も冷凍も宅配も一人で抱えてるお店ですのね。"
        }
      ],
      "id": 14
    },
    {
      "title": "雲の居場所",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ところでずんだもん、素朴な疑問なんですけど。"
        },
        {
          "speaker": "ずんだもん",
          "text": "どうぞなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "クラウドって「雲」って名前じゃないですか。物理的にはどこにありますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そこがぼくも調べてて一番意外だったところなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "気になりますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "エンジニア界隈でよく引用される言い回しがあるのだ。「クラウドなんて存在しない。ただの、誰かのコンピュータだ」。"
        },
        {
          "speaker": "めたん",
          "text": "誰かの…？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。雲のどこかじゃなくて、具体的な建物の中にある、具体的なマシンなのだ。"
        }
      ],
      "id": 15
    },
    {
      "title": "アシュバーン",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "たとえばアメリカのバージニア州アシュバーンって街。"
        },
        {
          "speaker": "めたん",
          "text": "聞いたことないですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "普通の町なのだけど、この一帯にデータセンターが200以上集まってるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "200…。"
        },
        {
          "speaker": "ずんだもん",
          "text": "一説には、世界のネット通信のおよそ7割がここを経由するとも言われるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "業界でよく語られる数字ってことですのね。正確な計測は難しそうですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ぼくたちが見てる動画の光は、地球の反対側の倉庫から飛んできてる可能性が高いのだ。"
        }
      ],
      "id": 16
    },
    {
      "title": "1サイトの規模",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "しかも1つの建物がとんでもない大きさなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "どれくらいですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "大きいところは東京ドーム数個分の広さで、電力は中規模の発電所1基分を使うのだ。"
        },
        {
          "speaker": "めたん",
          "text": "発電所1基…。冷房とかすごそうですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "冷却だけで1日に数百万リットルの水を使う施設もあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "重工業みたいですわね。"
        }
      ],
      "id": 17
    },
    {
      "title": "415TWh",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "世界全体で見ると、データセンターは2024年で年間およそ415テラワットアワーの電力を食ってるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "単位が大きすぎてピンと来ませんわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "世界の総電力のだいたい1パーセントなのだ。1つの業種だけで、なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "「雲」って言葉のイメージと真逆ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかも生成AIのせいで、この消費は2030年までに倍になる予測なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それ、電気を作る側が追いつくんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そこが今、世界中で議論になってるのだ。"
        }
      ],
      "id": 18
    },
    {
