{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "title": "あの音飛び",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "めたん、Bluetoothってすぐ不安定になる、って話を調べてきたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ありますわ、それ。電車で急にブツブツ途切れる、あの感じ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。家の中だと平気なのに、駅のホームで突然崩れるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "イヤホンの片方だけ落ちる、みたいなこともしょっちゅうですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "あと、ポケットに入れると安定して、机に置くと飛び始めるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「物理的には近いのに切れる」のがいちばん不思議なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "しかも、再生機器が変わると挙動も変わりますわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "iPhoneとAndroidとPCで、それぞれ違う癖があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "なぜBluetoothって、こんなに環境次第で表情を変えるのかしら。"
        },
        {
          "speaker": "ずんだもん",
          "text": "今日は、その「不安定さ」の正体を解きほぐしていくのだ。"
        }
      ],
      "id": 0
    },
    {
      "title": "今日の見取り図",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "調べてみたら、不安定さの理由が大きく三つに分かれたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "三つ、ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ひとつ目。Bluetoothは「混雑した道路」を走っているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ふたつ目。電波は人の体を意外と吸収するのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "みっつ目。仕様が25年積み重なって、地層みたいになっているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "地層、ですの。なんだか考古学みたいですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "途中で「電子レンジで切れる」噂の本当のところにも触れるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あれ、ずっと気になっていましたの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "最後に、なぜTWSイヤホンが特に弱いのか、その物理的事情も話すのだ。"
        },
        {
          "speaker": "めたん",
          "text": "今日のいちばんの驚きはどこですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "たぶん、人の体が電波の関所になっている、っていう話なのだ。"
        }
      ],
      "id": 1
    },
    {
      "title": "共有の電波道路",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まず、いちばん根っこの話からなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Bluetoothが使っているのは、2.4 GHzという周波数帯なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "2.4 GHz、聞いたことありますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "実はこれ、世界中で「免許なしで使っていい」と決められた共通の帯域なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "英語ではISM帯と呼ばれていて、産業・科学・医療用に開放されているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "誰でも自由に使える、便利な周波数ということですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "だからBluetoothは世界中の機器でそのまま動くのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも、便利だから、ものすごく混雑しているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "自由通行の道路には車が殺到する、というのと同じですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その例えがぴったりなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "同じ道路を走っているのは、Wi-Fi、電子レンジ、ZigBee、ベビーモニター、コードレス電話。"
        },
        {
          "speaker": "めたん",
          "text": "電子レンジまで、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "電子レンジは2450 MHzで食べ物を温めているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "シールドはあるけど、漏れた電波は同じ道路を走るのだ。"
        },
        {
          "speaker": "めたん",
          "text": "庫内でぶつかっている電波が、外にこぼれているということ？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。電子レンジが動くとBluetoothが弱る、という体験は理屈に合うのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あれ、思い込みじゃなかったんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それから、意外な犯人がもう一人いるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "もう一人？"
        },
        {
          "speaker": "ずんだもん",
          "text": "USB 3.0なのだ。USB 3.0のケーブルやハブから、2.4 GHz帯にノイズが漏れるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "これはIntelが公式文書で「Bluetoothに干渉しうる」と認めているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "パソコンに繋いだケーブルから、邪魔をしているということ？"
        },
        {
          "speaker": "ずんだもん",
          "text": "机の上のBluetoothドングルが、隣のUSB 3.0ハブに殺されている話は珍しくないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "USBケーブルが電波を漏らしているなんて、想像もしませんでしたわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "USB 3.0は内部で高速にデータを送るから、その信号がちょうど2.4 GHz帯にかぶるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "「机に置くと不安定」の正体が見えてきましたわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "道路は混んでいる。そして、混雑の犯人は、思った以上に身近にいるのだ。"
        }
      ],
      "id": 2
    },
    {
      "title": "周波数ホッピング",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "混んでる道路で、Bluetoothはどうやって走っているのか、なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "気になりますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "実はBluetoothは、周波数を1秒間に1600回も飛び回っているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "1600回、ですの。気が遠くなりますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "これを周波数ホッピングと呼ぶのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2.4 GHz帯を79本のレーンに分けて、ぴょんぴょん飛び移って通信するのだ。"
        },
        {
          "speaker": "めたん",
          "text": "なぜ、そんな忙しいことを？"
        },
        {
          "speaker": "ずんだもん",
          "text": "1本のレーンに居座ると、Wi-Fiの大きなトラックに潰される瞬間があるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "飛び回っていれば、潰されたレーンに居る確率が下がるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "どこかで衝突しても、次の瞬間には別のレーンに居るんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "これは1990年代の設計で、もとは軍用無線の発想なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "つまり、混雑前提で作られていた、ということですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "いい質問なのだ。実は、当初は「Wi-Fiみたいな大物」を想定していなかったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "……予想外、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "1999年にBluetoothが登場した頃、Wi-Fiはまだ家庭にほぼ無かったのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "当時の2.4 GHzの道路は、ガラガラだったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それが2000年代にWi-Fiが家庭にも広まって、状況が一変したんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。慌てて2003年に新機能が追加されたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それがAFH、適応的周波数ホッピングなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "適応的、ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Wi-Fiが使っているレーンを観測して、そこは避けて飛ぶ動きなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "交通整理係を後から雇った、みたいな感じですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その例えが近いのだ。今のBluetoothはWi-Fiの隣でもそこそこ動くのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも、これは「あとから追加された対策」だ、というのは押さえたいのだ。"
        },
        {
          "speaker": "めたん",
          "text": "設計時点で混雑を想定していたわけではなかった、ということですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。だから、AFHが効かない場面ではあっさり弱るのだ。"
        },
        {
          "speaker": "めたん",
          "text": "たとえばどんな場面ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "周囲の電波状況がコロコロ変わる場所、たとえば人混みや駅のホーム、なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "観測する暇もなく状況が変わってしまう、ということですのね。"
        }
      ],
      "id": 3
    },
    {
      "title": "体は水袋",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "次は、もっと身近な話なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "実は、人の体は2.4 GHzの電波をけっこう吸ってしまうのだ。"
        },
        {
          "speaker": "めたん",
          "text": "体が、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "人の体の60%くらいは水分なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そして水は、2.4 GHzの電波と相性が悪いのだ。"
        },
        {
          "speaker": "めたん",
          "text": "相性が悪い、とは？"
        },
        {
          "speaker": "ずんだもん",
          "text": "水分子は電波の中で揺さぶられて、エネルギーを熱に変えてしまうのだ。"
        },
        {
          "speaker": "めたん",
          "text": "……それ、聞き覚えがありますわ。電子レンジが食べ物を温めるしくみですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "まさにそうなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "電子レンジが2.45 GHzを使うのは、水を効率よく温められるからなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "偶然じゃないんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "偶然じゃないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Bluetoothの出力は微弱だから食べ物は温まらないけど、原理は同じなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "体の中を通ろうとすると、エネルギーが少しずつ吸われていくのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ポケットのスマホから耳のイヤホンへ届くとき、間の体で弱るんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "右ポケットから左耳まで、胴体を斜めに横切るルートになるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "その経路、けっこうな距離の水袋を通っていますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "人間の胴体はBluetoothにとって、巨大な濡れたタオルみたいな存在なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あの「机に置いた瞬間に途切れる」現象、もしかして……"
        },
        {
          "speaker": "ずんだもん",
          "text": "体が遮蔽物になっているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "机からポケットに入れると、経路が短くなって安定する、ということが起きるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ポケットのほうが安定する、という体感と合いますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "人混みも同じなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "駅のホームで音飛びするのは、周りの何十人もの「水袋」が壁になっているから。"
        },
        {
          "speaker": "めたん",
          "text": "他人の体まで関所になっているんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Bluetoothの出力は、Wi-Fiの数十分の一しかないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "もともと「届けばいい」くらいの控えめな電力で動いているから、吸収にも弱いのだ。"
        },
        {
          "speaker": "めたん",
          "text": "体一つで簡単に弱る、というのは、そういう事情なんですのね。"
        }
      ],
      "id": 4
    },
    {
      "title": "小さなアンテナ",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "もうひとつ、TWSイヤホン特有の事情があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あの完全ワイヤレスのイヤホンですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "あの中に、アンテナが入っているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あのちっちゃいケースに、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "サイズは数ミリしかないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "豆粒サイズですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "アンテナには、電波の波長と相性のいい長さがあるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2.4 GHzだと、本当は数センチくらい欲しいのだ。"
        },
        {
          "speaker": "めたん",
          "text": "イヤホンの中には収まりませんわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう、最初から「無理のあるサイズ」で動かしているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "物理的にハンデを背負っているんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "さらに、装着すると皮膚や水分に密着するのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "これが、アンテナの特性をわずかにズラしてしまうのだ。"
        },
        {
          "speaker": "めたん",
          "text": "耳の中、まさに水袋に直接押し付けている状態ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "机に置いた状態と耳に装着した状態では、電波の出方が違うのだ。"
        },
        {
          "speaker": "めたん",
          "text": "装着したらアンテナの調子が変わる、というのは盲点でしたわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そして、TWSにはもう一個ハンデがあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "もう一個、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "左右のイヤホンが、それぞれ独立した小さな機械なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "昔の方式は、片方が親になって受け取り、もう片方に転送していたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "バケツリレー、ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから片耳だけ切れる、という不思議な現象が起きやすかったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "最近のモデルは、その方式が変わったとも聞きましたわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "両方が同時にスマホを聞きにいく方式が、主流になってきたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "技術は地道に進歩しているんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ただ、アンテナの小ささは物理の壁だから、付き合い続けるしかないのだ。"
        }
      ],
      "id": 5
    },
    {
      "title": "設計上の宿命",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここまでは「電波そのもの」の話だったのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "次は、Bluetoothの「設計」が不安定さに加担している話なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "設計、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "音楽や通話で使う通信は、常に接続を保つタイプなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "常に、ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「ここに居ますよ」と確認し合いながら通信を続けているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ある程度の時間、相手の声が聞こえないと、切断と判断する仕組みなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "相手が急に黙ったら「ねえ聞いてる？」と言いたくなる、あの感覚ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その例えがちょうどいいのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "返事がない時間が一定を超えると、「もう切れた」と判定するのだ。"
        },
        {
          "speaker": "めたん",
          "text": "人混みで一瞬詰まっただけで、切断扱いになることもありますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "あるのだ。そして再接続には数秒かかる、その間は無音になるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "「ブツッ、シーン……ブツッ」っていう、あの感じ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "もうひとつ、プロファイルという仕組みも関わるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "プロファイル？"
        },
        {
          "speaker": "ずんだもん",
          "text": "Bluetoothには「音楽用」「通話用」と、機能ごとの規格があるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "A2DPは音楽用、HFPは通話用、というふうに別々なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "用途ごとに制服を着替えるイメージですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通りなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "音楽を聞いている途中で電話がかかると、A2DPからHFPに切り替わるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "通話中に音質が一気に落ちるあれ、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "HFPは双方向の通話のために、音楽用より低い品質モードに落ちる仕様なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "通信が悪いんじゃなくて、規格上そういう動きなんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう、不安定に「見える」現象には、設計上の挙動も混じっているのだ。"
        }
      ],
      "id": 6
    },
    {
      "title": "25年の地層",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "最後に、いちばん根の深い話をするのだ。"
        },
        {
          "speaker": "めたん",
          "text": "根の深い、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "Bluetoothって、実はひとつの規格じゃないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "え、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ClassicとLE、ふたつの全く違う無線が、同じ名前で同居しているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ふたつ、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "1999年に最初のBluetoothが登場した、これがClassicなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2010年に省電力向けに、BLE、Bluetooth Low Energyが追加されたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "これは新しい物理層で、Classicとは互換性が無いのだ。"
        },
        {
          "speaker": "めたん",
          "text": "別物が同じ名前を名乗っている、ということですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。実際は両対応のチップで、一緒に動かしているだけなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "地層、っておっしゃっていたのはそういう意味ですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そして、これだけじゃないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2017年にはMesh、2020年にはLE Audioが追加されたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "また増えていますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "仕様書は今や3000ページを超えているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "3000ページ……分厚い辞書ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "プロファイルも30個以上あって、それぞれ独立に進化してきたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "実装する側は、相当大変ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "これがメーカーごとの動作差を生むのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "iPhoneとAndroidとPCで挙動が違うのは、解釈の余地が大きいからなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "「同じBluetoothなのに何で？」の答えが、25年分の地層ですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう、不安定さの一部は、技術じゃなくて歴史が作っているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "では、これから一本化される予定はあるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "LE Audioという新しい音声規格が、ゆっくり置き換えを進めようとしているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ただ、Classic音声を使う機器がまだ世界中にあるから、置き換えは長い時間がかかるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "地層は、これからも当分は地層のまま、ということですのね。"
        }
      ],
      "id": 7
    },
    {
      "title": "三つの理由",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まとめると、不安定さの理由は大きく三つだったのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ひとつ目、世界中の機器がひしめく2.4 GHz帯という共有道路。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ふたつ目、人の体や小さなアンテナといった物理的なハンデ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "みっつ目、25年積み重なった仕様の地層。"
        },
        {
          "speaker": "めたん",
          "text": "「すぐ不安定になる」のは、運でも欠陥でもなく、構造の問題ですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1999年に「ケーブルを無くしたい」と願った仕組みが、25年後の今も頑張っているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "そう聞くと、ちょっと健気な感じもしますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "今度音飛びがしたら、責める前に思い出してあげてほしいのだ。"
        },
        {
          "speaker": "めたん",
          "text": "「あ、いま水袋の壁を越えているのね」と思えれば、気持ちもおだやかですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それで少しでも穏やかになれば、今日の話の元は取れたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ふふ、また次回もよろしくお願いしますわ。"
        }
      ],
      "id": 8
