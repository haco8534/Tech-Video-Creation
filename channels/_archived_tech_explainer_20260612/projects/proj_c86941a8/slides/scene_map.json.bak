  "scenes": [
    {
      "title": "押してるあのボタン",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ずんだもん、設定をスクロールしてたら「キャッシュを消去」ってボタンを見つけましたの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "あるのだ。ブラウザでもアプリでも、だいたい同じようなボタンが並んでるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "わたくし、よく押しますわ。動作が重くなった時や、サイトが最新にならない時に。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ぼくも押すのだ。月に一回くらい、なんとなく衝動的に押してる気がするのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ありますわ、そのノリ。「とりあえず消しとけば直るかも」みたいな。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ぼくも同じだったのだ。でもちょっと前に、あれを調べていて気づいたのだ。"
        }
      ],
      "id": 0
    },
    {
      "title": "何を消した？",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "「キャッシュを消す」って押した時、本当に何が消えてるか説明できる人、あんまりいないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "言われてみると、中身を考えたことないですわね。何となく「要らないゴミ」くらいの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そこなのだ。今日の動画は、あのボタンの裏側を覗きに行く回なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "裏側って、そんなに大げさな話になりますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "けっこう大げさなのだ。「キャッシュ」の下に、別物の仕組みが七つも八つも並んでるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "「キャッシュ」って単語は毎日のように耳にしますけれど、正体はぼんやりしてますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "耳になじみすぎて、逆に確認しないまま使ってる人が多いのだ。ぼくもそうだったのだ。"
        }
      ],
      "id": 1
    },
    {
      "title": "今日の道筋",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "今日の道筋を先に言っておくのだ。まず言葉の語源、次になぜ存在するか。"
        },
        {
          "speaker": "めたん",
          "text": "へえ、語源からですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そのあと、あのボタンが裏で何を触っているか、そして消すと本当に速くなるかを見るのだ。"
        },
        {
          "speaker": "めたん",
          "text": "最後にスマホ事情もお願いしますわ。iPhoneには消すボタンがないの、ずっと気になってましたの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "最後に全部まとめて、「結局どうすればいいか」で着地する、そんな二十分なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "流れが先に見えると、安心して聞けますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "途中で分からない単語が出ても、その都度ぼくが噛み砕いていくから心配ないのだ。"
        }
      ],
      "id": 2
    },
    {
      "title": "実はフランス語",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ではまず語源、お願いしますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「キャッシュ」って英語に見えるけど、元はフランス語なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "フランス語ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "綴りは cacher、カシェ。意味は「隠す」なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "隠す……コンピュータの中で「隠す」って、なんだか物騒ですわね。"
        }
      ],
      "id": 3
    },
    {
      "title": "隠し場所が語源",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "物騒じゃないのだ。昔のカナダの罠猟師が、森で獲った獲物を隠す場所をこう呼んだらしいのだ。"
        },
        {
          "speaker": "めたん",
          "text": "獲物の隠し場所、ですの。ちゃんと場所を決めて、こっそり置いておく感じですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そういう感じなのだ。「よく使うものを手近に忍ばせておく」という性格が、元から入ってるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "「貯蔵庫」より「隠し場所」のニュアンスが強いんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。だから今のキャッシュも、外から見えにくいところで動くのが基本なのだ。"
        }
      ],
      "id": 4
    },
    {
      "title": "1965年の命名",
      "lines": [
        {
          "speaker": "めたん",
          "text": "コンピュータの言葉になったのはいつですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "1965年、ケンブリッジ大学のWilkesという人の論文なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "そんなに古い話。1965年というと、コンピュータ自体がまだ高価で大きかった時代ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。当時メモリは高くて遅くて、もっと速くする方法を真剣に考えてたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ただし面白いのが、当時はまだ「キャッシュ」と呼ばれてなかったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "え、じゃあ何と呼んでましたの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "slave memory、「奴隷の記憶」なのだ。"
        }
      ],
      "id": 5
    },
    {
      "title": "編集者の一言",
      "lines": [
        {
          "speaker": "めたん",
          "text": "奴隷の記憶、って……今だったら絶対に通らない名前ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1967年にIBMの論文を編集してた人が、辞書を引いて cache に書き換えた、と記録があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "編集者の一言で呼び名が決まったんですの。もし通らなかったら。"
        },
        {
          "speaker": "ずんだもん",
          "text": "今頃みんなで「マファーを消去」とか言ってたかもしれないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ともあれ、出自は「よく使うものを隠しておく場所」ですのね。"
        }
      ],
      "id": 6
    },
    {
      "title": "冷蔵庫とスーパー",
      "lines": [
        {
          "speaker": "めたん",
          "text": "そもそもの話を聞かせてほしいですの。なぜ「隠しておく場所」が要りますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "冷蔵庫を想像してほしいのだ。"
        },
        {
          "speaker": "めたん",
          "text": "冷蔵庫、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "毎日使う牛乳、わざわざスーパーまで買いに行くのは無駄なのだ。だから家の冷蔵庫に置いておくのだ。"
        },
        {
          "speaker": "めたん",
          "text": "言われてみると確かに。スーパーは「全部揃ってるけど遠い」、冷蔵庫は「少ないけど近い」。"
        }
      ],
      "id": 7
    },
    {
      "title": "速度差の正体",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "コンピュータでも同じなのだ。ハードディスクやネットの向こうのサーバーは、「全部あるけど遠い」なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "遠いというのは、物理的にですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "物理もあるし、速度の話もあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "どれくらい違いますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "CPUの一番内側のキャッシュと、メインメモリ、教科書的にざっくり百倍くらい速度差があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "百倍って、毎日感じるレベルなんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "体感はしないのだ。一秒未満で何百万回も処理する世界の話だから、人間の感覚に入ってこないのだ。"
        }
      ],
      "id": 8
    },
    {
      "title": "手元と保管庫",
      "lines": [
        {
          "speaker": "めたん",
          "text": "百倍……それはスーパーまで歩くどころじゃないですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから、よく使うデータは「もっと近い場所」に一時的に置いておくのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それがキャッシュですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "手元の作業台によく使う工具を並べるのと同じ発想なのだ。地下の棚まで毎回行くのは効率が悪いのだ。"
        }
      ],
      "id": 9
    },
    {
      "title": "ヒット率95%",
      "lines": [
        {
          "speaker": "めたん",
          "text": "効果はどれくらいあるものですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "CPUの一番内側のキャッシュは、教科書的に九十五パーセント以上ヒットするのが普通と言われるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "十回のうち九回以上は、遠くまで行かずに済んでる計算ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。だから「キャッシュ」は速くする魔法みたいな扱いを受けるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "そんなに当たってるなら、消したくなる気持ちが、ちょっと揺らぎますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。「キャッシュは敵」じゃなくて、むしろ縁の下の主役なのだ。"
        }
      ],
      "id": 10
    },
    {
      "title": "実は分身している",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここからが今日の本題なのだ。「キャッシュ」は一つじゃない。分身してるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "分身……どういうことですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "同じ「キャッシュ」という言葉で、別物の仕組みが少なくとも七つ八つ呼ばれてるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "七つ八つ。急に増えましたわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "CPUのL1とL2とL3、OSのページキャッシュ、DNSキャッシュ、HTTPキャッシュ。"
        },
        {
          "speaker": "めたん",
          "text": "まだありますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ブラウザのService Workerのキャッシュ、CDNと呼ばれる中継地のキャッシュ、「戻る」ボタン用のキャッシュ。"
        }
      ],
      "id": 11
    },
    {
      "title": "ブラウザの中身",
      "lines": [
        {
          "speaker": "めたん",
          "text": "一度ブラウザの中だけに絞って見せてほしいですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ブラウザの中だけでも、複数のストアが並列で動いてるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ストアというのは、「置き場」みたいな意味ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。HTTPキャッシュ、Cache Storage、IndexedDB、localStorage、Cookie。"
        },
        {
          "speaker": "めたん",
          "text": "全部、「キャッシュ」として一括りにされてる気がしますの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Web標準の仕様では「キャッシュ」と「ストレージ」は別物なのだ。ただ、ボタン一個で一緒に消されるのだ。"
        }
      ],
      "id": 12
    },
    {
      "title": "Cookieも巻き込む",
      "lines": [
        {
          "speaker": "めたん",
          "text": "一緒に消される？"
        },
        {
          "speaker": "ずんだもん",
          "text": "Chromeで「Cookieとその他のサイトデータ」を選ぶと、CookieだけじゃなくIndexedDBなども巻き込むのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それって、ログイン情報が吹き飛ぶやつですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。「キャッシュを消したらログアウトしてた」経験、結構あると思うのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ありますわ。あれ、勝手にログアウトされたと思ってましたの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "厳密には「キャッシュ」じゃなく、「Cookieとサイトデータ」の方を消したから、なのだ。"
        }
      ],
      "id": 13
    },
    {
      "title": "DNSは別々",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ブラウザの外にもキャッシュはありますのよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "例えばDNSキャッシュ。これはOSとブラウザで、別々に持ってるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "別々に？"
        },
        {
          "speaker": "ずんだもん",
          "text": "パソコンのDNSキャッシュをコマンドで消しても、Chromeは自分の中に別のDNSキャッシュを持ってるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "そっちは残ってしまうんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "消したつもりで消せてない層が、同じ端末の中にいくつもあるのだ。"
        }
      ],
      "id": 14
    },
    {
      "title": "CDNも仲間",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "もう一つ大きいのが、CDNという中継のキャッシュなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それはどこにありますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ユーザーの近くに配置された、世界中のサーバーなのだ。動画や画像をコピーして、近い場所から配る仕組みなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それも手元のボタンで消せますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ユーザー側からは触れないのだ。ブラウザのキャッシュを消しても、CDNに古いものが残れば古いまま届くのだ。"
        }
      ],
      "id": 15
    },
    {
      "title": "消したのに残る訳",
      "lines": [
        {
          "speaker": "めたん",
          "text": "「消したのに最新が出ない」の正体は、そこですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そこもあるし、仕様側の理由もあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "仕様側？"
        },
        {
          "speaker": "ずんだもん",
          "text": "HTTPの仕様には「古いものをとりあえず見せて、裏でこっそり最新に差し替える」モードがあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "最新と思って見てたのが、一回古かった、ということがありえるんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それがバグではなく、仕様どおりの挙動なのだ。"
        }
      ],
      "id": 16
    },
    {
      "title": "消すと速い神話",
      "lines": [
        {
          "speaker": "めたん",
          "text": "では本命の話。「キャッシュを消すと速くなる」はどうですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "結論、半分は神話なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "半分、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "キャッシュは「速くするための仕組み」なのだ。消した瞬間に、速くするための仕組みを壊したことになるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "じゃあ逆に遅くなる、ということですの？"
        }
      ],
      "id": 17
    },
    {
      "title": "再ダウンロードの罠",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "消した直後、いつも見ているサイトを開くと、画像も動画も全部ダウンロードし直しになるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "帯域も時間も、余分に使いますのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「消したら軽くなった気がする」は、実はキャッシュではなくてタブを閉じた効果、ということも多いのだ。"
        },
        {
          "speaker": "めたん",
          "text": "切り分けが難しいですわね。"
        }
      ],
      "id": 18
    },
    {
      "title": "カーネルの警告",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "OSの話も似てるのだ。Linuxには、メモリキャッシュを強制的に解放するコマンドがあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "聞いたことありますわ、サーバー管理で使うやつ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それの公式ドキュメントに、こう書いてあるのだ。「テストやデバッグ以外では使うことを推奨しない」と。"
        },
        {
          "speaker": "めたん",
          "text": "作った本人たちが「むやみに消すな」と言ってますの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "キャッシュの成長を抑える手段でもないし、IOとCPUを余計に使うだけだ、と明記されてるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "「キャッシュ＝邪魔者」のイメージとは真逆ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "作った側からすると、キャッシュはRAMをちゃんと使い切るための工夫なのだ。"
        }
      ],
      "id": 19
    },
    {
      "title": "それでもボタンはある",
      "lines": [
        {
          "speaker": "めたん",
          "text": "でも、ボタンは用意されてますのよね。なぜですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "元々は、開発者のデバッグ用だったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "一般の人向けじゃなかった。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「古いものが表示され続けて、最新が試せない」ときの強制リセット手段だったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それが、Webの普及と一緒に一般のUIに昇格した、と。"
