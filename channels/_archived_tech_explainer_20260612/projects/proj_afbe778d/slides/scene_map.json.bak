  "scenes": [
    {
      "title": "素朴な疑問",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ねえずんだもん。ちょっと聞いてもよろしくて？"
        },
        {
          "speaker": "ずんだもん",
          "text": "何なのだ？"
        },
        {
          "speaker": "めたん",
          "text": "プログラマーって、結局何をしているんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "……意外と、考えたことなかったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "コードをカタカタ打って、機械に命令を与えている、みたいなイメージですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "確かにそれっぽい絵ではあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "でも、実際に何をやっているかは、よく分かっていなくて。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ぼくも、調べ始めて驚いたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "なにに？"
        },
        {
          "speaker": "ずんだもん",
          "text": "コードを書く時間って、プログラマの1日の、たった1〜2割なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "えっ、じゃあ残りの8割は何をしていますの？"
        }
      ],
      "id": 0
    },
    {
      "title": "3つの違和感",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "今日はね、プログラミングの素朴なイメージを3つ崩していきたいのだ。"
        },
        {
          "speaker": "めたん",
          "text": "3つ。楽しそうですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1つ目、コードを書くことは、プログラミングの中心じゃない。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2つ目、書いたコードは、書いた順で実行されていない。"
        },
        {
          "speaker": "ずんだもん",
          "text": "3つ目、最初のプログラマは、そもそも文字を打っていなかった。"
        },
        {
          "speaker": "めたん",
          "text": "……どれも直感と逆ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。全部ひっくり返したあとで、じゃあ何をしているのか、に戻るのだ。"
        }
      ],
      "id": 1
    },
    {
      "title": "見取り図",
      "lines": [
        {
          "speaker": "めたん",
          "text": "では、今日の見取り図を先にお願いできますか？"
        },
        {
          "speaker": "ずんだもん",
          "text": "まず、プログラマの1日を開けてみる。"
        },
        {
          "speaker": "ずんだもん",
          "text": "次に、CPUの中の実行順を開けてみるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それから、歴史をさかのぼって、最初のプログラマに会いに行くのだ。"
        },
        {
          "speaker": "めたん",
          "text": "最後は？"
        },
        {
          "speaker": "ずんだもん",
          "text": "じゃあ何をしているのか、を、業界のレジェンドたちの定義で答えるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "きっちり最初の問いに帰ってくる構成ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "はいなのだ。では、最初のひっくり返しからいくのだ。"
        }
      ],
      "id": 2
    },
    {
      "title": "1日の中身",
      "lines": [
        {
          "speaker": "めたん",
          "text": "さっきの「1〜2割」の話、詳しく聞きたいですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "プログラマの1日を分解した業界調査がいくつかあってね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "新しいコードを打ち込んでいる時間は、ざっくり1〜2割なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "残りは？"
        },
        {
          "speaker": "ずんだもん",
          "text": "大きいのが、デバッグなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "書いたコードがうまく動かない原因を、ひたすら探す時間のことなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "バグ取りですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "複数の業界調査で、開発時間の35〜50%がデバッグに使われているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "複雑なシステムだと、最大75%という報告もあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "半分以上が、壊れたものを直す時間ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。作業の主役は、書くことじゃなく、直すことなのだ。"
        }
      ],
      "id": 3
    },
    {
      "title": "もう一つの主役",
      "lines": [
        {
          "speaker": "めたん",
          "text": "もう一つの主役は何ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "読む時間なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "自分で書いたコードを、読むんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "自分のもだし、他人のもだし、1年前の自分のものも読むのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "業界で広く読まれている本によるとね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "読む時間は、書く時間の10倍あると言われているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "10倍。想像よりずっと長いですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "新しい機能を1つ付け足すには、まず周りを理解しないといけないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "家の増築と同じですわね。壁の中を見ずに釘を打ったら崩れてしまいますもの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "うまい例えなのだ。書く前に、必ず読むが入るのだ。"
        }
      ],
      "id": 4
    },
    {
      "title": "タイピング以外",
      "lines": [
        {
          "speaker": "めたん",
          "text": "では、残りの時間は？"
        },
        {
          "speaker": "ずんだもん",
          "text": "会議、検索、ツール操作、ドキュメント書き、環境の準備……"
        },
        {
          "speaker": "ずんだもん",
          "text": "いわゆる、キーボードを叩く以外が、ものすごく多いのだ。"
        },
        {
          "speaker": "めたん",
          "text": "想像していた、黙々とコードを打つ人の姿は、もう跡形もないですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "映画のハッカーのイメージは、現実のプログラマとは結構違うのだ。"
        },
        {
          "speaker": "めたん",
          "text": "まず、ここでひとつ素朴イメージが崩れましたわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "コードを書くは、主役じゃなくて、脇役のひとつなのだ。"
        }
      ],
      "id": 5
    },
    {
      "title": "コードの順番",
      "lines": [
        {
