  "scenes": [
    {
      "title": "無料なのに儲かる謎",
      "lines": [
        {
          "speaker": "めたん",
          "text": "スマホのアプリって、ほとんどタダでダウンロードできますわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。アプリストアに並ぶアプリの、だいたい98%が無料配布なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ほぼ全部、無料ですのね。なのに、作ってる会社は潰れてませんわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "潰れないどころか、アプリ業界で動いてるお金の9割以上は、無料アプリから生まれてるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "無料なのに、そんなに稼いでますの。どういう仕組みですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "よく聞く説明に、こういうのがあるのだ。「タダで使ってるなら、あなた自身が商品なんだよ」って言い方なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "わたくしも聞いたことありますわ。なんとなく、わかったような気になりますのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "便利な言葉なのだけど、ぼくが調べた感じ、この説明は半分しか合ってないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "半分、ですの。残りの半分が気になりますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その残りの半分を、今日はゆっくり見ていくのだ。"
        }
      ],
      "id": 0
    },
    {
      "title": "今日の見取り図",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "流れはシンプルなのだ。4つの順番で見ていくのだ。"
        },
        {
          "speaker": "めたん",
          "text": "並べてくださいまし。"
        },
        {
          "speaker": "ずんだもん",
          "text": "まず、お金を払ってないなら、ぼくたちは何を払ってるのか。"
        },
        {
          "speaker": "めたん",
          "text": "対価の中身、ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "次に、会社はそれをどう受け取って、お金に変えてるのか。"
        },
        {
          "speaker": "めたん",
          "text": "回収の仕組みですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "三番目に、さっきの「あなたが商品」って言葉を、本当にそうか疑ってみるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "標語を一度疑うのは大事ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "最後に、じゃあどう付き合えばいいかを考えるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "怖がる話でも、諦める話でもないってことですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "分解して見るだけで、選べる側に回れるのだ。"
        }
      ],
      "id": 1
    },
    {
      "title": "3つの見えない対価",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "無料アプリを使うとき、ぼくたちが払ってるものは、大きく3つあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "3つ、並べてくださいまし。"
        },
        {
          "speaker": "ずんだもん",
          "text": "画面を見てる時間。それから、どこで何をしたかのデータ。最後に、集中力なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "時間とデータはわかりますけど、集中力って、どういうことですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "通知が来るたびに、頭の切り替えが起きるって話なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "仕事中にメッセージが来て、戻るのに時間がかかるアレですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。一度気を取られると、完全に戻るまで十数分かかるって研究もあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ひゃあ、けっこう長いですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1日に何回も中断が起きると、その細切れが積み重なるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "10回通知が来たら、気づかないうちに集中時間をごっそり持っていかれますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "つまり無料に見えて、集中の細切れを、けっこう払ってるのだ。"
        }
      ],
      "id": 2
    },
    {
      "title": "1日4時間半",
      "lines": [
        {
          "speaker": "めたん",
          "text": "みんなは、1日どれくらい画面を見てますの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2024年の世界平均で、スマホを1日およそ4時間半触ってるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "4時間半。起きてる時間の、3割近いですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そしてその時間のうち、だいたい3分の2がSNSと動画系に集中してるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "残りのアプリ全部合わせて、3分の1ですの。かなり偏ってますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "時間という対価は、ごく少数のアプリに集まって払われてるのだ。"
        }
      ],
      "id": 3
    },
    {
      "title": "注意の奪い合い",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで一つ、骨組みになる考え方を共有したいのだ。"
        },
        {
          "speaker": "めたん",
          "text": "どんなですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "情報は、世の中に増えるほど安くなる。でも、ぼくたちが見られる量には限界があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "1日24時間より見られませんものね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから、希少なのは情報のほうじゃなくて、こちら側の「注意」なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "希少なものは、奪い合いになりますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "無料アプリの世界は、ぼくたちの注意を取り合う市場なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "お金を払う前に、わたくしたちの目や指の時間が、もう商品になってるんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから「無料」って言葉は、お金の話だけしてるのだ。他の対価は、言葉に出てこないだけなのだ。"
        }
      ],
      "id": 4
