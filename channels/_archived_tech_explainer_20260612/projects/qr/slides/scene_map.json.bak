{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "id": 0,
      "title": "QRコードの秘密",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ずんだもん、1つ聞いてもいいですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "もちろんなのだ"
        },
        {
          "speaker": "めたん",
          "text": "QRコードの隅にある3つの大きな四角、あれ何なのか知ってますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "おっ、いい質問なのだ！あれが今日の話のカギになるのだ"
        }
      ]
    },
    {
      "id": 1,
      "title": "22億人の日常",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まず1つ数字を出すのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ある統計によると世界で22億人以上が日常的にQRコードを使っているのだ"
        },
        {
          "speaker": "めたん",
          "text": "22億人…！わたくし毎日使ってるのに、模様の意味なんて考えたことなかったですわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "みんなそうなのだ。でもあの白黒の点々、実は1ドットも無駄がないのだ"
        }
      ]
    },
    {
      "id": 2,
      "title": "3割消えても読める",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで思考実験をするのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "QRコードの3割くらいをマジックで塗りつぶしてみるのだ"
        },
        {
          "speaker": "めたん",
          "text": "3割も塗りつぶしたら、さすがに読めなくなるんじゃないですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ところが、ちゃんと読めるのだ"
        },
        {
          "speaker": "めたん",
          "text": "壊れてるのに読める…！？バーコードなら絶対無理ですわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "バーコードだと1本線が消えただけでアウトなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもQRコードには「見つける」「直す」「読む」の3つの仕組みが重なっているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "今日はその設計の秘密を全部見ていくのだ！"
        }
      ]
    },
    {
      "id": 3,
      "title": "バーコードの限界",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "QRコードを理解するにはまずバーコードから見ていくのだ"
        },
        {
          "speaker": "めたん",
          "text": "スーパーのレジで「ピッ」ってやるあれですわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。バーコードは線の太さと間隔で数字を表しているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも1列の線だから、入る情報は英数字で最大20文字程度なのだ"
        },
        {
          "speaker": "めたん",
          "text": "たった20文字！？URLすら入らないですわね"
        }
      ]
    },
    {
      "id": 4,
      "title": "1次元から2次元へ",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここがポイントなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "バーコードは情報を「横一列」にしか並べられないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "これを「棚の1段にしか本を置けない本棚」だと思ってほしいのだ"
        },
        {
          "speaker": "めたん",
          "text": "なるほど…段を増やせばもっと本が入りますわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "まさにそれなのだ！縦横に情報を並べる2次元にしたのがQRコードなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "同じ面積でバーコードの約350倍、数字なら最大7089桁も入るのだ"
        },
        {
          "speaker": "めたん",
          "text": "350倍！しかもバーコードにはない誤り訂正もあるんですわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。しかもサイズも柔軟で、21×21セルから177×177セルまで40段階あるのだ"
        },
        {
          "speaker": "めたん",
          "text": "用途に合わせてサイズを選べるんですのね"
        }
      ]
    },
    {
      "id": 5,
      "title": "囲碁からの着想",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "その通りなのだ。で、この2次元コードの発想がどこから来たか"
        },
        {
          "speaker": "ずんだもん",
          "text": "1994年、デンソーという会社の原昌宏さんがたった2人で開発したのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "当時トヨタの工場では部品にバーコードを10個も並べて管理していたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "現場から「もっと多くの情報を1つに入れてほしい」と頼まれたのだ"
        },
        {
          "speaker": "めたん",
          "text": "10個も！そりゃ現場は大変ですわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "で、原さんが昼休みに打っていた囲碁がヒントになったと言われているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "碁盤に白と黒の石を並べる。まさに二次元の白黒パターンなのだ"
        },
        {
          "speaker": "めたん",
          "text": "囲碁からQRコード！面白い着想ですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "ただしこのエピソードは語り継がれるうちに美化されている可能性もあるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "実際の開発は1年半もの地道な試行錯誤だったのだ"
        }
      ]
    },
    {
      "id": 6,
      "title": "QRコードの全体像",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "こうして生まれたQRコードの構造を見てみるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "大きく分けると5つのパーツがあるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "3隅の大きな四角が「ファインダーパターン」なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "白黒の交互の点線が「タイミングパターン」なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "小さな四角が「アライメントパターン」、歪みの補正用なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "そして残りの大部分が「データ」と「誤り訂正」の領域なのだ"
        },
        {
          "speaker": "めたん",
          "text": "全部に役割があるんですのね…"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。ではいよいよ「見つける」仕組みから見ていくのだ"
        }
      ]
    },
    {
      "id": 7,
      "title": "3つの四角の正体",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "スマホをQRコードにかざすと何が起きるか考えてみるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "カメラにはQRコードだけじゃなく周りの文字や模様も映っているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "その中から「ここにQRコードがある！」と見つけるのが最初の仕事なのだ"
        },
        {
          "speaker": "めたん",
          "text": "それが3つの四角の役割ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ！3つの四角の位置関係で、コードの場所・大きさ・傾きが一瞬でわかるのだ"
        }
      ]
    },
    {
      "id": 8,
      "title": "1:1:3:1:1の発見",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "でもここからが本当に面白いところなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "この四角を拡大すると黒・白・黒の入れ子構造になっているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "横に切ると黒白の幅が1:1:3:1:1の比率になるのだ"
        },
        {
          "speaker": "めたん",
          "text": "1:1:3:1:1…なぜそんな中途半端な比率ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "原さんたちは膨大な量の印刷物を調べたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "チラシ、雑誌、段ボール、あらゆる印刷物の白黒パターンを分析したのだ"
        },
        {
          "speaker": "めたん",
          "text": "えっ、そんな地道な調査をしたんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ぼくも最初これを知ったとき驚いたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "理論ではなく実地調査で最適解を見つけるアプローチなのだ"
        }
      ]
    },
    {
      "id": 9,
      "title": "存在しない比率",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "その結果「1:1:3:1:1は印刷物の中で最も出現しない比率」だとわかったのだ"
        },
        {
          "speaker": "めたん",
          "text": "つまり他の模様と絶対に間違えない比率を探し出したってことですの！？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そういうことなのだ。漢字にもハングルにもアルファベットにもこの比率は現れないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから背景にどんな文字や絵があっても誤検出がほぼ起きないのだ"
        },
        {
          "speaker": "めたん",
          "text": "力技と数学で見つけた答え…地味だけどすごいですわ"
        }
      ]
    },
    {
      "id": 10,
      "title": "360度読み取り",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "しかもこの比率、どの方向から切っても同じ1:1:3:1:1なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "縦に切っても斜めに切っても、入れ子構造だから比率が変わらないのだ"
        },
        {
          "speaker": "めたん",
          "text": "あっ、確かにいつもスマホを適当にかざしてますわ。角度なんて気にしたことない"
        },
        {
          "speaker": "ずんだもん",
          "text": "それがこの設計のおかげなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "バーコードは正面から真っ直ぐスキャンする必要があったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもQRコードは360度どこからでも読める。Quick Responseの名に恥じないのだ"
        },
        {
          "speaker": "めたん",
          "text": "バーコードだとレジの人がピッと向きを合わせてますわよね。あれが不要になったと"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。向きを気にしなくていいのは日常的にかなり助かっているはずなのだ"
        }
      ]
    },
    {
      "id": 11,
      "title": "静寂ゾーン",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ところでQRコードの周りの余白にも意味がありますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "鋭いのだ！それは「静寂ゾーン」と呼ばれているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "QRコードの境界をはっきりさせるための余白で、最低4セル分必要なのだ"
        },
        {
          "speaker": "めたん",
          "text": "デザインで余白を削りすぎると読めなくなるってことですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通りなのだ。さて、位置は見つかった。でも1つ問題が残っているのだ"
        },
        {
          "speaker": "めたん",
          "text": "問題？"
        },
        {
          "speaker": "ずんだもん",
          "text": "汚れたらどうするか、なのだ"
        }
      ]
    },
    {
      "id": 12,
      "title": "もし訂正がなかったら",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで思考実験をしてみるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "もしQRコードに誤り訂正がなかったらどうなるか？"
        },
        {
          "speaker": "めたん",
          "text": "ちょっとでも汚れたら読めなくなりますわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。工場の部品コードが油で汚れたら一発アウトなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "QRコードはそもそも工場生まれだから、汚れに耐えることは必須だったのだ"
        },
        {
          "speaker": "めたん",
          "text": "確かに、工場は紙がきれいなままってことはないですわよね"
        }
      ]
    },
    {
      "id": 13,
      "title": "リード・ソロモンの直感",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そこで登場するのが「リード・ソロモン符号」なのだ"
        },
        {
          "speaker": "めたん",
          "text": "リード・ソロモン…ちょっと難しそうですわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "考え方は意外とシンプルなのだ。たとえ話で説明するのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「1, 3, 5, 7」という数列があるとするのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "これは「2ずつ増える」という規則があるのだ"
        },
        {
          "speaker": "めたん",
          "text": "それなら1つ消えても復元できますわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通りなのだ。「1, ?, 5, 7」でも「?は3」とわかるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "リード・ソロモンも本質は同じで、データに数学的な規則を付け加えているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "壊れた部分があっても残りの規則から元データを復元できるのだ"
        },
        {
          "speaker": "めたん",
          "text": "でも実際のQRコードはもっと複雑なデータですわよね？"
        },
        {
          "speaker": "ずんだもん",
          "text": "もちろんなのだ。実際には多項式の計算を使っているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ざっくり言うと、データを多項式として表現して余分な項を追加するイメージなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "厳密な数学は結構深いから、ここでは「規則を付け足す」と覚えてほしいのだ"
        }
      ]
    },
    {
      "id": 14,
      "title": "CDもQRも同じ技術",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ちょっと待ってくださいまし。リード・ソロモンって、どこかで聞いたような…"
        },
        {
          "speaker": "ずんだもん",
          "text": "実はCDやDVDにも全く同じ技術が使われているのだ！"
        },
        {
          "speaker": "めたん",
          "text": "えっ！CDの裏に傷がついても音が飛ばないの、不思議に思ってましたわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "あれがまさにリード・ソロモン符号のおかげなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "それだけじゃないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "NASAのボイジャー探査機が何十億kmの彼方から送る信号にも使われているのだ"
        },
        {
          "speaker": "めたん",
          "text": "宇宙からQRコードまで、同じ数学が使われてるって感動しますわ…！"
        }
      ]
    },
    {
      "id": 15,
      "title": "インターリーブ",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "さらにもう1つ賢い工夫があるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "QRコードではデータを複数ブロックに分けて交互に配置しているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "これを「インターリーブ」と呼ぶのだ"
        },
        {
          "speaker": "めたん",
          "text": "交互に？それに何の意味がありますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "コーヒーをこぼして一箇所が汚れた場面を想像してほしいのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "データが順番に並んでいたら、1つのブロックが丸ごと壊れるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも交互に配置していれば被害が複数ブロックに分散されるのだ"
        },
        {
          "speaker": "めたん",
          "text": "あぁ！各ブロックのダメージが少なければ、それぞれ復元できますわね！"
        }
      ]
    },
    {
      "id": 16,
      "title": "デザインQRの仕組み",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ちなみに企業のロゴが入ったQRコード、見たことあるのだ？"
        },
        {
          "speaker": "めたん",
          "text": "ありますわ！あれずっと不思議に思ってましたの"
        },
        {
          "speaker": "ずんだもん",
          "text": "あれは誤り訂正レベルを最高のHに設定しているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "Hだと最大30%が壊れていても復元できるから、中央にロゴを置けるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ちなみにレベルは4段階で、L7%、M15%、Q25%、H30%なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "復元力を上げるほど冗長データが増えるから格納できるデータ量は減るのだ"
        },
        {
          "speaker": "めたん",
          "text": "安全性と容量のトレードオフですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "まさにそうなのだ。万能な正解はなくて用途に合わせて選ぶのだ"
        },
        {
          "speaker": "めたん",
          "text": "わざと壊して数学の力で読めるようにするデザインQR、発想が面白いですわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "さて、見つけて直して、最後は「読む」仕組みなのだ"
        }
      ]
    },
    {
      "id": 17,
      "title": "読み取りの全体像",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "QRコードの読み取りは大きく6ステップで進むのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "まずカメラが画像を撮って、白と黒の2値に変換するのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "次にファインダーパターンで位置と傾きを特定するのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "そしてタイミングパターンでセルの座標を確定させるのだ"
        },
        {
          "speaker": "めたん",
          "text": "タイミングパターンというのは？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ファインダーの間を結ぶ白黒交互の点線なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "方眼紙の線みたいに、どのセルがどの位置かを教えてくれるのだ"
        },
        {
          "speaker": "めたん",
          "text": "なるほど、座標の基準になるんですわね"
        }
      ]
    },
    {
      "id": 18,
      "title": "4つのモード",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "座標が決まったらデータを取り出すのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "QRコードには4つのエンコードモードがあるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "数字だけなら10ビットで3桁、英数字なら11ビットで2文字を表せるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "さらに漢字モードもあるのだ。13ビットで漢字1文字を表現できるのだ"
        },
        {
          "speaker": "めたん",
          "text": "数字専用のモードがあるなら、URLより電話番号の方が効率的ですのね"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通り。格納する内容に応じて最適なモードが自動で選ばれるのだ"
        }
      ]
    },
    {
      "id": 19,
      "title": "マスクパターン",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "最後にもう1つ、QRコードの見た目を決める重要な仕組みがあるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「マスクパターン」と呼ばれているのだ"
        },
        {
          "speaker": "めたん",
          "text": "マスク？何かを隠すんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "データをそのまま白黒にすると偏りが出ることがあるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "たとえば黒が広い範囲に固まると読み取り精度が落ちるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "そこで8種類のマスクパターンを順番に試すのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "白と黒のバランスが最も良くなるパターンを自動で選んでいるのだ"
        },
        {
          "speaker": "めたん",
          "text": "あの模様がランダムに見えるのはマスクのせいだったんですのね！"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。あの一見ランダムな模様は計算で最適化された結果なのだ"
        }
      ]
    },
    {
      "id": 20,
      "title": "32ミリ秒の世界",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ところでここまでの全処理、どれくらい時間がかかりますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "英数字100文字以下のQRコードなら、わずか32ミリ秒で完了するのだ"
        },
        {
          "speaker": "めたん",
          "text": "32ミリ秒！？まばたきより速いですわ！"
        },
        {
          "speaker": "ずんだもん",
          "text": "Quick Responseは伊達じゃないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "それと1つ大事な補足をしておくのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "QRコードは「暗号化」ではなく「符号化」なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "中身は誰でもスキャンすれば読めるのだ。秘密のメッセージではないのだ"
        },
        {
          "speaker": "めたん",
          "text": "暗号だと思ってる人、結構多そうですわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから街中のQRコードを不用意にスキャンするのは気をつけてほしいのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "最近はQRコードを使ったフィッシング詐欺も増えているのだ"
        },
        {
          "speaker": "めたん",
          "text": "便利な技術だからこそ、悪用されるリスクもあるんですわね"
        }
      ]
    },
    {
      "id": 21,
      "title": "オープン戦略",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ずんだもん、こんなに精巧な技術なのになぜ世界中で無料で使えますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ここにデンソーウェーブの巧みな戦略があるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "QRコードの仕様は無償で公開して誰でも自由に使えるようにしたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "一方で読み取り装置の特許は保持して、そちらで収益を上げているのだ"
        },
        {
          "speaker": "めたん",
          "text": "仕様はオープン、装置はクローズ…なるほど賢いですわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "この戦略のおかげで誰でも自由にQRコードを作れるようになったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ただし裏を返せば、悪意あるQRコードも簡単に作れてしまうのだ"
        },
        {
          "speaker": "めたん",
          "text": "便利さとリスクは表裏一体ですわね"
        }
      ]
    },
    {
      "id": 22,
      "title": "普及の3つの波",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "普及には大きく3つの波があったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "最初は2002年頃、日本の携帯電話にQRリーダーが搭載されたときなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "次が2010年代の中国。AlipayやWeChat PayでQR決済が爆発的に広まったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "そして2020年のコロナ禍で非接触のニーズから欧米にも一気に広がったのだ"
        },
        {
          "speaker": "めたん",
          "text": "工場の部品管理から始まって、世界の決済インフラになったんですのね"
        },
        {
          "speaker": "ずんだもん",
          "text": "開発した原さん自身も「決済での使用は想定外だった」と語っているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "2014年には欧州発明家賞を日本人として初めて受賞しているのだ"
        },
        {
          "speaker": "めたん",
          "text": "たった2人で始めた発明が、ここまで来るなんて…"
        },
        {
          "speaker": "ずんだもん",
          "text": "2020年にはIEEEマイルストーンにも認定されたのだ"
        },
        {
          "speaker": "めたん",
          "text": "世界的に認められた日本の発明ですわね"
        }
      ]
    },
    {
      "id": 23,
      "title": "あの模様の正体",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "さて最初の問いに戻るのだ。あの3つの四角は何だったか"
