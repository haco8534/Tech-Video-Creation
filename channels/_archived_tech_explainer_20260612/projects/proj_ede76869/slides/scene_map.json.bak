{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "title": "質問からスタート",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "めたん、今日ちょっと変な質問していいのだ。"
        },
        {
          "speaker": "めたん",
          "text": "いきなり何ですの。どうぞ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "もし明日、世界中のインターネットを止めたい国があったとして、どこに電話すれば止まるのだ？"
        },
        {
          "speaker": "めたん",
          "text": "えっと……Googleとか、そういう大きい会社ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ぼくも最初そう思ったのだ。でも違ったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "Googleじゃないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "Googleは大きいけど、インターネットそのものを持ってるわけじゃないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "じゃあアメリカ政府とか、国連とか？"
        },
        {
          "speaker": "ずんだもん",
          "text": "それも違うのだ。実は「電話先」自体が、どこにも存在しないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "えっ、でも毎日普通に動いてますわよね？"
        },
        {
          "speaker": "ずんだもん",
          "text": "動いてるのだ。でも誰も全体を握ってないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ちょっと不気味ですわよ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "冷静に考えると、これだけ生活に食い込んでるインフラで、社長がいないって変なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "電気も水道も、会社が持ってますもの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "なのにインターネットだけは違うのだ。なぜそうなってるか、順番に解きほぐすのだ。"
        }
      ],
      "id": 0
    },
    {
      "title": "今日話すこと",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "今日はその謎を4つに分けて話すのだ。"
        },
        {
          "speaker": "めたん",
          "text": "4つ、ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "まず「誰が作ったのか」、次に「今は誰が管理してるのか」なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "はい。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それから「物理的にどうつながってるのか」、最後に「じゃあ本当に止められないのか」なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "わたくしの中で「インターネット＝どこかの会社が動かしてる」でふんわり止まってた気がしますの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そこが今日更新されるのだ。順番に見ていくのだ。"
        }
      ],
      "id": 1
    },
    {
      "title": "1969年のUCLA",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "始まりは1969年の10月29日、夜10時半なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ずいぶん具体的な日付ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "UCLAの研究室から、スタンフォードの研究所へ、初めてコンピューター同士のメッセージが送られたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "なんて送ったんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ログインと打とうとして、エルとオーを送った時点で相手のシステムがクラッシュしたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "つまり記念すべき初メッセージが、エル、オーの二文字だけ、ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。このネットワークがARPANETと呼ばれる、インターネットの直接のご先祖なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "アーパネット、初めて聞きましたの。"
        }
      ],
      "id": 2
    },
    {
      "title": "発注者と実装者",
      "lines": [
        {
          "speaker": "めたん",
          "text": "これは誰が作ったんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "発注したのはアメリカのARPA、今のDARPAなのだ。実装したのはBBNという会社なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "アメリカ軍が核戦争に備えて作った、みたいな話を聞いたことがある気がしますの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それ、よく言われるけど実は違うのだ。"
        }
      ],
      "id": 3
    },
    {
      "title": "核戦争説の訂正",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "当時のARPA長官だったCharles Herzfeldさん本人が、はっきり否定してるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "なんて？"
        },
        {
          "speaker": "ずんだもん",
          "text": "「ARPANETは核攻撃に耐えるために始めたものではない」と明言してるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "本人が言ってるなら確かですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "本当の動機は、もっと地味だったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "どんな？"
        },
        {
          "speaker": "ずんだもん",
          "text": "「大型コンピューターが全国に数台しかなくて、遠くの研究者が使えなくて不便」なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "まさかの資源共有ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "核戦争の話は、Paul Baranという別の研究者が1964年にRAND研究所で書いた論文と混ざって伝わったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "別人の別研究ですのね。"
        }
      ],
      "id": 4
    },
    {
      "title": "TCP/IPの発明者",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "で、ARPANETをインターネットに進化させた通信ルールがTCP/IPなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ティーシーピーアイピー、名前は聞きますの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1974年にVint CerfとBob Kahnの二人が原型を発表したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "その二人が「インターネットの父」ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう呼ばれることが多いのだ。仕様として固まったのは1981年、RFC 791と793というドキュメントに書かれてるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "アールエフシー、も名前が出てきますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "インターネットの仕様書の通し番号なのだ。後でまた出てくるのだ。"
        }
      ],
      "id": 5
    },
    {
      "title": "WWWは別の発明",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ところで、Tim Berners-Leeって聞いたことがありますの。あの人は？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ここが大事なのだ。Berners-Leeが1989年にCERN研究所で発明したのは、World Wide Web、つまりWebなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "Webとインターネットは同じじゃないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "違うのだ。インターネットは通信のインフラ、Webはその上で動くアプリのひとつなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "そうなんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "メールもFTPも、Webと並ぶ別のアプリなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "電気と家電、みたいな関係ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "まさにそのイメージなのだ。"
        }
      ],
      "id": 6
    },
    {
      "title": "1995年に政府が手を引いた",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "作ったのはアメリカ政府だったけど、ずっと持ってたわけじゃないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "いつ手放したんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "1995年4月30日、NSFNETという学術バックボーンが退役したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それで？"
        },
        {
          "speaker": "ずんだもん",
          "text": "政府はここで手を引いて、運用は民間のISPに全部渡ったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "じゃあ今は誰が管理してるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "分担してるのだ。名前だけ4つ紹介するのだ、覚えなくていいのだ。"
        }
      ],
      "id": 7
    },
    {
      "title": "ICANNの仕事",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ひとつ目、ICANN。アイキャンと読むのだ。"
        },
        {
          "speaker": "めたん",
          "text": "なにを管理してますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ドメイン名、youtube.comとかの「名前」と、IPアドレスという「番号」の重複を防ぐ調整役なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "インターネットの管理会社、ってこと？"
        },
        {
          "speaker": "ずんだもん",
          "text": "よくそう誤解されるけど違うのだ。ICANNはコンテンツも、ISPも、プロトコルも、ルーティングも管理しないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "管理しないものの方が多いですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "やるのは識別子の調整だけなのだ。それでも結構大変なのだ。"
        }
      ],
      "id": 8
    },
    {
      "title": "IETFの意思決定",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ふたつ目、IETF。通信ルールそのもの、プロトコルの仕様を決める集まりなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "どうやって決めてますの？投票ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ここが面白いのだ。1992年にDavid Clarkという研究者がこう言ったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "なんて？"
        },
        {
          "speaker": "ずんだもん",
          "text": "「我々は王も大統領も投票も拒否する。ラフコンセンサスと動くコードを信じる」なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "かっこよすぎますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "多数決はしないのだ。議論して、だいたい合意できたら、会場の参加者がうなり声で意思表示するのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ハミング、ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。RFC 7282という文書に正式に書かれてるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "本当にそれで決まりますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "決まるのだ。しかも参加はオープンで、会費もいらないのだ。会場の服装はTシャツとサンダルが多いのだ。"
        },
        {
          "speaker": "めたん",
          "text": "国連の会議とは対極ですわね。"
        }
      ],
      "id": 9
    },
    {
      "title": "RIRの地域分散",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "みっつ目、RIR。これはIPアドレスを地域ごとに配る組織なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "世界に何個ありますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "5つなのだ。アジア太平洋、ヨーロッパ、北米、中南米、アフリカで1つずつなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "見事に分散してますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "本社もオーストラリア、オランダ、アメリカ、ウルグアイ、モーリシャスでバラバラなのだ。"
        }
      ],
      "id": 10
    },
    {
      "title": "W3Cとまとめ",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "よっつ目、W3C。Web、つまりHTMLとかCSSの標準を決めてる組織なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "これは誰が作りましたの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "Berners-Leeが1994年に作ったのだ。Webの発明者が作ったWebの標準団体なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "整理しますわ。名前を配る人、通信ルールを決める人、番号を配る人、Webのルールを決める人、が全部別なんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。しかも互いに上下関係がないのだ。横並びの分業なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ピラミッドじゃないんですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通りなのだ。上にCEOはいないのだ。"
        }
      ],
      "id": 11
    },
    {
      "title": "クラウドの実体",
      "lines": [
        {
          "speaker": "めたん",
          "text": "組織の話はわかりましたの。でも結局、線はどこを通ってるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ここが一番意外なのだ。世界中の国際通信の約99パーセントは、海の底のケーブルを通ってるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "えっ、衛星じゃないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "衛星は1パーセント未満なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "想像と全然違いますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "TeleGeographyという会社の2026年のデータで、世界に海底ケーブルは694本あるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "総延長はどのくらいですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "150万キロメートルなのだ。地球から月までの距離の、およそ4倍なのだ。"
        }
      ],
      "id": 12
    },
    {
      "title": "漁船で切れる",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "しかもこのケーブル、年に150回から200回、切れるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "何が切ってますの。サメ？"
        },
        {
          "speaker": "ずんだもん",
          "text": "サメもたまにあるけど、原因の8割は漁船の錨か、底引き網なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "意外とアナログですわね。"
        },
        {
          "speaker": "めたん",
          "text": "切れたらどうしますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "専用のケーブル敷設船が現場に駆けつけて、海底から拾い上げて繋ぎ直すのだ。世界に十数隻しかないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「クラウド」って言葉のイメージから一番遠い現実なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "雲じゃなくて、海底に横たわるガラス繊維ですの。"
        }
      ],
      "id": 13
    },
    {
      "title": "Netflixの配信",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "もう一個意外な話があるのだ。Netflixでドラマを見てる時、データはアメリカから毎回飛んできてるわけじゃないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "じゃあどこから？"
        },
        {
          "speaker": "ずんだもん",
          "text": "近所のISP、日本ならNTTやKDDIのビルの中に、Netflixが設置した専用の箱があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "近所からですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "世界のNetflixトラフィックの約95パーセントは、この仕組みで配信されてるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "名前はありますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "Open Connectというのだ。ISPには無償で提供されてるのだ。"
        }
      ],
      "id": 14
    },
    {
      "title": "物理層も分散",
      "lines": [
        {
          "speaker": "めたん",
          "text": "つまり、ケーブルを持ってる会社も、コンテンツを配る会社もバラバラ、ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。海底ケーブルは各国の通信会社の共同所有が基本なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "最近は？"
        },
        {
          "speaker": "ずんだもん",
          "text": "GoogleやMeta、Microsoft、Amazonも所有側に加わってるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "コンテンツ企業が道まで持つ、ですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Googleだけで世界の海底ケーブルの約8.5パーセントに関与してるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "コンテンツを作る会社が道路まで持ってる時代ですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "CDNという中継網も、CloudflareやAkamaiなど数社で分担してるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "物理の層まで、全部分散してるんですわね。"
        }
      ],
      "id": 15
    },
    {
      "title": "国単位では止まる",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで冒頭の質問に戻るのだ。「インターネットは止められるか」なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ここまで聞くと、止められなさそうですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "半分正解で、半分違うのだ。"
        },
        {
          "speaker": "めたん",
          "text": "どういうことですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "国単位では、実はしょっちゅう止まってるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "えっ、そうなんですの？"
        }
      ],
      "id": 16
    },
    {
      "title": "Access Nowの数字",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "Access Nowという人権団体の集計で、2025年は52か国で313件の遮断が記録されてるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "多いですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "世界人口の半分以上、46億人が何らかの影響を受けたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "けっこうな規模ですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ミャンマー、インド、パキスタン、イランあたりが上位なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "国はどうやって止めてますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "自国のISPに命令すれば止まるのだ。中国はGreat Firewall、ロシアはRuNet、イランはNINという独自の運用もあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "つまり、国の中の扉は国が閉められる、ですのね。"
