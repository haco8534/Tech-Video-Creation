{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "id": 0,
      "title": "VPN広告の謎",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ずんだもん、最近YouTube見てて思うんですけど。"
        },
        {
          "speaker": "ずんだもん",
          "text": "なんなのだ？"
        },
        {
          "speaker": "めたん",
          "text": "VPNの広告、多すぎませんの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "あー、わかるのだ。NordVPNとかSurfsharkとか。"
        },
        {
          "speaker": "めたん",
          "text": "もはや見ない日がないですわ。動画の途中で急に始まるアレですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「この動画のスポンサーは…」ってやつなのだ。"
        }
      ]
    },
    {
      "id": 1,
      "title": "44000本の動画",
      "lines": [
        {
          "speaker": "めたん",
          "text": "正直うんざりですわ。でも一体どれくらい多いんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "NordVPNだけで7,800人以上のYouTuberと契約しているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "7,800人！？"
        },
        {
          "speaker": "ずんだもん",
          "text": "スポンサー動画の本数は4万4千本を超えているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "4万4千本…ちょっと規模がおかしいですわ。"
        }
      ]
    },
    {
      "id": 2,
      "title": "4人に1人がVPN利用",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "しかも世界のネットユーザーの約23%がVPNを使っているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "4人に1人ですの？思ったより多いですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもここで疑問が湧かないのだ？"
        },
        {
          "speaker": "めたん",
          "text": "何がですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "なんでVPN会社はこんなに広告費を出せるのか、ということなのだ。"
        }
      ]
    },
    {
      "id": 3,
      "title": "今日の問い",
      "lines": [
        {
          "speaker": "めたん",
          "text": "確かに…。あれだけのYouTuberにお金を払うって相当ですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "今日はその裏側を全部解剖するのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "お金の仕組みから、VPNが本当に守れるもの、守れないものまでなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "楽しみですわ。わたくし「入れとけば安全」くらいの認識でしたの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その認識が今日で変わるかもしれないのだ。"
        }
      ]
    },
    {
      "id": 4,
      "title": "通信の丸見え問題",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まずVPNが何をしてるか、おさらいするのだ。"
        },
        {
          "speaker": "めたん",
          "text": "お願いしますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ふつうにネットを使うとき、データは中継地点をいくつも通るのだ。"
        },
        {
          "speaker": "めたん",
          "text": "パソコンからサーバーにまっすぐ飛ぶんじゃないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "違うのだ。ルーターやISPの設備を経由していくのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ISPって回線業者のことですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。で、昔の通信は手紙で言うとはがきだったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "はがき？封筒じゃなくて？"
        }
      ]
    },
    {
      "id": 5,
      "title": "はがきと封筒",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "はがきは配達員にも中身が読めてしまうのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "昔のインターネットはそれに近い状態だったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それは確かに怖いですわ…。"
        },
        {
          "speaker": "ずんだもん",
          "text": "VPNがやるのはざっくり二つなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "一つ目は通信の暗号化。はがきを封筒に入れるイメージなのだ。"
        }
      ]
    },
    {
      "id": 6,
      "title": "VPNトンネル",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "二つ目は、VPNサーバーを経由させて送り主を隠すことなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "経由させると何が変わるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "きみのIPアドレスの代わりに、VPNサーバーのアドレスが見えるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "封筒に入れて、代理の住所から出すってことですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。だから相手にはきみの本当の場所がわからなくなるのだ。"
        }
      ]
    },
    {
      "id": 7,
      "title": "HTTPS時代の現実",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ただし、ここで超重要なことを言うのだ。"
        },
        {
          "speaker": "めたん",
          "text": "なんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "実は今、Webサイトの約95%はHTTPSで暗号化されているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "95%！？"
        },
        {
          "speaker": "ずんだもん",
          "text": "Let's Encryptという無料の証明書サービスのおかげなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "つまりVPNがなくても、通信の中身はすでに封筒に入っているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "じゃあVPNの封筒って、封筒の上にさらに封筒を被せるようなものですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "鋭いのだ。まさに二重封筒なのだ。この話は後で詳しくやるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "気になりますわ…。"
        },
        {
          "speaker": "ずんだもん",
          "text": "まずは「なぜこんなに広告を出せるのか」お金の話からいくのだ。"
        }
      ]
    },
    {
      "id": 8,
      "title": "VPN市場500億ドル",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "VPN市場は2023年時点で約500億ドルと言われているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "日本円で7兆円超ですの！？"
        },
        {
          "speaker": "ずんだもん",
          "text": "調査会社によって数字はばらつくのだ。ただ、巨大な産業ではあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "VPNがそんなに大きなビジネスだとは思いませんでしたわ。"
        }
      ]
    },
    {
      "id": 9,
      "title": "SaaSの利益構造",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "しかもVPNビジネスは利益率がとんでもなく高いのだ。"
        },
        {
          "speaker": "めたん",
          "text": "どれくらいですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ソフトウェアだから物理的な製品を作らなくていいのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "サーバー代はかかるけど、ユーザーが増えても追加コストは小さいのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あ、クラウドサービスと同じ構造ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "業界では粗利益率70%から90%超とも言われているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "売上のほとんどが利益になるんですのね…。"
        }
      ]
    },
    {
      "id": 10,
      "title": "アフィリエイト報酬",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "だから広告に莫大なお金をかけられるのだ。具体的に見るのだ。"
        },
        {
          "speaker": "めたん",
          "text": "どれくらい払ってるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "NordVPNの場合、月間プランの売上100%をアフィリエイターに渡すのだ。"
        },
        {
          "speaker": "めたん",
          "text": "100%！？初月は丸々赤字ですわよね？"
        },
        {
          "speaker": "ずんだもん",
          "text": "初月だけ見ればそうなのだ。でもサブスクだから2ヶ月目以降は丸儲けなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あっ…そういうことですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "年間プランでも40%、更新時にも30%を払い続けるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "更新のたびにも払うんですの？太っ腹ですわね…。"
        }
      ]
    },
    {
      "id": 11,
      "title": "LTVの仕組み",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここが核心なのだ。1人のユーザーが2年3年と契約を続けるとするのだ。"
        },
        {
          "speaker": "めたん",
          "text": "はい。"
        },
        {
          "speaker": "ずんだもん",
          "text": "初月に100%払っても、生涯で見れば余裕で回収できるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "この「顧客が生涯で払う合計額」をLTVと言うのだ。顧客生涯価値なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "だからYouTuberにとっても美味しいんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "数十秒のスポンサー読みで高い報酬が入るのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "VPN会社もLTVで回収できるからどんどん広告費を積めるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "お互いにメリットがあるから止まらない…ですわね。"
        }
      ]
    },
    {
      "id": 12,
      "title": "恐怖マーケティング",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "さらにVPN広告には「売りやすさ」もあるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "売りやすさ？"
        },
        {
          "speaker": "ずんだもん",
          "text": "「ハッカーがあなたを狙っている」。こう言われたら不安になるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "確かに…怖いですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "恐怖と簡単な解決策。この組み合わせは広告としてとても強いのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「怖いならVPN入れればOK」。30秒で伝わる価値提案なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "シンプルで刺さるメッセージですわね…。"
        },
        {
          "speaker": "ずんだもん",
          "text": "メリーランド大学の研究チームがYouTubeのVPN広告を分析しているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "243本の広告動画、合計6,300万回再生分を調べたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "6,300万回分…すごい規模の調査ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "結果、多くが「絶対的な安全保証」や誤った技術的主張をしていたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "学術的に検証されてるんですのね…。"
        },
        {
          "speaker": "ずんだもん",
          "text": "つまりVPN広告の「多さ」は偶然じゃないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "高い利益率、高いアフィリエイト報酬、売りやすい恐怖訴求なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "この三つが揃ってるから、あれだけの広告が成り立つのだ。"
        },
        {
          "speaker": "めたん",
          "text": "儲かる仕組みが完成してるから止まらないんですわね…。"
        }
      ]
    },
    {
      "id": 13,
      "title": "広告を検証する",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "さて、ここからが今日のいちばん大事な話なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "VPN広告の主張を検証するんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "まず「公衆Wi-Fiは危険だからVPNを」という主張なのだ。"
        }
      ]
    },
    {
      "id": 14,
      "title": "ASA行政指導",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "2019年にイギリスの広告基準局がNordVPNに行政指導を出したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "え、公式に注意されてるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "「公衆Wi-Fiは危険」という主張の根拠が不十分と判断されたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "でも…昔は実際に危なかったんですわよね？"
        },
        {
          "speaker": "ずんだもん",
          "text": "昔と今では状況がまったく違うのだ。"
        }
      ]
    },
    {
      "id": 15,
      "title": "HTTPS普及率95%",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "今はWebトラフィックの約95%がHTTPS暗号化済みなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "もう「封筒」に入ってる状態ですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "カフェのWi-Fiでも、通信の中身を覗くのは遥かに難しくなったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "じゃあ「Wi-Fiが危ない」って話は時代遅れなんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "完全に嘘とは言えないけれど、リスクはかなり限定的なのだ。"
        }
      ]
    },
    {
      "id": 16,
      "title": "VPNが防げないもの",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "でもそれよりもっと大きな問題があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "もっと大きな問題？"
        },
        {
          "speaker": "ずんだもん",
          "text": "VPNが防げないものが山ほどあるということなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "たとえば？"
        },
        {
          "speaker": "ずんだもん",
          "text": "まずフィッシング詐欺。偽サイトにパスワードを入力しちゃうやつなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それはVPNでは止められないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "止められないのだ。VPNは通信経路を暗号化するだけなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "偽サイトを見分ける機能は持っていないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "マルウェアは？"
        },
        {
          "speaker": "ずんだもん",
          "text": "防げないのだ。ウイルス入りファイルを開いたらVPN関係ないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "Cookieによる追跡は？"
        },
        {
          "speaker": "ずんだもん",
          "text": "VPNはIPを隠すけど、ブラウザのCookieは別問題なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "サイトをまたいでCookieで追跡されるのはVPNでは防げないのだ。"
        }
      ]
    },
    {
      "id": 17,
      "title": "フィンガープリント",
      "lines": [
        {
          "speaker": "めたん",
          "text": "じゃあ広告追跡はどうですの？「VPNで追跡を防ごう」ってよく聞きますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ここが一番誤解されているポイントなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ブラウザフィンガープリントという技術があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "フィンガープリント？指紋ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "画面の解像度、フォント、ブラウザの設定を組み合わせるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "これでIPに関係なく90%のユーザーを特定できるという研究があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "VPNでIPを隠しても別の方法で追跡される…ですの？"
        }
      ]
    },
    {
      "id": 18,
      "title": "ログインした瞬間",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "その通りなのだ。さらに言えばGoogleにログインした時点で全部バレるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あ…確かに。ログインしたら誰かわかりますわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Consumer Reportsという米国の消費者団体は明言しているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「広告追跡への対策としてVPNは無力」と。"
        },
        {
          "speaker": "めたん",
          "text": "VPNへのイメージがかなり変わってきましたわ…。"
        },
        {
          "speaker": "ずんだもん",
          "text": "VPN広告は「守ってくれるもの」を強調するけど…"
        },
        {
          "speaker": "ずんだもん",
          "text": "「守れないもの」については一切触れないのだ。そこが問題なのだ。"
        }
      ]
    },
    {
      "id": 19,
      "title": "業界の寡占構造",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここからはVPN業界の闇深い部分に踏み込むのだ。"
        },
        {
          "speaker": "めたん",
          "text": "闇…ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "一見たくさんあるVPNブランド、実は少数の会社が持っているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "どういうことですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "NordVPN、Surfshark、Atlas VPN。この3つは全部同じ会社なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "え！？全然別のサービスだと思ってましたわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2022年に合併してNord Security傘下になったのだ。"
        }
