{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "id": 0,
      "title": "プログラミングの正体",
      "lines": [
        {
          "speaker": "めたん",
          "text": "今日のテーマは「プログラミングとは結局何をしているのか」ですわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "めたん、映画のプログラマーってどんなイメージなのだ？"
        },
        {
          "speaker": "めたん",
          "text": "暗い部屋で緑の文字が流れて、猛スピードでタイピングしてますわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "かっこいいよね。ぼくもあれに憧れた時期があったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもね、現実のプログラマーの日常は全然違うのだ"
        }
      ]
    },
    {
      "id": 1,
      "title": "たった16%",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "IDCの2024年レポートによるとね"
        },
        {
          "speaker": "ずんだもん",
          "text": "プログラマーがコードを書いてる時間は、業務全体の16%しかないのだ"
        },
        {
          "speaker": "めたん",
          "text": "16%！？ 8時間働いて1時間ちょっとしかコード書いてないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。残り84%は設計、テスト、打ち合わせ、バグ修正なんかなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかもケンブリッジ大学の研究では、コードを書いてる時間の半分近くはバグ探しなのだ"
        },
        {
          "speaker": "めたん",
          "text": "え…じゃあ純粋に新しいコードを生み出してるのって…"
        },
        {
          "speaker": "ずんだもん",
          "text": "全体の8%くらいしかないのだ"
        }
      ]
    },
    {
      "id": 2,
      "title": "92%の謎",
      "lines": [
        {
          "speaker": "めたん",
          "text": "8%…！ じゃあ残りの92%で一体何をしてるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "それが今日の核心なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "先に答えを言ってしまうとね、「考えること」なのだ"
        },
        {
          "speaker": "めたん",
          "text": "考えること…？ ちょっと漠然としてますわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "だよね。だから今日は言葉で説明するだけじゃなくて"
        },
        {
          "speaker": "ずんだもん",
          "text": "めたんに実際に「プログラミング的な体験」をしてもらうのだ"
        },
        {
          "speaker": "めたん",
          "text": "わたくしがですの？ コードなんて書いたことないですわよ"
        },
        {
          "speaker": "ずんだもん",
          "text": "大丈夫なのだ。コードは一切使わないから安心してほしいのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "まずは最初の実験からいくのだ"
        }
      ]
    },
    {
      "id": 3,
      "title": "靴ひもの結び方",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "めたん、靴ひもって結べるよね？"
        },
        {
          "speaker": "めたん",
          "text": "毎朝やってますわ。何を今さら"
        },
        {
          "speaker": "ずんだもん",
          "text": "じゃあ質問なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "靴ひもの結び方を「文章だけ」で説明できるのだ？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ただし相手は、靴を見たことがない宇宙人だと思ってほしいのだ"
        },
        {
          "speaker": "めたん",
          "text": "宇宙人…？ えっと、まず「2本のひもを持ちます」ですわね"
        }
      ]
    },
    {
      "id": 4,
      "title": "宇宙人への説明",
      "lines": [
        {
          "speaker": "めたん",
          "text": "「持ったら交差させて、片方をくぐらせて…」"
        },
        {
          "speaker": "ずんだもん",
          "text": "はい。「交差させて」ってどういう動作なのだ？"
        },
        {
          "speaker": "めたん",
          "text": "右のひもを左のひもの上に重ねて…"
        },
        {
          "speaker": "ずんだもん",
          "text": "「上」って重力方向の反対？ それとも体から遠い方？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そもそも「右」ってどっちの右なのだ？ 自分から見て？ 靴から見て？"
        },
        {
          "speaker": "めたん",
          "text": "うっ…これ、思ったより全然難しいですわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でしょ？ ぼくらは体が覚えてるから無意識にやれるけど"
        },
        {
          "speaker": "ずんだもん",
          "text": "言葉で正確に伝えようとすると、途端に大変になるのだ"
        }
      ]
    },
    {
      "id": 5,
      "title": "サンドイッチの罠",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "実はこれ、コンピュータサイエンスの授業で本当にやる演習なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "有名なのは「サンドイッチを作る手順を書け」っていうやつなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "学生が「パンにジャムを塗る」って書くとね"
        },
        {
          "speaker": "ずんだもん",
          "text": "先生はパンの袋を開けずに、袋の上からジャムを塗り始めるのだ"
        },
        {
          "speaker": "めたん",
          "text": "意地悪ですわ！ でも確かに「袋を開ける」なんて書いてないですわね…"
        },
        {
          "speaker": "ずんだもん",
          "text": "「ナイフでジャムをすくう」って書いた学生にはね"
        },
        {
          "speaker": "ずんだもん",
          "text": "先生はジャムの瓶のフタを開けずにナイフを突き立てたりするのだ"
        },
        {
          "speaker": "めたん",
          "text": "ああ…フタを開ける手順も書いてないから…"
        }
      ]
    },
    {
      "id": 6,
      "title": "暗黙知の発見",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ぼくらは「当然やるでしょ」っていう前提を山ほど省略して生きてるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "これを専門用語で「暗黙知」っていうのだ"
        },
        {
          "speaker": "めたん",
          "text": "言われてみると…わたくしも新人さんに仕事教えるとき苦労しましたわ"
        },
        {
          "speaker": "めたん",
          "text": "「これ適当にまとめといて」が全然通じなくて…"
        },
        {
          "speaker": "ずんだもん",
          "text": "あるあるなのだ。「適当に」の中身が共有されてないんだよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "その苦労の根っこが、実はプログラミングとまったく同じなのだ"
        }
      ]
    },
    {
      "id": 7,
      "title": "世界最速の新人",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ただし決定的に違うことがあるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "人間の新人さんは「適当に」でもなんとなく察してくれるよね"
        },
        {
          "speaker": "めたん",
          "text": "まあ、空気を読んでくれますわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "コンピュータは一切察してくれないのだ。一切、なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "計算速度は1秒間に何十億回。人間とは比べものにならないのだ"
        },
        {
          "speaker": "めたん",
          "text": "それは知ってますわ。だからすごいんでしょう？"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもね、指示されていないことは本当にゼロ。何一つやらないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「いい感じにして」→エラー。「だいたい右」→エラーなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "曖昧さが1ミリでもあると、完全に止まるのだ"
        },
        {
          "speaker": "めたん",
          "text": "超高速なのに融通がまるできかない…不思議な存在ですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "ぼくは「世界最速の新人」って呼んでるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "指示通りなら光速で動く。でも指示がなければ微動だにしない"
        },
        {
          "speaker": "ずんだもん",
          "text": "この新人に仕事させるのがプログラミング。…って思うでしょ？"
        },
        {
          "speaker": "めたん",
          "text": "違うんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "80%は合ってるのだ。でも残り20%がめちゃくちゃ大事なのだ"
        }
      ]
    },
    {
      "id": 8,
      "title": "自販機を設計しよう",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "さて、ここからが本番なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "この「世界最速の新人」に仕事をさせる体験をしてもらうのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "めたん、自動販売機を想像してほしいのだ"
        },
        {
          "speaker": "めたん",
          "text": "毎日使ってますわ。お金入れてボタン押すだけですわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "うん、単純に見えるよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "じゃあ、その「動き方」を全部書き出してみるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "まず、お金が入ったら何をする？"
        }
      ]
    },
    {
      "id": 9,
      "title": "分岐の発見",
      "lines": [
        {
          "speaker": "めたん",
          "text": "金額を確認して、買える商品のボタンを光らせますわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "うん。じゃあ100円入れて120円のボタンを押されたら？"
        },
        {
          "speaker": "めたん",
          "text": "「お金が足りません」と表示して…あっ、ボタンは光らせないようにしないと"
        },
        {
          "speaker": "ずんだもん",
          "text": "いいね。じゃあ130円入れて120円の商品を買ったら？"
        },
        {
          "speaker": "めたん",
          "text": "おつり10円を返す。でも…10円玉の在庫がなかったらどうするんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "おお、いいところに気づくね"
        }
      ]
    },
    {
      "id": 10,
      "title": "想定外の連鎖",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "もっといくよ。ボタンを2つ同時に押されたら？"
        },
        {
          "speaker": "めたん",
          "text": "先に押した方を優先…いや「同時」の場合は…？"
        },
        {
          "speaker": "ずんだもん",
          "text": "売り切れのボタンを連打されたら？ 千円札がぐしゃぐしゃだったら？"
        },
        {
          "speaker": "ずんだもん",
          "text": "お金を入れて何も買わず10分放置されたら？"
        },
        {
          "speaker": "ずんだもん",
          "text": "真夏に冷却が追いつかなくなったら？ 停電したらお金はどうなる？"
        },
        {
          "speaker": "めたん",
          "text": "ちょっと待ってくださいませ…きりがないですわ！"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう、きりがないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ぼくらが「単純だ」と思ってるものの裏には、膨大な分岐が隠れてるのだ"
        },
        {
          "speaker": "めたん",
          "text": "自販機ですらこれだけあるんですもの…"
        },
        {
          "speaker": "めたん",
          "text": "LINEとかYouTubeみたいなアプリだと、もう想像もつかないですわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "実際、大規模なアプリだと分岐の数は数万〜数十万になるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかも分岐同士が絡み合うから、組み合わせはさらに爆発するのだ"
        },
        {
          "speaker": "めたん",
          "text": "それを全部一人で考えるんですの…？"
        },
        {
          "speaker": "ずんだもん",
          "text": "一人じゃ無理なのだ。だからチームで分担するのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもそのためには、まず問題を「分担できる形」にしないといけないのだ"
        }
      ]
    },
    {
      "id": 11,
      "title": "分解という武器",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。でもここで、めたんが自然にやってたことに気づいてほしいのだ"
        },
        {
          "speaker": "めたん",
          "text": "自然にやってたこと…？"
        },
        {
          "speaker": "ずんだもん",
          "text": "めたんは「自販機」っていう大きな塊を、自然と分けてたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「お金の処理」「ボタンの処理」「おつり」「エラー対応」ってね"
        },
        {
          "speaker": "めたん",
          "text": "あっ…確かに、無意識にグループ分けしてましたわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "これが「分解」なのだ。プログラミングの最も根っこにある考え方なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "大きな問題をそのまま解こうとすると頭がパンクするのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから扱える大きさの小さな問題に分けていくのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "コードを書く前にプログラマーが一番時間を使う作業が、まさにこれなのだ"
        },
        {
          "speaker": "めたん",
          "text": "あっ…じゃあ、さっきの「92%の正体」って…"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう、ほとんどがこの「分解して整理する」作業なのだ"
        }
      ]
    },
    {
      "id": 12,
      "title": "4つの思考法",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "実はこの「分解」を含めて、体系的に整理した人がいるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "2006年にカーネギーメロン大学のジャネット・ウィングさんが提唱した概念なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「計算論的思考」、英語だとComputational Thinkingなのだ"
        },
        {
          "speaker": "めたん",
          "text": "計算論的思考…？ なんだか難しそうですわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "名前は堅いけど、さっき自販機でめたんが全部やってたことなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "4つの要素があるのだ。1つ目が、さっき体験した「分解」"
        }
      ]
    },
    {
      "id": 13,
      "title": "自販機で4つを体験",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "2つ目は「パターン認識」なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "さっきの自販機で「お金が足りない」と「売り切れ」ってどちらも…"
        },
        {
          "speaker": "めたん",
          "text": "あっ、「エラーを表示してお金を返す」で、やることが似てますわ！"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう！ 似た処理を見つけてまとめるのがパターン認識なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "3つ目は「抽象化」。細かすぎる部分を隠して本質だけ残すこと"
        },
        {
          "speaker": "ずんだもん",
          "text": "自販機の「お金の処理」を使うとき、中のコイン選別の仕組みは知らなくていいよね"
        },
        {
          "speaker": "めたん",
          "text": "確かに、使う側はブラックボックスで十分ですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "そして4つ目が「アルゴリズム設計」なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "手順を正しい順番に組み立てること。お金確認→ボタン受付→商品排出→おつり、ってね"
        }
      ]
    },
    {
      "id": 14,
      "title": "コード不要の発見",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここでめたんに気づいてほしいことがあるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "この4つの話、コードって一行も出てきてないよね？"
        },
        {
          "speaker": "めたん",
          "text": "あっ…本当ですわ。全部「考え方」の話ですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。プログラミングの本質は言語じゃなくて思考法なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "コンピュータ科学の巨人たちも同じことを言ってるのだ"
        }
      ]
    },
    {
      "id": 15,
      "title": "巨人の言葉",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "Dijkstraは「プログラミングの技術とは、複雑さを整理する技術だ」と言ったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "Knuthは「何をさせたいかを別の人間に伝える技術」と言ったのだ"
        },
        {
          "speaker": "めたん",
          "text": "別の人間に…？ コンピュータにじゃなくて？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。コードを読むのはコンピュータだけじゃないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "半年後の自分や、一緒に働く仲間も読むのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "だからコードは「自分の考えを他人に伝える手紙」に近いのだ"
        },
        {
          "speaker": "めたん",
          "text": "ああ…だから92%の時間が「考えること」に使われてたんですわね"
        }
      ]
    },
    {
      "id": 16,
      "title": "92%の内訳",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "最初の「92%の正体」をまとめようなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "設計は「何をどう分解するか考える」こと"
        },
        {
          "speaker": "ずんだもん",
          "text": "テストは「分解が正しかったか確かめる」こと"
        },
        {
          "speaker": "ずんだもん",
          "text": "打ち合わせやドキュメントは「自分の分解を他の人に伝える」こと"
        },
        {
          "speaker": "ずんだもん",
          "text": "バグ修正は「分解の抜け漏れを見つけて直す」こと"
        },
        {
          "speaker": "めたん",
          "text": "全部「考えて整理する」仕事ですわね…"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。コードは、考え抜いた結果を記録する手段にすぎないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "そしてね、この「整理する」っていう営みには、すごく面白い歴史があるのだ"
        }
      ]
    },
    {
      "id": 17,
      "title": "0と1の時代",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "1940年代の話から始めるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "最初のコンピュータでは、0と1の列を手で書いて命令を出してたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「2つの数を足す」だけで何十桁もの0と1を正確に並べる必要があったのだ"
        },
        {
          "speaker": "めたん",
          "text": "それは…気が遠くなりますわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかも1桁でも間違えたらプログラム全体が動かなくなるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "当然みんな思ったのだ。「もっと楽にならないのか」って"
        }
      ]
    },
    {
      "id": 18,
      "title": "抽象化の階段",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そこでまずアセンブリ言語が生まれたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "0と1の代わりにADDとかMOVとか、人間が読める名前をつけたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "それでも大変だったから、1954年にFORTRANっていう言語が登場したのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "数式に近い書き方でプログラムが書けるようになったのだ"
        },
        {
          "speaker": "めたん",
          "text": "どんどん人間にとってわかりやすくなっていったんですわね"
        }
      ]
    },
    {
      "id": 19,
      "title": "構造化の発明",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "面白いのはFORTRANが生まれた理由なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "プログラマーの人件費が、コンピュータ本体の値段を超え始めたからなのだ"
        },
        {
          "speaker": "めたん",
          "text": "機械より人間の方がコストがかかるようになった…！"
        },
        {
          "speaker": "ずんだもん",
          "text": "「人間が楽をするために」言語は進化してきたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "そして1968年、Dijkstraが「構造化プログラミング」を提唱したのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "それまではプログラムの中を自由にあちこち飛び回れたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもそれだと、大きなプログラムがスパゲッティみたいにぐちゃぐちゃになるのだ"
        },
        {
          "speaker": "めたん",
          "text": "自由すぎると逆に混乱するんですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから「順番」「条件分岐」「繰り返し」の3つに整理したのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "自由を制限したら、逆に人間が理解できるプログラムが書けるようになったのだ"
        }
      ]
    },
    {
      "id": 20,
      "title": "Linux4000万行",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "この整理のおかげで、人類はとんでもなく大きなものを作れるようになったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "Linuxっていうサーバー用OSは、1991年にたった1万行で始まったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "それが今では4,000万行を超えてるのだ"
        },
        {
          "speaker": "めたん",
          "text": "4,000万行…！？ 文庫本だと何冊分になりますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "約500冊分なのだ"
        },
        {
          "speaker": "めたん",
          "text": "一人で読むだけでも一生かかりますわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから「抽象化」で全体を知らなくても、自分の担当だけ触れるようにしてるのだ"
        },
        {
          "speaker": "めたん",
          "text": "あっ…さっきの計算論的思考の「抽象化」がここで活きてるんですわね！"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。0と1の時代から80年以上、人類はずっと同じことをやってきたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「人間がもっと楽に考えられるように」整理する。その繰り返しなのだ"
        }
      ]
    },
    {
      "id": 21,
      "title": "認識の変化",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ここまで来ると、最初の疑問に答えが出た気がしますわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "うん。「プログラミングとは結局何をしているのか」"
        },
        {
          "speaker": "ずんだもん",
          "text": "答えは「複雑なものを分解して、誰でも再現できる手順に整理すること」なのだ"
        },
        {
          "speaker": "めたん",
          "text": "そしてコードを打つのは、その整理した結果を記録するだけ…"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。だからプログラマーの仕事時間の92%が「考えること」だったのだ"
        }
      ]
    },
    {
      "id": 22,
      "title": "3つの誤解",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "この動画の前と後で、認識がどう変わったか確認してみようなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "まず「プログラミング＝コードを打つこと」"
        },
        {
          "speaker": "ずんだもん",
          "text": "これは全体の8%にすぎなかったのだ。本質は「考えて整理すること」"
        },
        {
          "speaker": "ずんだもん",
          "text": "次に「コンピュータは賢い」"
        },
        {
          "speaker": "ずんだもん",
          "text": "超高速だけど一切察しない「世界最速の新人」だったのだ"
        },
        {
          "speaker": "めたん",
          "text": "そして「プログラミングは特別な人だけの技術」"
        },
        {
          "speaker": "めたん",
          "text": "これも違いましたわよね。靴ひもの説明も自販機の設計も、わたくしにもできましたもの"
        }
      ]
    },
    {
      "id": 23,
      "title": "日常の中の整理",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "仕事の引き継ぎ書を作る。友達に道を教える。料理のレシピを書く"
        },
        {
          "speaker": "ずんだもん",
          "text": "全部「頭の中の曖昧な知識を、相手が再現できるように整理する」行為なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "プログラミングは、その相手がコンピュータになっただけなのだ"
        },
        {
          "speaker": "めたん",
          "text": "思ってたよりずっと身近なものだったんですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから第一歩はコードを覚えることじゃないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「これってどういう手順で動いてるんだろう」って考える習慣をつけることなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "自販機を使うとき、エレベーターに乗るとき、信号が変わるとき"
        },
        {
          "speaker": "ずんだもん",
          "text": "裏側の仕組みを想像してみる。それだけで、もう第一歩なのだ"
        },
        {
          "speaker": "めたん",
          "text": "プログラミングって「コンピュータの話」だと思ってたけど、実は人間の話でしたのね"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。興味が湧いたら、ぜひ実際に触ってみてほしいのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "それじゃあ今日はここまでなのだ。また次回会おうなのだ"
        },
        {
          "speaker": "めたん",
          "text": "ご視聴ありがとうございましたですわ！"
        }
