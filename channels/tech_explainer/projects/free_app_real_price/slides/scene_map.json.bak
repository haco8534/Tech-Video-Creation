{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "id": 0,
      "title": "無料アプリの本当の値段",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "「タダより高いものはない」なのだ"
        },
        {
          "speaker": "めたん",
          "text": "昔からよく聞くことわざですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "今日はこのことわざを、データと研究で科学的に検証するのだ"
        },
        {
          "speaker": "めたん",
          "text": "ことわざを科学的に？面白そうですわ"
        }
      ]
    },
    {
      "id": 1,
      "title": "97%が無料",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まず、めたんに質問なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "スマホのアプリストアにあるアプリ、何%くらいが無料だと思う？"
        },
        {
          "speaker": "めたん",
          "text": "うーん…半分くらいですの？6割？"
        },
        {
          "speaker": "ずんだもん",
          "text": "Statistaのデータだと、Google Playで97%なのだ"
        },
        {
          "speaker": "めたん",
          "text": "97%！？ほぼ全部じゃないですの"
        },
        {
          "speaker": "ずんだもん",
          "text": "App Storeでも約95%が無料なのだ"
        },
        {
          "speaker": "めたん",
          "text": "有料アプリってほんの一握りなんですわね…"
        }
      ]
    },
    {
      "id": 2,
      "title": "98%の収益構造",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここからが面白いところなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "じゃあ無料ばっかりで開発者はどうやって食べていくのか"
        },
        {
          "speaker": "めたん",
          "text": "そうですわよね、ボランティアじゃないんですし"
        },
        {
          "speaker": "ずんだもん",
          "text": "実はアプリ収益全体の98%が、無料アプリから生まれているのだ"
        },
        {
          "speaker": "めたん",
          "text": "え？無料なのに収益の98%？矛盾してませんの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "矛盾してないのだ。つまり「無料」は慈善事業じゃなくて"
        },
        {
          "speaker": "ずんだもん",
          "text": "実は最も稼げるビジネスモデルなのだ"
        },
        {
          "speaker": "めたん",
          "text": "…ということは、わたくしたちは気づかないうちに何かで「支払って」いる？"
        },
        {
          "speaker": "ずんだもん",
          "text": "その「何か」を一緒に確かめていこう"
        }
      ]
    },
    {
      "id": 3,
      "title": "もし全部有料だったら",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "じゃあ思考実験をするのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "明日から、Google検索もLINEもInstagramも全部有料になったとする"
        },
        {
          "speaker": "めたん",
          "text": "…想像しただけでゾッとしますわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "月いくらなら払う？"
        },
        {
          "speaker": "めたん",
          "text": "LINEは…まあ300円くらい？検索は500円？Instagramは…"
        },
        {
          "speaker": "めたん",
          "text": "YouTube、Googleマップ、Gmail…全部合わせたら月5,000円超えそうですわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "面白いのが、一つひとつは「まあ払えるか」くらいの額なんだよね"
        },
        {
          "speaker": "めたん",
          "text": "でも積み重なると結構な額ですわね"
        }
      ]
    },
    {
      "id": 4,
      "title": "年間700ドルの請求書",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ある推計では、アメリカのユーザーは"
        },
        {
          "speaker": "ずんだもん",
          "text": "GoogleとMetaの2社だけで年間700ドル以上のデータ価値を提供しているのだ"
        },
        {
          "speaker": "めたん",
          "text": "700ドル！？日本円にしたら10万円以上ですの！？"
        },
        {
          "speaker": "ずんだもん",
          "text": "内訳はGoogleに約460ドル、Metaに約217ドルくらいなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ただしこの数字はProtonの推計で、算出方法によって変わるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "大事なのは金額の正確さよりも、「ゼロではない」ということなのだ"
        },
        {
          "speaker": "めたん",
          "text": "「無料」と思ってたサービスに、10万円分の何かを渡していると…"
        }
      ]
    },
    {
      "id": 5,
      "title": "3つの通貨",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで整理するのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ぼくたちが無意識に支払っている「通貨」は大きく3種類あるのだ"
        },
        {
          "speaker": "めたん",
          "text": "通貨？お金以外の？"
        },
        {
          "speaker": "ずんだもん",
          "text": "1つ目は「データ」なのだ。検索履歴、位置情報、誰と繋がっているか"
        },
        {
          "speaker": "ずんだもん",
          "text": "アプリの利用パターン、購買履歴、こういったものがまるごと通貨になるのだ"
        },
        {
          "speaker": "めたん",
          "text": "日常のすべてが記録されてるようなものですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "2つ目は「注意力」なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "世界平均で1日約4時間半、Z世代は9時間以上スマホを見ているのだ"
        },
        {
          "speaker": "めたん",
          "text": "4時間半…確かにわたくしも気づいたら夜ですわ。あるあるですわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "この時間と集中力を広告の「在庫」として売っているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "3つ目が「行動変容」なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "広告を見た結果、買い物の選択や意思決定が無意識に変わること"
        },
        {
          "speaker": "めたん",
          "text": "つまりお金の代わりに、データと注意力と行動で支払っている…"
        },
        {
          "speaker": "ずんだもん",
          "text": "この3つの「見えない請求書」を、今日は1枚ずつ読み解いていくのだ"
        }
      ]
    },
    {
      "id": 6,
      "title": "広告モデルの常識",
      "lines": [
        {
          "speaker": "めたん",
          "text": "でも正直、「広告で稼いでる」こと自体は知ってましたわ"
        },
        {
          "speaker": "めたん",
          "text": "動画の前に広告が出たり、バナーが表示されたり"
        },
        {
          "speaker": "ずんだもん",
          "text": "うん。その理解は入り口としては間違っていないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもね、その広告がどうやって「あなた」に届くのかを知ると景色が一変するのだ"
        },
        {
          "speaker": "めたん",
          "text": "わたくし「に」？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。昔は「このサイトに広告を出す」だったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "今は「この人に広告を出す」に変わっているのだ"
        }
      ]
    },
    {
      "id": 7,
      "title": "広告市場1兆ドル",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まず規模感を押さえておくのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "2025年、世界の広告支出が史上初めて1兆ドルを超えたのだ"
        },
        {
          "speaker": "めたん",
          "text": "1兆ドル…日本円で150兆円くらいですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかもGoogle単体で広告収益2,000億ドル、Metaが1,421億ドルなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "この2社にAmazonを足した3社で、世界の広告費の55%を占めているのだ"
        },
        {
          "speaker": "めたん",
          "text": "3社で過半数…すごい集中度ですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "この巨額のお金が動く仕組みが、実はものすごく速いのだ"
        }
      ]
    },
    {
      "id": 8,
      "title": "RTBの仕組み",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "めたんがニュースアプリを開いた瞬間を想像してほしいのだ"
        },
        {
          "speaker": "めたん",
          "text": "はい、朝のニュースチェック、毎日やってますわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "その瞬間、めたんのデバイス情報、位置情報、閲覧履歴、年齢層の推定"
        },
        {
          "speaker": "ずんだもん",
          "text": "こういったデータがまとめて広告取引所に送信されるのだ"
        },
        {
          "speaker": "めたん",
          "text": "取引所？株式市場みたいなものですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "まさにそのイメージなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "そこで広告主たちがリアルタイムで入札するのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「この人の画面にうちの広告を出したい」ってね"
        },
        {
          "speaker": "めたん",
          "text": "わたくしの情報に広告主が値段をつけてるってことですの…？"
        }
      ]
    },
    {
      "id": 9,
      "title": "40ミリ秒の世界",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "しかもこのオークション、40ミリ秒から120ミリ秒で完了するのだ"
        },
        {
          "speaker": "めたん",
          "text": "40ミリ秒って…まばたき1回の10分の1くらいですわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通りなのだ。めたんがページを読み始める前に、もう競売は終わっているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "デジタルディスプレイ広告の90%以上がこの仕組みで配信されているのだ"
        },
        {
          "speaker": "めたん",
          "text": "わたくし、広告って「このサイトに出す」って決めてるだけだと思ってましたわ…"
        }
      ]
    },
    {
      "id": 10,
      "title": "1994年vs現在",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "1994年に世界初のバナー広告がWebに登場した時は、まさにそうだったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "AT&Tの広告で、クリック率44%という今では考えられない数字だったのだ"
        },
        {
          "speaker": "めたん",
          "text": "44%！？今だと1%でも良い方ですわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "当時は「このサイトの読者に出す」広告だった"
        },
        {
          "speaker": "ずんだもん",
          "text": "今は「この特定の人物のこの瞬間に出す」広告なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "30年かけて、広告は場所からヒトに変わったのだ"
        },
        {
          "speaker": "めたん",
          "text": "…ということは、わたくしは「広告を見せられている」のではなく"
        },
        {
          "speaker": "めたん",
          "text": "「行動データを0.1秒で競売にかけられている」んですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。それが「広告で稼いでる」の、80%の先にある景色なのだ"
        }
      ]
    },
    {
      "id": 11,
      "title": "Simonの予言",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで50年以上前の予言を紹介したいのだ"
        },
        {
          "speaker": "めたん",
          "text": "予言？"
        },
        {
          "speaker": "ずんだもん",
          "text": "1971年、ノーベル経済学賞のハーバート・サイモンがこう言ったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「情報の豊富さは、注意の貧困を生み出す」"
        },
        {
          "speaker": "めたん",
          "text": "情報が増えるほど注意力が足りなくなる…インターネットもない時代に"
        },
        {
          "speaker": "ずんだもん",
          "text": "これが「アテンションエコノミー」という概念の始まりなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "情報はタダ同然に溢れる時代になった。だから希少なのは注意力なのだ"
        },
        {
          "speaker": "めたん",
          "text": "希少なものに値段がつく…経済学の基本ですわね"
        }
      ]
    },
    {
      "id": 12,
      "title": "原材料としてのユーザー",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここでよく聞く表現を一つ修正したいのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「無料サービスでは、あなたが商品だ」って言うよね"
        },
        {
          "speaker": "めたん",
          "text": "ありますわ。SNSの話でよく出る定番フレーズですわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "ハーバード大学のショシャナ・ズボフ教授は、もっと踏み込んだ見方をしているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ぼくたちは「商品」じゃなくて「原材料」なのだ"
        },
        {
          "speaker": "めたん",
          "text": "原材料？商品よりもっと手前ってこと？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。ぼくたちの行動データは「無料の原材料」として一方的に回収されて"
        },
        {
          "speaker": "ずんだもん",
          "text": "「この人は次に何をするか」という行動予測に加工されて"
        },
        {
          "speaker": "ずんだもん",
          "text": "その予測が広告主に販売されるのだ"
        },
        {
          "speaker": "めたん",
          "text": "原材料を仕入れて、製品に加工して売る…完全に工場ですわね"
        }
      ]
    },
    {
      "id": 13,
      "title": "監視資本主義",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ズボフ教授はこの構造を「監視資本主義」と名づけたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "原材料がぼくたちの体験、加工ラインが行動分析アルゴリズム"
        },
        {
          "speaker": "ずんだもん",
          "text": "完成品が「行動予測」。これを買うのが広告主なのだ"
        },
        {
          "speaker": "めたん",
          "text": "予測の精度を上げるには…もっとデータが必要になりますわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。だからアプリは、ぼくたちをできるだけ長く引き留めようとする"
        },
        {
          "speaker": "ずんだもん",
          "text": "原材料の供給を止めたくないからなのだ"
        },
        {
          "speaker": "めたん",
          "text": "「あと1本だけ」って動画を見続けちゃうの、わたくしだけじゃないですわよね…"
        }
      ]
    },
    {
      "id": 14,
      "title": "ダークパターン",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そういう「つい続けてしまう」設計を、ダークパターンと呼ぶのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "2024年のarXivに公開された研究では64種類に分類されていて"
        },
        {
          "speaker": "ずんだもん",
          "text": "トップモバイルアプリの最大95%に何らかの形で存在すると報告されているのだ"
        },
        {
          "speaker": "めたん",
          "text": "95%！？ほぼ全アプリですの"
        },
        {
          "speaker": "ずんだもん",
          "text": "解約をわざと何ページも経由させたり、不安を煽って課金を促したり"
        },
        {
          "speaker": "ずんだもん",
          "text": "通知のタイミングを計算して、ちょうどスマホを置こうとした時に鳴らしたり"
        },
        {
          "speaker": "めたん",
          "text": "Amazon Primeの解約ページ、たしかに長かったですわ…あれもですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "代表的な例なのだ。こうやってぼくたちの注意力を精製所に送り続ける仕掛けなのだ"
        }
      ]
    },
    {
      "id": 15,
      "title": "ARPU推移",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "結果どうなったかというと、MetaのARPUを見るとわかるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ユーザー1人あたりの平均収益が、2011年の5ドルから2025年の57ドルに"
        },
        {
          "speaker": "ずんだもん",
          "text": "14年で10倍以上になっているのだ"
        },
        {
          "speaker": "めたん",
          "text": "1人あたりから搾り取れるデータの価値が10倍に増えたってことですわね…"
        },
        {
          "speaker": "ずんだもん",
          "text": "ただし地域差がすごくて、アメリカは68ドル、アジア太平洋は5.5ドルなのだ"
        },
        {
          "speaker": "めたん",
          "text": "でも聞けば聞くほど「じゃあ使わなきゃいい」って思うんですけど"
        },
        {
          "speaker": "ずんだもん",
          "text": "うん。でもそれが一番難しいのだ。次はその話をしよう"
        }
      ]
    },
    {
      "id": 16,
      "title": "ネットワーク効果",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "「嫌なら使わなきゃいい」って、正論に聞こえるよね"
        },
        {
          "speaker": "めたん",
          "text": "…でも正直、LINEをやめたら仕事にも友達付き合いにも支障が出ますわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "それが「ネットワーク効果」の罠なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "みんなが使ってるから自分も使う、自分が使うから人がさらに集まる"
        },
        {
          "speaker": "ずんだもん",
          "text": "このループが回りきったプラットフォームからは、簡単に抜けられないのだ"
        },
        {
          "speaker": "めたん",
          "text": "学校のグループLINE、自分だけ抜けるなんて無理ですわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "そしてこの「抜けられない」状況こそが、データを供給し続ける構造になっているのだ"
        }
      ]
    },
    {
      "id": 17,
      "title": "プライバシーパラドックス",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "Pew Research Centerの2023年の調査によると"
        },
        {
          "speaker": "ずんだもん",
          "text": "アメリカの成人の81%が企業のデータ利用に懸念を持っているのだ"
        },
        {
          "speaker": "めたん",
          "text": "8割が心配してる…でもみんな使い続けてますわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "それどころか、61%が「何をしても意味がない」と感じているのだ"
        },
        {
          "speaker": "めたん",
          "text": "あ…それ、わたくしも正直思ったことありますわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "これを「プライバシーパラドックス」と呼ぶのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "大事なのは、これはぼくたちの怠慢じゃないということなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "オプトアウトの手順がわざと複雑に設計されていたり"
        },
        {
          "speaker": "ずんだもん",
          "text": "そもそも代替手段がなかったりする、構造的な問題なのだ"
        },
        {
          "speaker": "めたん",
          "text": "個人の努力では限界がある、システム自体の問題なんですわね"
        }
      ]
    },
    {
      "id": 18,
      "title": "100年の系譜",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そしてこの構造は、実は100年の歴史があるのだ"
        },
        {
          "speaker": "めたん",
          "text": "100年も？"
        },
        {
          "speaker": "ずんだもん",
          "text": "1920年代、ラジオは無料で聴けたのだ。代わりに広告が流れた"
        },
        {
          "speaker": "ずんだもん",
          "text": "テレビも同じモデル。そしてインターネットが来て、スマホアプリに至る"
        },
        {
          "speaker": "めたん",
          "text": "ラジオとアプリ、時代は全然違いますけど…"
        },
        {
          "speaker": "ずんだもん",
          "text": "「コンテンツを無料で提供し、集まった注意力を広告主に売る」"
        },
        {
          "speaker": "ずんだもん",
          "text": "この基本構造は100年間、驚くほど変わっていないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "変わったのは、精度と速度だけなのだ"
        },
        {
          "speaker": "めたん",
          "text": "同じモデルが、テクノロジーでどんどん精密になっていった…"
        }
      ]
    },
    {
      "id": 19,
      "title": "Cookie廃止撤回",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "だからこそGoogleがCookieの廃止を4回も延期して結局撤回した話が象徴的なのだ"
        },
        {
          "speaker": "めたん",
          "text": "4回も延期…？"
        },
        {
          "speaker": "ずんだもん",
          "text": "廃止をテストしたら、パブリッシャーの広告収益が34%も落ちたのだ"
        },
        {
          "speaker": "めたん",
          "text": "3分の1も減ったらそりゃ撤回しますわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "100年かけて築いた構造を、簡単には壊せないのだ"
        },
        {
          "speaker": "めたん",
          "text": "じゃあ…この構造の中で、わたくしたちにできることはあるんですの？"
        }
      ]
    },
    {
      "id": 20,
      "title": "全部が悪じゃない",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここまでの話で「無料アプリは全部ダメだ」と思うかもしれないけど"
        },
        {
          "speaker": "ずんだもん",
          "text": "それは違うのだ"
        },
        {
          "speaker": "めたん",
          "text": "え？さっきまでの話を聞くと…"
        },
        {
          "speaker": "ずんだもん",
          "text": "Signalっていう暗号化メッセージアプリがあるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "月間7,000万人が使っていて、完全無料、広告ゼロ、データ収集もゼロなのだ"
        },
        {
          "speaker": "めたん",
          "text": "そんなアプリがあるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "非営利の財団が寄付で運営しているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "WhatsAppの共同創業者が5,000万ドルを寄付して始まったのだ"
        },
        {
          "speaker": "めたん",
          "text": "元WhatsAppの人が…面白い経緯ですわね"
        }
      ]
    },
    {
      "id": 21,
      "title": "Wikipediaモデル",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "Wikipediaも同じなのだ。年間2億ドル以上を寄付だけで運営しているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "800万人以上から平均10ドルの少額寄付が集まっているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "広告なし、追跡なし。20年以上これで成り立っているのだ"
        },
        {
          "speaker": "めたん",
          "text": "でもそういうサービスは少数派ですわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "だからこそ「無料」を一括りにしないことが大事なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "同じ「無料」でも、裏の仕組みはまったく違うのだ"
        }
      ]
    },
    {
      "id": 22,
      "title": "有料でも安心じゃない",
      "lines": [
        {
          "speaker": "めたん",
          "text": "逆に、有料アプリに切り替えれば安心ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "残念ながら、そうとも限らないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "有料のiOSアプリでも87%がデータ収集の有無を申告すらしていないのだ"
        },
        {
          "speaker": "めたん",
          "text": "有料なのにデータ収集…お金も取られてデータも取られるってことですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "「お金を払えば安全」も「無料は全部危険」も、どちらも単純化しすぎなのだ"
        },
        {
          "speaker": "めたん",
          "text": "白か黒かじゃなくて、グラデーションなんですわね"
        }
      ]
    },
    {
      "id": 23,
      "title": "値札を読む力",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "完璧な解決策はないのだ。でも3つだけ提案させてほしいのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "1つ目、「なぜこのアプリは無料なのか？」をまず考える習慣をつけること"
        },
        {
          "speaker": "めたん",
          "text": "たった一つの問いを持つだけでも違いますわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "2つ目、プライバシー設定を一度は確認すること"
        },
        {
          "speaker": "ずんだもん",
          "text": "面倒に設計されてるけど、だからこそ見る価値があるのだ"
        },
        {
          "speaker": "めたん",
          "text": "面倒なのはわざとだと知ってるだけでも、心構えが変わりますわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "3つ目、代替サービスの存在を知っておくことなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "Signal、Firefox、DuckDuckGo。完璧じゃなくても選択肢はあるのだ"
        },
        {
          "speaker": "めたん",
          "text": "全部を変える必要はなくて、「選べる」こと自体が大事なんですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "最初の問いに戻ろう。「タダより高いものはない」は本当だったか？"
        },
        {
          "speaker": "めたん",
          "text": "…少なくとも、見えなかった値札が見えるようになった気がしますわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "それだけで十分なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "値札が読めるようになれば、払うかどうかを自分で選べるのだ"
        },
        {
          "speaker": "めたん",
          "text": "見えない値札を読む力。これからは意識していきたいですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "ぼくたちの動画が、そのきっかけになれたら嬉しいのだ"
        }
      ]
    }
  ]
}