{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "id": 0,
      "title": "オープニング",
      "lines": [
        {
          "speaker": "めたん",
          "text": "今日のテーマは「パスワードの安全性」ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。いきなりだけど、衝撃的な数字から始めるのだ。"
        }
      ]
    },
    {
      "id": 1,
      "title": "15分で突破",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "2025年のHive Systemsの調査によると、8文字で数字だけのパスワードは、たった15分で解読されるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "15分…？お昼休みより短いじゃないですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかもこれ、特別なスパコンじゃなくて、市販のGPUを12台並べた環境での話なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ゲーム用のGPUですわよね？それで15分って…。"
        },
        {
          "speaker": "ずんだもん",
          "text": "じゃあ質問なのだ。記号や大文字を混ぜて「P@ss1234」みたいにしたら、どのくらい持つと思う？"
        },
        {
          "speaker": "めたん",
          "text": "うーん…記号も数字も入ってるし、数年くらいですの？"
        }
      ]
    },
    {
      "id": 2,
      "title": "解読時間の崖",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "Hive Systemsのデータだと、8文字で大小英字＋数字＋記号を混ぜても、164年なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "164年なら十分じゃないですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも12文字に伸ばすだけで、同じ文字種で約3,000年になるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "さらに13文字なら約560億年。宇宙の年齢の4倍なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "8文字から4〜5文字増やしただけで、年から億年に跳ね上がるんですの…？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。ここに今日の核心があるのだ。パスワードの安全性を決めているのは「記号を混ぜたか」じゃなくて、もっと根本的な数学の仕組みなのだ。"
        }
      ]
    },
    {
      "id": 3,
      "title": "世界一のパスワード",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "本題に入る前に、まず現実がどれだけヤバいか見ておくのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "NordPass 2025の調査によると、世界で最もよく使われるパスワードの1位は「123456」なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "わたくしも昔、とりあえず「123456」で登録して後で変えようと思ってそのまま…という経験がありますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "みんなそうなのだ。そしてこの調査だと、最もよく使われるパスワードの78%は1秒未満で解読可能だったのだ。"
        },
        {
          "speaker": "めたん",
          "text": "78%が1秒未満…ほとんど鍵がかかっていないのと同じですわね。"
        }
      ]
    },
    {
      "id": 4,
      "title": "漏洩の規模",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そしてここからが怖い話なのだ。Have I Been Pwnedという漏洩情報データベースがあるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2025年時点で120億件を超えるレコードが登録されているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "120億件…世界の人口より多いですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかも個別の事件を見ると規模がすごいのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2012年のLinkedIn漏洩では1億1,700万件のパスワードハッシュが流出したのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "SHA-1をソルトなしで使っていたせいで、大量のパスワードが即座に解読されたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "1億件超…大手サービスでもそんなことが起きるんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2013〜2014年のYahoo!の事件では、全30億アカウントが漏洩していたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "30億…当時のYahoo!ユーザー全員ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "Verizon DBIR 2025のレポートによると、今も侵害の初期アクセスの22%が盗まれた認証情報からなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そして2024年には28億件のパスワードがダークウェブで売買されていたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "でもパスワードって暗号化されて保存されてるんじゃないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "いい質問なのだ。実はそこが今日の話で一番大事なところなのだ。"
        }
      ]
    },
    {
      "id": 5,
      "title": "パスワード保存の仕組み",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まずパスワードがサービス側でどう保存されているか考えてみるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "まともなサービスはパスワードをそのまま保存しないのだ。「ハッシュ関数」という一方向の変換を通して、元に戻せない文字列にして保存するのだ。"
        },
        {
          "speaker": "めたん",
          "text": "一方向ということは、ハッシュ値からパスワードに戻す計算はできないんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。でもここで攻撃者は考えるのだ。「戻せないなら、こっちも同じ変換をかけて一致するか確かめればいい」と。"
        },
        {
          "speaker": "めたん",
          "text": "つまり片っ端からパスワードを試して、同じハッシュ値になるものを探す…？"
        },
        {
          "speaker": "ずんだもん",
          "text": "まさにそれが「ブルートフォース攻撃」なのだ。そして攻撃の速度を決めるのが、ハッシュ関数の「重さ」とGPUの処理能力なのだ。"
        }
      ]
    },
    {
      "id": 6,
      "title": "金庫のダイヤル",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここからが面白いところなのだ。さっき8文字と12文字で解読時間が激変したよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "あの差の正体は「エントロピー」という概念なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "エントロピーって物理で聞いた気がしますけど…情報量のことですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。ここではパスワードを金庫のダイヤルに例えて考えてみるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ダイヤルが数字0〜9の1桁なら、組み合わせは10通りなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "10回試せば確実に開きますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2桁にすると100通り、3桁で1,000通り。桁が1つ増えるたびに10倍になるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "掛け算で増えていく…指数関数ですわね。"
        }
      ]
    },
    {
      "id": 7,
      "title": "エントロピーの公式",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まさにそこなのだ。エントロピーの公式は、文字数×log₂（文字種の数）なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "たとえば数字だけで8文字なら、8×3.32で約26.6ビットなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ビットが大きいほど強い、ということですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "大小英字＋数字＋記号で8文字にすると52.4ビット。文字種を増やした効果は1.97倍なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも同じ文字種で12文字にすると78.8ビット。8文字の52.4ビットから26.4ビットも増える。"
        },
        {
          "speaker": "ずんだもん",
          "text": "26.4ビットの差は、組み合わせ数でいうと約8,800万倍の差なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "8,800万倍…！文字種を変えるより桁数を増やすほうが圧倒的に効くんですわね。"
        }
      ]
    },
    {
      "id": 8,
      "title": "文字種vs文字数",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここが多くの人が見落としているポイントなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「P@ss1234」は記号も大文字も入ってるけど8文字。エントロピーは最大でも52.4ビットなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも「mycatlikestuna」は小文字だけの15文字。エントロピーは約70.5ビットなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "え、記号なしの方が強いんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ランダムに選んだ場合の理論値ではそうなるのだ。ただし注意点があるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「mycatlikestuna」は英単語の組み合わせだから、辞書攻撃に対する実効エントロピーはもっと低くなるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あー、人間が考えるフレーズには偏りがありますわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。一般的に人が使う語彙は約3,000語と言われていて、4単語のパスフレーズだと実効エントロピーは46ビット程度まで下がるという指摘もあるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "大事なのは「長くてランダム」。この2つが揃って初めてエントロピーが最大化されるのだ。"
        }
      ]
    },
    {
      "id": 9,
      "title": "ハッシュ速度の差",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここまではパスワード側の話だったのだ。でも実は、もう一つの決定的な変数があるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "もう一つ？"
        },
        {
          "speaker": "ずんだもん",
          "text": "サービス側がパスワードを保存するときに使う「ハッシュ関数」の選び方なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "RTX 4090というGPU1枚でのベンチマークを見てほしいのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "MD5というハッシュ関数なら毎秒1,641億回計算できるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "1,641億…毎秒ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもbcryptというハッシュ関数だと毎秒約18万回。約89万倍遅いのだ。"
        },
        {
          "speaker": "めたん",
          "text": "同じGPUなのに89万倍も違うんですの！"
        }
      ]
    },
    {
      "id": 10,
      "title": "意図的な遅さ",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここが教科書的には「意図的な遅さ」と呼ばれる設計思想なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "bcryptは1999年に作られたハッシュ関数で、わざと計算を重くしているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ログイン時にユーザーが0.1秒待つのは気にならないけど、攻撃者が数十億回試すとなると致命的に遅くなるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "守る側は1回だけ計算すればいいけど、攻撃する側は何億回も計算しないといけない…。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。そして2015年にはArgon2というさらに強力なハッシュ関数が登場したのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Argon2idはPassword Hashing Competitionで優勝した設計で、メモリを大量に要求するのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "GPUは計算は速いけどメモリが小さいから、Argon2の前ではその強みが潰されるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "計算力だけじゃなくメモリも武器にする…なるほど、よく考えられてますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ちなみにハッシュ関数の歴史は面白いのだ。1976年のDES cryptから始まって、MD5、SHA、bcrypt、scryptと進化してきたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "新しいハッシュ関数が生まれるたびにGPUが高速化して追いつく。まさにいたちごっこなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "攻撃と防御の終わりなき競争ですわね。"
        }
      ]
    },
    {
      "id": 11,
      "title": "同じPWでも運命が違う",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "つまり同じ「Password123」でも、サービスがMD5で保存していたら数秒で破られるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもArgon2idで保存していたら数年かかるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "パスワードの強さだけじゃなくて、サービスの実装で運命が分かれるんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ここが怖いところなのだ。ユーザー側からはサービスが何のハッシュ関数を使っているか見えないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "えっ、じゃあどうしようもないですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "完全には防げないのだ。でもだからこそ「パスワードの使い回しをしない」ことが重要になるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1つのサービスが弱いハッシュで漏洩しても、他のサービスに影響しないからね。"
        }
      ]
    },
    {
      "id": 12,
      "title": "NISTの方針転換",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここでみんなの常識を1つ壊すのだ。"
        },
        {
          "speaker": "めたん",
          "text": "何ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "「パスワードは定期的に変更しましょう」。これ、今は公式に否定されているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "えっ？会社で3ヶ月ごとに変えさせられますけど…。"
        },
        {
          "speaker": "ずんだもん",
          "text": "NIST、アメリカ国立標準技術研究所が2024年に出したガイドラインで、定期変更は「してはならない」と明記したのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "英語で「SHALL NOT」。これは最も強い禁止の表現なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "え、なぜダメなんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "人間は定期変更を求められると、覚えやすい弱いパスワードに変えたり、末尾の数字だけ変えたりするのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "実はこのNISTのガイドラインの初版を書いたBill Burrさん本人が、後に「あのルールは間違いだった」と公に認めているのだ。"
        }
      ]
    },
    {
      "id": 13,
      "title": "旧常識vs新常識",
      "lines": [
        {
          "speaker": "めたん",
          "text": "作った本人が謝罪…それは衝撃的ですわね。じゃあ今はどうすればいいんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "NISTの新しい推奨をまとめるとこうなのだ。最小15文字、複雑性ルールの強制はしない、漏洩済みリストとの照合を必須にする。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そして変更は侵害が疑われるときだけ、なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "要するに「短くて複雑」より「長くてシンプル」のほうがいい、とNISTも認めたんですわね。"
        }
      ]
    },
    {
      "id": 14,
      "title": "LastPass事件",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そしてもう一つ、パスワードマネージャーの話もしておくのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2022年にLastPassが攻撃されて、暗号化されたパスワード金庫ごと盗まれたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "暗号化されていれば安全じゃないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "マスターパスワードが弱かったユーザーの金庫は実際に解読されたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "Krebs on Securityの報道によると、2025年末時点で累計1.5億ドル超の暗号通貨が盗まれたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "パスワードマネージャー自体は便利だけど、マスターパスワードが弱ければ意味がないんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう。どんなツールにも長所と短所があって、万能な解決策はないのだ。"
        }
      ]
    },
    {
      "id": 15,
      "title": "MFAも万能じゃない",
      "lines": [
        {
          "speaker": "めたん",
          "text": "でも多要素認証を入れれば安心じゃないですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "実はそこにも落とし穴があるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2024〜2025年のビジネスメール詐欺事案の79%で、MFA導入済みの環境が突破されているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "79%…MFAを入れてるのに突破されるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "SIMスワップでSMS認証を乗っ取ったり、リバースプロキシでセッションごと盗む手法があるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "だからこそUSPTOやFBI、CISAもSMS認証には公式に警告を出しているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "SMSの二段階認証って、一番よく使われてる印象ですけど…。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。フィッシング耐性があるのはパスキーのようなFIDO2方式だけなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "セキュリティは「何重にもガードする」のが大事で、どれか1つで完璧にはならないのだ。"
        }
      ]
    },
    {
      "id": 16,
      "title": "パスキーの仕組み",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "最後に「パスワードの未来」の話をするのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "パスキーという仕組みを聞いたことがあるかもしれないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "AppleやGoogleのログインで見かけますわ。あれはパスワードと何が違うんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "パスキーはFIDO2という規格に基づいていて、公開鍵暗号を使うのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ざっくり言うと、サーバーにパスワードを送る必要がそもそもないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "鍵のペアを作って、秘密鍵は自分のデバイスに、公開鍵だけサーバーに渡すのだ。"
        },
        {
          "speaker": "めたん",
          "text": "サーバーが攻撃されても秘密鍵は漏れない…それは強いですわね。"
        }
      ]
    },
    {
      "id": 17,
      "title": "普及のジレンマ",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "FIDO Allianceの2025年のレポートによると、消費者の69%がパスキーを1つ以上持っているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも実際にログインでパスキーを使っている割合は26%にとどまるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "持ってるけど使ってない人が多いんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ログイン成功率はパスキーが98%、パスワード＋MFAだと32%。体験は圧倒的に良いのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもレガシーシステムの移行に時間がかかるから、パスワードとの併存は当面続くのだ。"
        },
        {
          "speaker": "めたん",
          "text": "つまり今すぐパスワードを捨てられるわけではないんですわね。"
        }
      ]
    },
    {
      "id": 18,
      "title": "今日のまとめ",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。だから今日の話をまとめるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1つ目。パスワードの強さはエントロピーで決まる。文字種より文字数が指数関数的に効くのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2つ目。サービス側のハッシュ方式で解読時間が89万倍変わる。だから使い回しは絶対にダメなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "3つ目。NISTは定期変更を否定した。長くてランダムなパスワードを、サービスごとに固有で使うのだ。"
        },
        {
          "speaker": "めたん",
          "text": "冒頭の「8文字で15分」に戻りますけど、あの恐怖の対策はシンプルなんですわね。長くする、使い回さない、パスキーが使えるなら使う。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通りなのだ。パスワードは「複雑さの呪い」から「長さの数学」に移行しているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "仕組みを知れば、怖がるんじゃなくて正しく備えられるのだ。"
        }
      ]
    },
