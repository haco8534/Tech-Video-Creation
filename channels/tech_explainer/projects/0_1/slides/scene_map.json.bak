{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "id": 0,
      "title": "オープニング",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "突然だけど、レコードの表面を拡大して見たことはあるのだ？"
        },
        {
          "speaker": "めたん",
          "text": "溝がぐるぐる螺旋状に刻まれているんですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。あの溝の凹凸は音の振動をそのまま記録しているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "物理的に波の形を刻んでいるんですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "じゃあ、CDの表面を拡大するとどうなると思うのだ？"
        },
        {
          "speaker": "めたん",
          "text": "えっと……CDもなにか波っぽいものが刻まれてますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "いや、ただの穴の列なのだ。ピットって呼ばれる微細な凹みが並んでるだけ。"
        }
      ]
    },
    {
      "id": 1,
      "title": "溝と穴の違い",
      "lines": [
        {
          "speaker": "めたん",
          "text": "穴の列だけで音楽になるなんて、ちょっと信じがたいですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "レコードの溝は見るからに「音の形」をしているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもCDの穴は「ある」か「ない」か、つまり1か0の2択でしかないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "たった2種類の信号で、オーケストラの繊細な響きまで再現できますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "できるのだ。しかもレコードより正確に、ね。"
        },
        {
          "speaker": "めたん",
          "text": "……それは説明してもらわないと納得できませんわ。"
        }
      ]
    },
    {
      "id": 2,
      "title": "身近なデジタル",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "実はみんな、毎日「0と1の魔法」に囲まれて暮らしているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "スマホの写真、LINEのボイスメッセージ、この動画も全部0と1の羅列なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "言われてみれば……でも正直ピンと来ないですわ。"
        },
        {
          "speaker": "めたん",
          "text": "「なんとなく数字にしてるんだろうな」くらいの理解で止まってますの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "今日はその「なんとなく」を「なるほど！」に変えるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "まずは0と1だけでどうやって数を表すのか、そこから始めるのだ。"
        }
      ]
    },
    {
      "id": 3,
      "title": "モザイク画のたとえ",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "めたん、モザイク画って知ってるのだ？"
        },
        {
          "speaker": "めたん",
          "text": "小さなタイルを並べて絵を作るあれですわよね。教会とかでよく見ますわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。タイル1枚1枚は、ただの四角い色の塊でしかないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも何千、何万と並べると……。"
        },
        {
          "speaker": "めたん",
          "text": "遠くから見ると、まるで精密な絵画に見えますわ！"
        },
        {
          "speaker": "ずんだもん",
          "text": "デジタルデータもまったく同じ原理なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "0と1という超単純なタイルを膨大に並べて、複雑な情報を表現するのだ。"
        }
      ]
    },
    {
      "id": 4,
      "title": "2進数の仕組み",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "じゃあ具体的に考えてみるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ぼくらが普段使う10進数は0から9の10種類の数字を使うのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "9の次は桁が上がって10になるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それは当たり前ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "2進数は使える数字が0と1の2種類だけなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから1の次はもう桁が上がって「10」になるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "2進数の「10」は、わたくしたちの感覚だと「2」ってことですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。「11」が3、「100」が4。桁を増やすたびに表現できる数が倍になるのだ。"
        }
      ]
    },
    {
      "id": 5,
      "title": "ビット数と表現力",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここが面白いところなのだ。1桁だと2通り、2桁だと4通り、3桁だと8通り。"
        },
        {
          "speaker": "めたん",
          "text": "2の累乗で増えていくんですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "8ビットなら256通り。16ビットなら65,536通りなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "24ビットだと約1,677万通りにもなるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "1,677万！？ たった24個の0と1の並びでそんなに？"
        },
        {
          "speaker": "ずんだもん",
          "text": "これがモザイク画でいう「タイルの種類」にあたるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "タイルが2色でも、配置パターンが爆発的に増えればどんな絵でも描けるのだ。"
        }
      ]
    },
    {
      "id": 6,
      "title": "核心の一言",
      "lines": [
        {
          "speaker": "めたん",
          "text": "0と1しかなくても、並べ方が膨大だから何でも表現できるってことですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そういうことなのだ。実はスマホの画面の色も、この仕組みで表現されているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あの鮮やかな写真が、全部0と1の並びだと思うと不思議ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "じゃあ次は「音」をどうやって0と1に変えるのか、見ていくのだ。"
        }
      ]
    },
    {
      "id": 7,
      "title": "音は波である",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まず大前提として、音の正体は空気の振動、つまり波なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ギターの弦を弾くと空気が震えて、その波が鼓膜を揺らすんですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通り。で、この波は連続的に変化しているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "時間が流れるにつれて、振幅がなめらかに上下する。ここがポイントなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "連続的……つまり「境目がない」ってことですわね。"
        }
      ]
    },
    {
      "id": 8,
      "title": "もし波を数字にするなら",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "さて、ここで思考実験なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "この滑らかに動き続ける波を数字の列に変えたい。めたんならどうするのだ？"
        },
        {
          "speaker": "めたん",
          "text": "うーん……一定間隔で波の高さを測って、その値を記録する……とか？"
        },
        {
          "speaker": "ずんだもん",
          "text": "めたん、天才なのだ。まさにそれが「サンプリング」なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "正式には「標本化」っていうのだ。"
        },
        {
          "speaker": "めたん",
          "text": "え、本当にそんな単純な発想でいいんですの？"
        }
      ]
    },
    {
      "id": 9,
      "title": "サンプリングの様子",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "単純だけど強力なのだ。この波を1秒間に10回測ると、10個の数字が得られるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "10個だとかなり粗いですわね。波の細かい動きが抜け落ちそうですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "いい直感なのだ。じゃあ100回にしたら？1,000回にしたら？"
        },
        {
          "speaker": "めたん",
          "text": "回数を増やすほど、元の波に近づいていきますわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "CDの場合、1秒間に44,100回も測っているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "44,100回！？ そんなに細かければ、ほぼ元の波と同じでは……。"
        },
        {
          "speaker": "ずんだもん",
          "text": "人間が聞ける音は最高でも約2万ヘルツなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "44,100回はその2倍以上。なぜ2倍が大事かは、もう少し後で説明するのだ。"
        }
      ]
    },
    {
      "id": 10,
      "title": "量子化の説明",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ただ、まだ問題があるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "測った高さが「3.7823…」みたいに無限に続く小数だったら？"
        },
        {
          "speaker": "めたん",
          "text": "コンピュータって無限小数は扱えませんわよね……。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そこで「量子化」の出番なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「3.78…」を一番近い整数値、たとえば「4」に丸めるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "四捨五入みたいなものですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ざっくり言うとそうなのだ。CDでは16ビット、65,536段階の目盛りで丸めるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "65,536段階あれば、丸め誤差はほとんど感じないレベルですわね。"
        }
      ]
    },
    {
      "id": 11,
      "title": "A/D変換まとめ",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "最後に、この整数を2進数に変換して0と1の列にする。これが「符号化」なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "サンプリングで波を区切って、量子化で数値に丸めて、符号化で0と1にする。"
        },
        {
          "speaker": "めたん",
          "text": "この3段階ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "それがA/D変換、アナログからデジタルへの変換なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもここで一つ、気になることがあるはずなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "……区切った「間」の情報は、どこに行ったんですの？"
        }
      ]
    },
    {
      "id": 12,
      "title": "直感の提示",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "いい質問なのだ。多くの人はこう思うのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「点と点の間の波は失われた。だから完全には元に戻せない」と。"
        },
        {
          "speaker": "めたん",
          "text": "わたくしもそう思いましたわ。間の情報を捨てたなら復元は近似でしかないはずですの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "直感的にはその通りなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかもよく見る図解では、サンプリングした点をカクカクの階段でつないでいるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「デジタルの波形はガタガタです」みたいに説明されていることが多いのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あ、見たことありますわ。デジタルは階段状で、アナログは滑らか、みたいな比較。"
        }
      ]
    },
    {
      "id": 13,
      "title": "階段波形の誤解",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "実はあの図、大きな誤解を生んでいるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "え？"
        },
        {
          "speaker": "ずんだもん",
          "text": "デジタルを元に戻すとき、点をカクカクの直線で結ぶなんてしないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "DAコンバーターには「再構成フィルタ」というローパスフィルタが入っているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "これが数学的に元の滑らかな波を復元するのだ。"
        },
        {
          "speaker": "めたん",
          "text": "階段状にならないんですの！？"
        }
      ]
    },
    {
      "id": 14,
      "title": "標本化定理の核心",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ならないのだ。ここに数学の偉大さがあるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1949年にクロード・シャノンが証明した「標本化定理」。"
        },
        {
          "speaker": "ずんだもん",
          "text": "元の信号の最も高い周波数の2倍を超えるレートでサンプリングすれば……。"
        },
        {
          "speaker": "ずんだもん",
          "text": "元の連続信号を「完全に」復元できると証明されたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "完全に！？ 近似じゃなくて？"
        },
        {
          "speaker": "ずんだもん",
          "text": "近似じゃないのだ。数学的に証明された「完全復元」なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "CDの44,100回は、可聴域上限の約20,000ヘルツの2倍以上なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "だから可聴域の音はすべて完全に復元できる……。"
        }
      ]
    },
    {
      "id": 15,
      "title": "認識の転換",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ただし大事な注意点があるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "この定理は「信号が帯域制限されている」ことが前提なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "一定の周波数以上の成分を含まないという条件が必要なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "現実にはサンプリング前にフィルタで高周波をカットする処理が入るのだ。"
        },
        {
          "speaker": "めたん",
          "text": "万能ではないけど、条件を満たせば完全復元できるってことですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「デジタルはアナログの劣化コピー」は人間の耳の範囲では正しくないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "むしろCDのダイナミックレンジはレコードより約26デシベルも広いのだ。"
        },
        {
          "speaker": "めたん",
          "text": "デジタルのほうが正確……直感とは逆ですわね。イメージが崩れましたわ。"
        }
      ]
    },
    {
      "id": 16,
      "title": "データ量の現実",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "さて、ここまでで音を0と1にする方法はわかったのだ。でも問題があるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "CDは1秒で44,100回×16ビット×2チャンネル、約140万ビットなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1秒の音だけで約180キロバイト。3分の曲なら約30メガバイトなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "結構大きいですわね……。"
        },
        {
          "speaker": "ずんだもん",
          "text": "動画はもっと大変なのだ。フルHDは1フレーム約200万ピクセルなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "各ピクセル24ビットだから1枚で約6メガバイト。これが1秒に30枚。"
        },
        {
          "speaker": "めたん",
          "text": "1秒で180メガバイト！？ 3分の動画なら30ギガ超えですわ！"
        }
      ]
    },
    {
      "id": 17,
      "title": "画像も同じ原理",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ところでめたん、気づいたのだ？"
        },
        {
          "speaker": "ずんだもん",
          "text": "今ぼくは画像の説明をしたけど、やっていることは音と同じなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "あ……確かに。音は「波の高さ」を一定間隔で数値にするでしょう？"
        },
        {
          "speaker": "めたん",
          "text": "画像は「色の明るさ」をピクセルごとに数値にする。同じですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "動画は画像を時間方向に一定間隔で並べたもの。"
        },
        {
          "speaker": "ずんだもん",
          "text": "音も画像も動画も「連続的なものを区切って数値化する」同じ原理なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "次元が違うだけで同じ構造……さっきのモザイク画とも繋がりますわね！"
        }
      ]
    },
    {
      "id": 18,
      "title": "MP3の心理音響モデル",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "問題はこの膨大なデータ量をどう減らすかなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ここで人類は天才的な発想をしたのだ。「人間に知覚できない部分は捨てろ」。"
        },
        {
          "speaker": "めたん",
          "text": "捨てる！？ 大胆ですわね……。"
        },
        {
          "speaker": "ずんだもん",
          "text": "たとえばMP3の話をするのだ。人間の耳には「マスキング効果」があるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "大きな音の瞬間、近くの周波数の小さな音は聞こえなくなるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "ドラムがドンって鳴った瞬間に小さなノイズは聞こえない、みたいな？"
        },
        {
          "speaker": "ずんだもん",
          "text": "まさにそれなのだ。MP3はこの性質を数理モデル化したのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「今この瞬間、聞こえないはずの音」を特定してデータを大幅に削減する。"
        },
        {
          "speaker": "ずんだもん",
          "text": "結果、データ量を約10分の1に圧縮できるのだ。"
        }
      ]
    },
    {
      "id": 19,
      "title": "JPEGの圧縮原理",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "画像圧縮のJPEGも発想は同じなのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "人間の目は明るさの変化に敏感だけど、色の変化には鈍感なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "さらに細かいパターンの変化にも鈍感。"
        },
        {
          "speaker": "めたん",
          "text": "だから色情報を間引いても、細かいパターンを省略しても気づかない……。"
        },
        {
          "speaker": "ずんだもん",
          "text": "JPEGは画像を8×8のブロックに分けて数学的な変換をかけるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そのあと、人間の目が鈍感な高周波成分を大胆にカットするのだ。"
        }
      ]
    },
    {
      "id": 20,
      "title": "動画圧縮の仕組み",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "動画圧縮はさらに面白いのだ。連続するフレーム間で変化がない部分がある。"
        },
        {
          "speaker": "めたん",
          "text": "ニュースのキャスターなら背景はほとんど動きませんわよね。前のフレームを流用？"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通り。基準フレームを1枚記録して、あとは差分だけ記録するのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "H.264やH.265といったコーデックがこの方式を使っているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "だからYouTubeが数百メガバイトで済むんですのね。30ギガにはならないと。"
        }
      ]
    },
    {
      "id": 21,
      "title": "圧縮の限界",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ただし注意なのだ。MP3やJPEGの非可逆圧縮は情報を元に戻せないのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "MP3をFLACに変換しても、消えた音は復活しないのだ。"
        },
        {
          "speaker": "めたん",
          "text": "それでも実用上は問題ないんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "多くの場合はね。ただシンバルみたいな瞬間的な音では限界もあるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "万能ではないけど、人間の知覚の限界を逆手にとった賢い設計なのだ。"
        },
        {
          "speaker": "めたん",
          "text": "人間の弱点を利用するなんて、なんだか騙されてる気分ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもおかげで、スマホで高画質な動画をストリーミングで観られるのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "もし圧縮がなかったら、3分の動画のダウンロードに何時間もかかるのだ。"
        },
        {
          "speaker": "めたん",
          "text": "……圧縮様様ですわね。"
        }
      ]
    },
    {
      "id": 22,
      "title": "シャノンの貢献",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで少し歴史の話をするのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "1937年、イギリスのアレック・リーヴスがあるアイデアを思いついたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "「音声を0と1の列に変換すれば、ノイズに強い通信ができる」と。"
        },
        {
          "speaker": "めたん",
          "text": "1937年って、まだコンピュータもない時代ですわよね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。当時の技術では実現できなかったけど、発想は完成していたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "そして1948年、シャノンが情報理論で0と1の数学的基盤を確立したのだ。"
        },
        {
          "speaker": "めたん",
          "text": "その論文、「情報時代のマグナカルタ」って呼ばれていますわよね。"
        }
      ]
    },
    {
      "id": 23,
      "title": "技術の系譜",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "シャノンの理論からCDが生まれ、MP3が生まれ、JPEGが生まれたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "面白いのは、1972年にナシル・アーメッドが考案した離散コサイン変換。"
        },
        {
          "speaker": "ずんだもん",
          "text": "この一つの数学的手法がJPEGにもMPEGにもAACにも使われているのだ。"
        },
        {
          "speaker": "めたん",
          "text": "1つの数学的発見が、音声も画像も動画も支えている……すごい話ですわ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "ぜんぶ「連続→離散化→知覚に合わせて圧縮」っていう同じ哲学なのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "80年以上前のアイデアが、今のストリーミング時代を支えているのだ。"
        }
      ]
    },
    {
      "id": 24,
      "title": "日常の中の0と1",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "今この瞬間も、ぼくたちの声は0と1に変換されて届いているのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "スマホの写真、LINEの音声、電車のSuica、街のQRコードも全部そうなのだ。"
        },
        {
          "speaker": "めたん",
          "text": "全部、あの「サンプリング→量子化→符号化」の原理の応用ですのね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "最初にレコードの溝とCDの穴を見比べたのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "溝は音の形そのもので、穴はただの0と1に見えたのだ。"
        },
        {
          "speaker": "めたん",
          "text": "でもあの穴の列には、元の音を完全に復元する情報が詰まっていたんですわ。"
        }
      ]
    },
    {
      "id": 25,
      "title": "0と1が紡ぐ世界",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。0と1のたった2つの状態でも、並べ方は無限に近い。"
        },
        {
          "speaker": "ずんだもん",
          "text": "標本化定理が完全復元を保証し、圧縮が知覚の限界を巧みに利用する。"
        },
        {
          "speaker": "めたん",
          "text": "「0と1で何ができるか」より「できないこと」を探すほうが難しい時代ですわね。"
        },
        {
          "speaker": "ずんだもん",
          "text": "次にスマホで音楽を聴くとき、ちょっとだけ思い出してほしいのだ。"
        },
        {
          "speaker": "ずんだもん",
          "text": "膨大な0と1が、きみの耳と目が感じる世界を紡いでいるんだって、ね。"
        },
        {
          "speaker": "めたん",
          "text": "なんだか、いつもの音楽がちょっと違って聞こえそうですわ。"
        }
      ]
    }
  ]
}