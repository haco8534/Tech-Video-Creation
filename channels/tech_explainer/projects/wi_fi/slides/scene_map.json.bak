{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "id": 0,
      "title": "Wi-Fiと壁の物理学",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "みんなに聞きたいことがあるのだ"
        },
        {
          "speaker": "めたん",
          "text": "なんですの、改まって"
        },
        {
          "speaker": "ずんだもん",
          "text": "トイレでスマホの動画が止まったこと、あるのだ？"
        },
        {
          "speaker": "めたん",
          "text": "…あるに決まってますわ"
        },
        {
          "speaker": "めたん",
          "text": "リビングでは爆速なのに、ドア2枚隔てただけでクルクルですもの"
        }
      ]
    },
    {
      "id": 1,
      "title": "壁1枚で100分の1",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "実はコンクリート壁1枚で電波の強さはざっくり100分の1になるのだ"
        },
        {
          "speaker": "めたん",
          "text": "100分の1！？壁1枚でそんなにですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "NISTっていうアメリカの国立標準技術研究所が実測したデータがあるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "コンクリート壁の減衰はだいたい20dBなのだ"
        },
        {
          "speaker": "めたん",
          "text": "dBって聞いたことはあるけど、ピンと来ませんわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "dBは対数のスケールなのだ。10dBで電力10分の1なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "20dBなら100分の1、30dBなら1,000分の1なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "つまり10dB増えるごとに桁が1つ変わるのだ"
        },
        {
          "speaker": "めたん",
          "text": "わかりやすい…じゃあ壁2枚だと？"
        },
        {
          "speaker": "ずんだもん",
          "text": "40dBで1万分の1。3枚なら60dBで100万分の1なのだ"
        },
        {
          "speaker": "めたん",
          "text": "100万分の1…ほぼゼロじゃないですの"
        },
        {
          "speaker": "ずんだもん",
          "text": "マンションで寝室のWi-Fiが壊滅的な理由、これでわかるのだ"
        }
      ]
    },
    {
      "id": 2,
      "title": "素材で変わる減衰",
      "lines": [
        {
          "speaker": "めたん",
          "text": "でもわたくしの家は木造ですけど、それでもWi-Fi弱くなりますわよ？"
        },
        {
          "speaker": "ずんだもん",
          "text": "木材の減衰は約3dBで、電力はだいたい半分になる程度なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "石膏ボードならほぼ0dB、つまりほとんど素通りなのだ"
        },
        {
          "speaker": "めたん",
          "text": "コンクリートと石膏ボードで天と地の差ですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "マンション住まいと一戸建てでWi-Fi事情が全然違う理由がここにあるのだ"
        },
        {
          "speaker": "めたん",
          "text": "なるほど…でもなぜ素材でこんなに差が出ますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "それを理解するには、まず電波の正体を知る必要があるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "答えを先に言ってしまうと「電波は見えない光」なのだ"
        },
        {
          "speaker": "めたん",
          "text": "…見えない光？どういうことですの？"
        }
      ]
    },
    {
      "id": 3,
      "title": "電磁波スペクトル",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "Wi-Fiの電波も、部屋を照らしてる光も、実は同じ「電磁波」なのだ"
        },
        {
          "speaker": "めたん",
          "text": "電磁波…物理の授業で聞いた気がしますわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "電磁波は波の長さ、つまり「波長」で性質がガラッと変わるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "可視光の波長はだいたい400〜700ナノメートルなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "1ナノメートルは10億分の1メートル、目に見えないくらい短い波なのだ"
        },
        {
          "speaker": "めたん",
          "text": "相当小さいですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "一方でWi-Fiの2.4GHz帯は波長が約12.5センチなのだ"
        },
        {
          "speaker": "めたん",
          "text": "12.5センチ！？手のひらサイズじゃないですの"
        }
      ]
    },
    {
      "id": 4,
      "title": "波長10万倍の差",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "光と比べるとだいたい10万倍くらい長いのだ"
        },
        {
          "speaker": "めたん",
          "text": "10万倍も違ったら、そりゃ別物ですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも本質は同じ電磁波なのだ。違うのは波長だけなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ここで思考実験をしてみるのだ。プールの波を想像してほしいのだ"
        },
        {
          "speaker": "めたん",
          "text": "プールの波、ですの？"
        }
      ]
    },
    {
      "id": 5,
      "title": "プールの波と障害物",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "プールに板を立てたとするのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "小さなさざ波は板にぶつかって跳ね返るのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも波長の大きなうねりは、板の端を回り込んで向こう側に伝わるのだ"
        },
        {
          "speaker": "めたん",
          "text": "あっ、なるほど。波長が長いと障害物を回り込めるんですわね！"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通り。これを物理学では「回折」と呼ぶのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "Wi-Fiの波長12.5センチは、一般的な壁の厚さとだいたい同じくらいなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから完全には通り抜けられないけど、ある程度は回折で回り込めるのだ"
        },
        {
          "speaker": "めたん",
          "text": "光は波長が短すぎて回り込めない…だから壁の向こうは真っ暗ってことですのね"
        }
      ]
    },
    {
      "id": 6,
      "title": "波長が決める透過力",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そういうことなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "同じ電磁波なのに、波長が10万倍違うだけで「壁を通れるか通れないか」が決まるのだ"
        },
        {
          "speaker": "めたん",
          "text": "じゃあ波長が長いほど壁を通りやすいってことですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "大まかにはそうなのだ。でも話はそう単純じゃないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "波長だけじゃなくて壁の中身も重要なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "壁を通るとき電波に何が起きてるか、もう少し詳しく見ていくのだ"
        },
        {
          "speaker": "めたん",
          "text": "気になりますわ。壁の中で何が起きてるんですの？"
        }
      ]
    },
    {
      "id": 7,
      "title": "電波vs壁の3段階",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "電波が壁にぶつかるとき、大きく3つのことが同時に起きるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「反射」「吸収」「回折」の3つなのだ"
        },
        {
          "speaker": "めたん",
          "text": "1つずつ順番に聞きたいですわ"
        }
      ]
    },
    {
      "id": 8,
      "title": "反射のメカニズム",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まず反射なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "鏡に光が当たると跳ね返るように、電波も壁の表面で反射するのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "特に金属は電波をほぼ全部反射するのだ"
        },
        {
          "speaker": "めたん",
          "text": "じゃあ鉄筋コンクリートの中の鉄筋が電波を跳ね返してるんですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通り。鉄筋が反射して、さらにコンクリートが吸収する二重の壁なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "だからRC造のマンションは電波にとって最悪の環境なのだ"
        },
        {
          "speaker": "めたん",
          "text": "タワマンでWi-Fiが各部屋に届かない話、よく聞きますわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "面白いのは、反射は悪いことだけじゃないのだ"
        },
        {
          "speaker": "めたん",
          "text": "えっ、反射が良いこともあるんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "壁や天井で反射した電波が回り道してスマホに届くことがあるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "現代のWi-Fi技術、特にMIMOはこの反射波を積極的に活用しているのだ"
        },
        {
          "speaker": "めたん",
          "text": "敵を味方にする技術ですわね"
        }
      ]
    },
    {
      "id": 9,
      "title": "吸収のメカニズム",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "次に吸収なのだ。これが一番エネルギーを奪う仕組みなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "電波が壁の内部を通過するとき、素材の分子が電波のエネルギーを吸い取るのだ"
        },
        {
          "speaker": "めたん",
          "text": "吸い取ったエネルギーはどこに行きますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "熱になるのだ。ほんのわずかだけど壁が温まるのだ"
        },
        {
          "speaker": "めたん",
          "text": "えっ、まさか電子レンジと同じ原理ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "鋭いのだ！実はまさにその通りで、あとで詳しく話すのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "素材によって吸収量は全然違うのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "石膏ボードはほぼ素通りだけど、コンクリートは大量に吸収するのだ"
        },
        {
          "speaker": "めたん",
          "text": "さっきの素材別の差は、主に吸収の違いだったんですわね"
        }
      ]
    },
    {
      "id": 10,
      "title": "回折のメカニズム",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "最後に回折なのだ。さっきプールの波で話した現象なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "壁の端や廊下の曲がり角で電波が回り込んで、見えない場所にも届くのだ"
        },
        {
          "speaker": "めたん",
          "text": "回折があるおかげで、直接見えない部屋にもWi-Fiが届くんですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。ただし回り込むほどエネルギーは弱くなるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "廊下を2回曲がった先の部屋でWi-Fiが弱いのは、回折で2回エネルギーを失うからなのだ"
        },
        {
          "speaker": "めたん",
          "text": "そういうことだったんですわね…"
        }
      ]
    },
    {
      "id": 11,
      "title": "3つの複合効果",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "実際の壁では、この3つが同時に起きているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "電波の一部は反射で跳ね返り、一部は壁の中で吸収されて熱になるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "残ったわずかな分だけが向こう側に届くのだ"
        },
        {
          "speaker": "めたん",
          "text": "つまり壁が厚いほど吸収される量が増えて弱くなる…単純な話ですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "うん、それが80%正しい直感なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも…実は壁に「触れてすらいない」のに弱くなるケースがあるのだ"
        },
        {
          "speaker": "めたん",
          "text": "え？触れてないのに弱くなる？そんなことありますの？"
        }
      ]
    },
    {
      "id": 12,
      "title": "フレネルゾーン",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここがすごく面白いところなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "電波はレーザーみたいな細いビームじゃないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ルーターとスマホの間に、ラグビーボール型の見えない楕円体が広がっているのだ"
        },
        {
          "speaker": "めたん",
          "text": "ラグビーボール型の空間…ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "これを「フレネルゾーン」と呼ぶのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "この楕円体の60%以上が障害物から解放されていれば減衰はほぼゼロなのだ"
        },
        {
          "speaker": "めたん",
          "text": "60%…逆に言えば40%まではOKってことですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも60%を下回ると、急激に信号が弱くなるのだ"
        }
      ]
    },
    {
      "id": 13,
      "title": "壁ギリギリの棚",
      "lines": [
        {
          "speaker": "めたん",
          "text": "つまり壁に触れなくても、楕円体の中に食い込むだけで弱くなる…"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "たとえばルーターの横に大きな金属の本棚を置いただけで影響が出るのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "壁を1枚増やしたのと同じ効果が出ることもあるのだ"
        },
        {
          "speaker": "めたん",
          "text": "それはショックですわ…模様替えしたらWi-Fiが悪くなった経験、まさにそれかも"
        },
        {
          "speaker": "ずんだもん",
          "text": "実体験があるんだね。フレネルゾーンを知ってると原因がわかるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "さてここからもう一つ面白い話なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "さっきめたんが鋭いことを言ったのだ。電子レンジの話なのだ"
        }
      ]
    },
    {
      "id": 14,
      "title": "水と2.4GHz",
      "lines": [
        {
          "speaker": "めたん",
          "text": "あ、吸収のところで「電子レンジと同じ？」って聞いた話ですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "Wi-Fiの2.4GHz帯と電子レンジは全く同じ周波数を使っているのだ"
        },
        {
          "speaker": "めたん",
          "text": "えっ、同じ！？それは偶然ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "偶然じゃないのだ。歴史を辿ると1947年に遡るのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "2.4GHz帯はもともと電子レンジ用のISMバンドとして確保された帯域なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "1985年にアメリカのFCCが「この帯域を通信にも使っていいよ」と開放したのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "つまりWi-Fiが2.4GHzなのは、電波特性が建物に最適だからじゃなくて…"
        },
        {
          "speaker": "めたん",
          "text": "免許がいらなかったから、ですの？"
        }
      ]
    },
    {
      "id": 15,
      "title": "パターン統合",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "正解なのだ。そしてここでパターンに気づいてほしいのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "2.4GHzは水分子が特に効率よくエネルギーを吸収する周波数帯なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "電子レンジの近くでWi-Fiが途切れる、満員電車でWi-Fiが遅くなる"
        },
        {
          "speaker": "ずんだもん",
          "text": "湿気の多い日にWi-Fiの調子が悪い"
        },
        {
          "speaker": "ずんだもん",
          "text": "これ全部、「水が2.4GHzの電波を吸収している」という同じ原因なのだ"
        },
        {
          "speaker": "めたん",
          "text": "全部つながった…！人体も約60%が水ですわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "査読済み論文によると、人が1人動くだけでスループットが最大約20%低下するのだ"
        },
        {
          "speaker": "めたん",
          "text": "人間も電波にとっては「水の壁」だったんですわね"
        }
      ]
    },
    {
      "id": 16,
      "title": "2.4GHz vs 5GHz",
      "lines": [
        {
          "speaker": "めたん",
          "text": "ところで最近のルーターって2.4GHzと5GHzが選べますわよね"
        },
        {
          "speaker": "めたん",
          "text": "5GHzの方が速いから、とりあえず5GHzにしておけばいいんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "それが一番やりがちな落とし穴なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "iBwaveの実測データでは、コンクリート壁の減衰は2.4GHzで約23dBなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ところが5GHzだと約45dBまで跳ね上がるのだ"
        },
        {
          "speaker": "めたん",
          "text": "45dBって電力にすると…3万分の1以上ですわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "壁1枚でそこまで差が出るのだ"
        }
      ]
    },
    {
      "id": 17,
      "title": "周波数と波長の関係",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "5GHzは波長が約6センチ。2.4GHzの12.5センチの約半分なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "波長が短いと壁の素材に吸収されやすく、回折もしにくくなるのだ"
        },
        {
          "speaker": "めたん",
          "text": "速いけど壁に弱い。遅いけど壁に強い。まさにジレンマですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかもWi-Fi 6Eや7で使える6GHz帯はさらに壁に弱いのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "実測で、5GHzが-88dBmの場所で6GHzは-93dBmまで落ちるのだ"
        },
        {
          "speaker": "めたん",
          "text": "新しい規格ほど壁に弱くなるって、なんだか皮肉ですわね"
        }
      ]
    },
    {
      "id": 18,
      "title": "同じ部屋の逆転",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "でもここで面白い逆転現象があるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "密閉された1つの部屋の中なら5GHzの方が有利なことがあるのだ"
        },
        {
          "speaker": "めたん",
          "text": "えっ、壁に弱いはずの5GHzが有利？"
        },
        {
          "speaker": "ずんだもん",
          "text": "壁を「通り抜けにくい」ということは、壁で「よく反射する」ことでもあるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "密閉された部屋では反射波が効率よくデバイスに届くのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "エネルギーが部屋の外に漏れにくいから、中に留まるのだ"
        },
        {
          "speaker": "めたん",
          "text": "短所が長所に変わるんですわね"
        },
        {
          "speaker": "めたん",
          "text": "あ、そういえばマンションの隣の部屋に電波が漏れにくいのも同じ理屈ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "その通り。集合住宅で隣家のWi-Fiと干渉しにくいのは5GHzの利点なのだ"
        },
        {
          "speaker": "めたん",
          "text": "物理って面白いですわ。見方を変えると意味が逆転するんですわね"
        }
      ]
    },
    {
      "id": 19,
      "title": "万能解はない",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "だから「5GHzが最強」も「2.4GHzで十分」も、どちらも正しくないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "壁の素材、部屋の構造、ルーターとの距離で最適解は変わるのだ"
        },
        {
          "speaker": "めたん",
          "text": "万能な正解はないってことですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。でも物理法則を知っていれば自分の環境に合った選択ができるのだ"
        },
        {
          "speaker": "めたん",
          "text": "じゃあ具体的にどうすればWi-Fiは良くなるんですの？"
        }
      ]
    },
    {
      "id": 20,
      "title": "ルーター配置の科学",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "最初に一番大事なことを言うのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "高性能ルーターに買い替えても、壁の減衰量は1dBも変わらないのだ"
        },
        {
          "speaker": "めたん",
          "text": "えっ！？じゃあ何万円もするルーターって…"
        },
        {
          "speaker": "ずんだもん",
          "text": "処理速度や同時接続数は改善されるのだ。でも電波が壁を貫通する力は同じなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかも日本の電波法で出力の上限が決まっているから、高級機でも出力は変わらないのだ"
        },
        {
          "speaker": "めたん",
          "text": "なんと…性能とは別の話なんですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "さらに重要なのは、Wi-Fiは双方向通信だということなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ルーターの電波が届いても、スマホの返事がルーターに届かないと通信できないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "スマホの送信出力は約15ミリワットで、ルーターよりずっと弱いのだ"
        },
        {
          "speaker": "めたん",
          "text": "つまりスマホ側がボトルネックになるんですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "だからこそ物理的な配置が重要なのだ"
        }
      ]
    },
    {
      "id": 21,
      "title": "最適配置の原則",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ルーターのアンテナは水平方向に強く、垂直方向に弱い特性があるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "床に直置きすると、信号の大部分が床と天井に吸われてしまうのだ"
        },
        {
          "speaker": "めたん",
          "text": "高さ1メートルくらいの棚の上がいいってことですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。フレネルゾーンのことも思い出してほしいのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ルーターの周りにはあの楕円体の空間が必要なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから棚の隅に押し込むより、少し開けた場所に置く方がいいのだ"
        },
        {
          "speaker": "めたん",
          "text": "見た目は邪魔でも、物理的には正解なんですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "あとは家の中心に近い場所に置くのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "壁1枚で20dBの減衰なら、2枚通るルートと1枚のルートでは100倍の差になるのだ"
        },
        {
          "speaker": "めたん",
          "text": "配置を工夫するだけで100倍…これは今日すぐ試せますわね"
        }
      ]
    },
    {
      "id": 22,
      "title": "周波数の使い分け",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "周波数の使い分けも覚えておくといいのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ルーターと同じ部屋にいるなら5GHzで速度を最大限活かすのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "壁を隔てた別の部屋なら2.4GHzに切り替えるのだ"
        },
        {
          "speaker": "めたん",
          "text": "環境に合わせて使い分けるんですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "最近のルーターは自動で切り替える機能もあるけど、うまくいかない場合もあるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "そのときはSSIDを分けて手動で選ぶのも一つの手なのだ"
        }
      ]
    },
    {
      "id": 23,
      "title": "3つのポイント",
      "lines": [
        {
          "speaker": "めたん",
          "text": "改めて振り返ると、最初に壁1枚で100分の1って聞いたときは衝撃でしたわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも今は「なぜ100分の1になるか」その仕組みがわかったのだ"
        },
        {
          "speaker": "めたん",
          "text": "反射と吸収と回折…壁の中で電波の三つ巴の戦いが起きてたんですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "フレネルゾーンで壁に触れなくても弱くなるし、水分子が電波を吸うのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でもその仕組みを知っていれば、配置や周波数で対策できるのだ"
        },
        {
          "speaker": "めたん",
          "text": "全部つながりましたわ"
        },
        {
          "speaker": "めたん",
          "text": "物理法則を知ると、Wi-Fiへの不満が「なるほど」に変わりますわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "最後にもう一つだけ伝えたいのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "最新のWi-Fi 6や7は壁の透過力自体は改善していないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "改善しているのは電波の使い方の効率であって、物理法則は変えられないのだ"
        },
        {
          "speaker": "めたん",
          "text": "テクノロジーが進歩しても、物理の壁は超えられないんですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "だからこそ物理を知ることに意味があるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "Wi-Fiは魔法じゃなくて物理なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "物理法則を味方につければ、今日からWi-Fi環境は改善できるのだ"
        },
        {
          "speaker": "めたん",
          "text": "さっそく帰ったらルーターの位置を見直しますわ！"
        }
      ]
    }
  ]
}