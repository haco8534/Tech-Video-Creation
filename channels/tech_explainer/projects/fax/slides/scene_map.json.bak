{
  "voicevox_url": "http://localhost:50021",
  "speakers": {
    "ずんだもん": 3,
    "めたん": 2
  },
  "speed_scale": 1.14,
  "inter_line_silence": 0.3,
  "scene_end_padding": 0.5,
  "scenes": [
    {
      "id": 0,
      "title": "オープニング",
      "lines": [
        {
          "speaker": "めたん",
          "text": "今日のテーマは「なぜ日本だけFAXが生き残っているのか」ですわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "2020年の春、東京都の保健所がパンクしたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "原因はサーバーダウンでもハッキングでもないのだ"
        }
      ]
    },
    {
      "id": 1,
      "title": "4065人の計上漏れ",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "FAXなのだ"
        },
        {
          "speaker": "めたん",
          "text": "FAX…ですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "感染者情報を保健所に手書きでFAXして、受け取った側も手入力していたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "結果、東京都だけで4,065人の計上漏れが起きたのだ"
        },
        {
          "speaker": "めたん",
          "text": "4,065人…第5波のピーク時ですわよね。正確な感染状況がわからなくなっていたと"
        },
        {
          "speaker": "ずんだもん",
          "text": "このニュースで多くの人が思ったはずなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「2020年にもなって、なんで日本はまだFAXなんか使ってるんだ」って"
        }
      ]
    },
    {
      "id": 2,
      "title": "素朴な疑問",
      "lines": [
        {
          "speaker": "めたん",
          "text": "正直、わたくしもそう思いましたわ。メールじゃだめなの？って"
        },
        {
          "speaker": "ずんだもん",
          "text": "だよね。でもね、調べていくと全然違う景色が見えてくるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ここでひとつ質問するのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "日本、アメリカ、ドイツ。業務でFAXを一番使っている国はどこだと思う？"
        },
        {
          "speaker": "めたん",
          "text": "それは…日本に決まってますわよね？"
        },
        {
          "speaker": "ずんだもん",
          "text": "その答えは後半でひっくり返るのだ。楽しみにしていてほしいのだ"
        }
      ]
    },
    {
      "id": 3,
      "title": "FAXの誕生",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "まずFAXがどういう技術なのか、歴史から見ていくのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "FAXの原型が特許を取られたのは1843年なのだ"
        },
        {
          "speaker": "めたん",
          "text": "1843年…？それって江戸時代の終わりごろですわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "しかも電話の特許は1876年なのだ"
        },
        {
          "speaker": "めたん",
          "text": "えっ、FAXの方が電話より33年も古いんですの！？"
        },
        {
          "speaker": "ずんだもん",
          "text": "意外でしょ？画像を電気信号にして送る発想は、声を送るより先に生まれたのだ"
        },
        {
          "speaker": "めたん",
          "text": "てっきりFAXは電話の後に出てきた技術だと思ってましたわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ただしこれは原型の話で、ぼくたちが知るFAXとはだいぶ違うのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "現代のFAXが本格的に普及し始めたのは1980年代なのだ"
        }
      ]
    },
    {
      "id": 4,
      "title": "漢字という壁",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "1980年にG3という国際規格ができて、A4を約1分で送れるようになったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "日本メーカーがこぞって参入して、一気に価格が下がったのだ"
        },
        {
          "speaker": "めたん",
          "text": "そのころのパソコン事情はどうだったんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ここが日本にとって決定的だったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "英語はアルファベット26文字。キーボードで打てばそのまま文書になるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも日本語は漢字が何千文字もあるのだ"
        },
        {
          "speaker": "めたん",
          "text": "変換という手間がありますわね。しかも当時の変換精度は…"
        },
        {
          "speaker": "ずんだもん",
          "text": "ひどかったのだ。使い物にならないレベルだったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「会議」と打ちたいのに「怪奇」が出てくるような時代なのだ"
        },
        {
          "speaker": "めたん",
          "text": "それは仕事にならないですわね…"
        }
      ]
    },
    {
      "id": 5,
      "title": "世帯保有率57%",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "そこにFAXが現れたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "手書きの文書をそのまま送れる。漢字も図面も地図も関係ないのだ"
        },
        {
          "speaker": "めたん",
          "text": "なるほど…FAXは日本語の壁を飛び越える道具だったんですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "まさにそうなのだ。いわば「日本語の翻訳機」だったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "1981年にNTTがFAX通信網を整備して料金も下がったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "結果、日本の世帯保有率はピーク時に57%に達したのだ"
        },
        {
          "speaker": "めたん",
          "text": "2軒に1軒以上にFAXがあったんですの…"
        },
        {
          "speaker": "ずんだもん",
          "text": "当時の日本にとってFAXは「古い技術」じゃなかったのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "漢字文化圏における最適解だったのだ"
        },
        {
          "speaker": "めたん",
          "text": "でも今はパソコンもスマホも日本語入力が普通にできますわよね"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。だから問題は「なぜ普及したか」ではないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「なぜ今もやめられないのか」。ここからが本題なのだ"
        }
      ]
    },
    {
      "id": 6,
      "title": "抜けられない構造",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで一つたとえ話をするのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ある町で全員が右側通行をしているとするのだ"
        },
        {
          "speaker": "めたん",
          "text": "はい"
        },
        {
          "speaker": "ずんだもん",
          "text": "自分だけ左側通行に変えたらどうなる？"
        },
        {
          "speaker": "めたん",
          "text": "正面衝突しますわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。交通ルールは全員が同時に切り替えないと機能しないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "FAXの問題もまったく同じ構造なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "自社がメールに変えても、取引先がFAXなら結局FAXが必要なのだ"
        },
        {
          "speaker": "めたん",
          "text": "一社だけ頑張っても意味がない…"
        }
      ]
    },
    {
      "id": 7,
      "title": "個社vs業界全体",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "経済学ではこれを「ネットワーク外部性」と呼ぶのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "みんなが使っているから自分も使う。抜けたくても抜けられないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "製造業や建設業では、発注書を毎日FAXでやりとりしているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "取引先が100社あれば、100社全部に「メールにしませんか」と頼む必要があるのだ"
        },
        {
          "speaker": "めたん",
          "text": "それは気が遠くなりますわね…。しかも相手にもシステム変更の負担がかかる"
        },
        {
          "speaker": "ずんだもん",
          "text": "中小企業にとっては「番号を入れて送信ボタンを押すだけ」の手軽さも大きいのだ"
        },
        {
          "speaker": "めたん",
          "text": "確かに、わたくしの実家の町工場でもFAXで注文を受けてましたわ"
        },
        {
          "speaker": "ずんだもん",
          "text": "それなのだ。新しいシステムを入れるにはお金も勉強も必要なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "IT担当者なんていない会社がほとんどだからね"
        },
        {
          "speaker": "めたん",
          "text": "でも国が「やめろ」と言えば変わりませんの？"
        }
      ]
    },
    {
      "id": 8,
      "title": "三重の壁",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "実はそれも試されたのだ。でもうまくいかなかった"
        },
        {
          "speaker": "ずんだもん",
          "text": "FAXが残っている背景には大きく三つの壁があるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "一つ目はハンコ文化なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "1997年に政府がペーパーレス化を推進しようとしたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ところが印鑑業界がわずか3万5000人の署名で計画を潰してしまったのだ"
        },
        {
          "speaker": "めたん",
          "text": "3万5000人の署名で国の方針が変わるんですの…？"
        },
        {
          "speaker": "ずんだもん",
          "text": "紙がなくなればハンコも要らなくなる。業界にとっては生き残りの問題だったのだ"
        },
        {
          "speaker": "めたん",
          "text": "紙が消えればハンコが消える。ハンコが消えればFAXの出番も減る…"
        },
        {
          "speaker": "ずんだもん",
          "text": "そう、紙・ハンコ・FAX。この三つは運命共同体なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "どれか一つだけを変えようとしても、残り二つが引き戻すのだ"
        }
      ]
    },
    {
      "id": 9,
      "title": "法制度の壁",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "二つ目は法制度の壁なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "電子帳簿保存法は1998年にできたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも「改ざん防止措置」や「検索機能の確保」など要件が厳しすぎたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "現場からすると「紙で保存した方が楽で確実」だったのだ"
        },
        {
          "speaker": "めたん",
          "text": "法律はあるのに使えない。それが20年近く続いたと"
        },
        {
          "speaker": "ずんだもん",
          "text": "ざっくり言えば、制度が現場の実態に追いつかなかったのだ"
        }
      ]
    },
    {
      "id": 10,
      "title": "世代別FAX保有率",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "三つ目は高齢化なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "日本のFAX世帯保有率を年代別に見ると、景色がまったく違うのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "20代はわずか0.9%。ほぼゼロなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも60代以上は30%を超えているのだ"
        },
        {
          "speaker": "めたん",
          "text": "同じ日本でも、世代によって別の国みたいですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "80代以上のインターネット利用率は36%しかないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "スマホを使わない理由の1位が「自分の生活に必要ない」で52%なのだ"
        },
        {
          "speaker": "めたん",
          "text": "その世代にとってFAXは現役の、むしろ唯一の通信手段ですのね"
        },
        {
          "speaker": "ずんだもん",
          "text": "ハンコ、法制度、高齢化。この三つが絡み合っているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ここまで聞くと「やっぱり日本は遅れてるんだな」と思うかもしれないのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "でも、ここからが本当に面白い話なのだ"
        }
      ]
    },
    {
      "id": 11,
      "title": "常識が覆る瞬間",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "さっき冒頭で質問したのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "日本、アメリカ、ドイツ。業務FAX利用率が一番高いのはどこか"
        },
        {
          "speaker": "めたん",
          "text": "もう待ちきれませんわ。答えを教えてくださいまし"
        },
        {
          "speaker": "ずんだもん",
          "text": "2024年のCIAJの調査を見てほしいのだ"
        }
      ]
    },
    {
      "id": 12,
      "title": "日米独FAX利用率",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "日本40.1%、ドイツ50.7%、そしてアメリカは69.0%なのだ"
        },
        {
          "speaker": "めたん",
          "text": "……え？日本が一番低いんですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "そうなのだ。ぼくも最初見たとき目を疑ったのだ"
        },
        {
          "speaker": "めたん",
          "text": "アメリカが69%！？SlackとかTeamsの国じゃないですの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "さらに「今後もFAXを使い続けたい」という意向は米独が8割以上なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "日本は7割台で、むしろ脱FAX意向は三か国で最も強いのだ"
        },
        {
          "speaker": "めたん",
          "text": "完全に予想と逆ですわ…。じゃあ「日本だけFAX大国」って一体何だったんですの"
        }
      ]
    },
    {
      "id": 13,
      "title": "各国のFAX事情",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "なぜ他の先進国でもFAXが残っているか見ていくのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "アメリカでは医療業界がFAXの最大ユーザーなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "HIPAA法という患者情報保護の法律があって、FAXは準拠手段として認められているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "コロナ禍ではアメリカでもFAXで感染者数を報告して大混乱になったのだ"
        },
        {
          "speaker": "めたん",
          "text": "日本だけの問題ではなかったんですわね…"
        },
        {
          "speaker": "ずんだもん",
          "text": "ドイツでも病院間の患者情報をFAXで送るのが普通なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "「メールはハッキングされうるけどFAXなら安全」という認識があるのだ"
        },
        {
          "speaker": "めたん",
          "text": "先進国でも、セキュリティを理由にFAXが選ばれているんですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "世界全体で見ると、今も約4,300万台のFAXが稼働しているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "購入台数はアメリカが1位、日本は2位なのだ"
        },
        {
          "speaker": "めたん",
          "text": "買ってる数もアメリカの方が多いんですの…"
        }
      ]
    },
    {
      "id": 14,
      "title": "なぜ日本だけ注目される",
      "lines": [
        {
          "speaker": "めたん",
          "text": "でもなぜ海外メディアは「日本だけ」と取り上げますの？"
        },
        {
          "speaker": "ずんだもん",
          "text": "ポイントは「業務利用率」と「家庭保有率」の違いなのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "日本の家庭保有率は24.6%。アメリカは約5%なのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "業務では使うけど家にはない。それがアメリカなのだ"
        },
        {
          "speaker": "めたん",
          "text": "「家庭にFAXがある」こと自体が珍しいと"
        },
        {
          "speaker": "ずんだもん",
          "text": "さらに日本にはFAXとハンコと紙が三点セットで残っているのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "2025年にCNNが「かつての技術大国がなぜFAXとハンコに固執するのか」と報じたのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "技術の遅れではなく、この「三点セット」が絵になるから注目されるのだ"
        },
        {
          "speaker": "めたん",
          "text": "単体では他国にもあるのに、組み合わせが独特だということですわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "2018年には日本のサイバーセキュリティ担当大臣が「PCを使ったことがない」と発言して世界中で報じられたのだ"
        },
        {
          "speaker": "めたん",
          "text": "それはさすがに衝撃ですわ…"
        },
        {
          "speaker": "ずんだもん",
          "text": "こういうエピソードが積み重なって「日本＝ハイテクなのにローテク」というイメージが定着したのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "ただし注意が必要で、この調査は国ごとに定義や対象者が違う可能性があるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "だから数字の単純比較には限界がある。でも「日本だけが異常」は一面的なのだ"
        }
      ]
    },
    {
      "id": 15,
      "title": "小切手とFAX",
      "lines": [
        {
          "speaker": "ずんだもん",
          "text": "ここで視点をもう一段広げてみるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "アメリカには別の「なぜまだ使ってるの？」があるのだ。小切手なのだ"
        },
        {
          "speaker": "めたん",
          "text": "小切手…日本ではほとんど見ませんわね"
        },
        {
          "speaker": "ずんだもん",
          "text": "アメリカでは2020年代でも家賃を小切手で払う人がたくさんいるのだ"
        },
        {
          "speaker": "ずんだもん",
          "text": "手書きサインが不正防止になるし、クレジットカードの手数料もかからないのだ"
        },
        {
          "speaker": "めたん",
